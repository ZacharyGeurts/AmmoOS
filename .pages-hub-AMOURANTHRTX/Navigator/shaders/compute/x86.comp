float dosHudRamStr(vec2 uv, float x0, float rowY, vec2 cell, uint ramBase, uint maxChars) {
    float ink = 0.0;
    float x = x0;
    for (uint i = 0u; i < maxChars; ++i) {
        uint ch = ramByte(ramBase + i);
        if (ch == 0u) break;
        if (ch < 32u || ch >= 0x80u) continue;
        ink = max(ink, dosHudGlyph(ch, uv, x, rowY, cell));
        x += cell.x;
    }
    return ink;
}

float dosHudRamStrBorder(vec2 uv, float x0, float rowY, vec2 cell, uint ramBase, uint maxChars) {
    float border = 0.0;
    border = max(border, dosHudRamStr(uv + vec2(-1.0, 0.0), x0, rowY, cell, ramBase, maxChars));
    border = max(border, dosHudRamStr(uv + vec2(1.0, 0.0), x0, rowY, cell, ramBase, maxChars));
    border = max(border, dosHudRamStr(uv + vec2(0.0, -1.0), x0, rowY, cell, ramBase, maxChars));
    border = max(border, dosHudRamStr(uv + vec2(0.0, 1.0), x0, rowY, cell, ramBase, maxChars));
    border = max(border, dosHudRamStr(uv + vec2(-1.0, -1.0), x0, rowY, cell, ramBase, maxChars));
    border = max(border, dosHudRamStr(uv + vec2(1.0, -1.0), x0, rowY, cell, ramBase, maxChars));
    border = max(border, dosHudRamStr(uv + vec2(-1.0, 1.0), x0, rowY, cell, ramBase, maxChars));
    border = max(border, dosHudRamStr(uv + vec2(1.0, 1.0), x0, rowY, cell, ramBase, maxChars));
    return border;
}

float dosHudRunBorder(vec2 uv, float x0, float rowY, vec2 cell,
    uint c0, uint c1, uint c2, uint c3, uint c4, uint c5, uint c6, uint c7) {
    float border = 0.0;
    border = max(border, dosHudRun(uv + vec2(-1.0, 0.0), x0, rowY, cell, c0, c1, c2, c3, c4, c5, c6, c7));
    border = max(border, dosHudRun(uv + vec2(1.0, 0.0), x0, rowY, cell, c0, c1, c2, c3, c4, c5, c6, c7));
    border = max(border, dosHudRun(uv + vec2(0.0, -1.0), x0, rowY, cell, c0, c1, c2, c3, c4, c5, c6, c7));
    border = max(border, dosHudRun(uv + vec2(0.0, 1.0), x0, rowY, cell, c0, c1, c2, c3, c4, c5, c6, c7));
    border = max(border, dosHudRun(uv + vec2(-1.0, -1.0), x0, rowY, cell, c0, c1, c2, c3, c4, c5, c6, c7));
    border = max(border, dosHudRun(uv + vec2(1.0, -1.0), x0, rowY, cell, c0, c1, c2, c3, c4, c5, c6, c7));
    border = max(border, dosHudRun(uv + vec2(-1.0, 1.0), x0, rowY, cell, c0, c1, c2, c3, c4, c5, c6, c7));
    border = max(border, dosHudRun(uv + vec2(1.0, 1.0), x0, rowY, cell, c0, c1, c2, c3, c4, c5, c6, c7));
    return border;
}

const vec3 AOS_INK_BLACK = vec3(0.97, 0.98, 1.0);
const vec3 AOS_INK_DIM = vec3(0.76, 0.78, 0.84);
const vec3 AOS_INK_TASKBAR = vec3(0.97, 0.98, 1.0);

float vgaGlyphBorder(uint ch, vec2 cell, uint px, uint py) {
    float b = 0.0;
    if (px > 0u) b = max(b, fontOn(ch, px - 1u, py) ? 1.0 : 0.0);
    if (px < 7u) b = max(b, fontOn(ch, px + 1u, py) ? 1.0 : 0.0);
    if (py > 0u) b = max(b, fontOn(ch, px, py - 1u) ? 1.0 : 0.0);
    if (py < 15u) b = max(b, fontOn(ch, px, py + 1u) ? 1.0 : 0.0);
    return b;
}

float dosHudUintInk(vec2 uv, float x0, float rowY, vec2 cell, uint val, uint minDigits) {
    float ink = 0.0;
    uint divv = 1u;
    for (uint i = 1u; i < 10u; ++i) {
        if (val / divv < 10u && i >= minDigits) break;
        divv *= 10u;
    }
    float x = x0;
    for (uint place = divv; place >= 1u; place /= 10u) {
        uint digit = (val / place) % 10u;
        ink = max(ink, dosHudGlyph(48u + digit, uv, x, rowY, cell));
        x += cell.x;
        if (place == 1u) break;
    }
    return ink;
}

float dosHudIconMem(vec2 uv, vec2 origin) {
    vec2 b = (uv - origin) / vec2(14.0, 14.0);
    if (any(lessThan(b, vec2(0.0))) || any(greaterThanEqual(b, vec2(1.0)))) return 0.0;
    float chip = step(0.12, b.x) * step(b.x, 0.88) * step(0.18, b.y) * step(b.y, 0.82);
    float pins = step(0.04, b.x) * step(b.x, 0.96) * (step(b.y, 0.16) + step(0.84, b.y));
    return clamp(chip + pins * 0.65, 0.0, 1.0);
}

float dosHudIconDisk(vec2 uv, vec2 origin) {
    vec2 b = (uv - origin) / vec2(14.0, 14.0);
    if (any(lessThan(b, vec2(0.0))) || any(greaterThanEqual(b, vec2(1.0)))) return 0.0;
    vec2 c = b - 0.5;
    float disk = smoothstep(0.34, 0.28, length(c)) * (1.0 - smoothstep(0.10, 0.04, length(c)));
    float hub = 1.0 - smoothstep(0.0, 0.10, length(c));
    return clamp(disk + hub * 0.8, 0.0, 1.0);
}

float dosHudIconDrive(vec2 uv, vec2 origin) {
    vec2 b = (uv - origin) / vec2(14.0, 14.0);
    if (any(lessThan(b, vec2(0.0))) || any(greaterThanEqual(b, vec2(1.0)))) return 0.0;
    float body = step(0.10, b.x) * step(b.x, 0.90) * step(0.30, b.y) * step(b.y, 0.88);
    float slot = step(0.22, b.x) * step(b.x, 0.78) * step(0.42, b.y) * step(b.y, 0.56);
    return clamp(body + slot * 0.55, 0.0, 1.0);
}

vec3 dosStatusHudColor(vec2 uv, vec2 winSize, float hudH, ThemePal th) {
    float uiSc = max(winSize.x / 1920.0, 0.75) * 1.35;
    float footY0 = winSize.y - hudH;
    float localY = uv.y - footY0;
    vec3 topCol = vec3(0.86, 0.86, 0.88);
    vec3 botCol = vec3(0.74, 0.74, 0.78);
    vec3 col = mix(topCol, botCol, clamp(localY / max(hudH, 1.0), 0.0, 1.0));
    float edge = smoothstep(0.0, 1.2, hudH - localY);
    col *= 1.0 - edge * 0.06;

    vec2 cell = aosHudTextCell(uiSc);
    float rowY = footY0 + hudH * 0.5 - 8.0 * uiSc;
    float ink = dosHudRamStr(uv, 10.0 * uiSc, rowY, cell, AOS_FOOTER_RAM + 1u, AOS_FOOTER_LEN);
    float inkB = dosHudRamStrBorder(uv, 10.0 * uiSc, rowY, cell, AOS_FOOTER_RAM + 1u, AOS_FOOTER_LEN);
    return mixHudInk(col, ink, inkB, AOS_INK_BLACK);
}

const uint VGA_PAL_BYTE = 0x98000u;
const uint VGA_FB_BYTE = 0xA0000u;
const uint VGA_META_BYTE = 0x98FF0u;
const uint VGA_LFB_BYTE = 0xE00000u;
const uint VGA_MODE_13 = 0x13u;
const uint VGA_MODE_EGA0D = 0x0Du;
const uint VGA_MODE_EGA12 = 0x12u;
const uint VGA_MODE_VOODOO = 0xA0u;
const uint VGA_MODE_SVGA = 0xFEu;

vec3 vgaPalRam(uint idx) {
    uint b = VGA_PAL_BYTE + (idx & 0xFFu) * 3u;
    uint r = ramByte(b);
    uint g = ramByte(b + 1u);
    uint b0 = ramByte(b + 2u);
    return vec3(float(r), float(g), float(b0)) / 255.0;
}

uvec2 dosVideoMetaSize() {
    uint w = uint(ramByte(VGA_META_BYTE)) | (uint(ramByte(VGA_META_BYTE + 1u)) << 8u);
    uint h = uint(ramByte(VGA_META_BYTE + 2u)) | (uint(ramByte(VGA_META_BYTE + 3u)) << 8u);
    if (w < 8u) w = 320u;
    if (h < 8u) h = 200u;
    return uvec2(w, h);
}

vec3 dosSampleMode13(vec2 gameUv) {
    gameUv = clamp(gameUv, vec2(0.0), vec2(0.9999));
    uint x = min(uint(floor(gameUv.x * 320.0)), 319u);
    uint y = min(uint(floor(gameUv.y * 200.0)), 199u);
    uint idx = ramByte(VGA_FB_BYTE + y * 320u + x);
    return vgaPalRam(idx);
}

vec3 dosSampleModeEga(vec2 gameUv, uvec2 size) {
    gameUv = clamp(gameUv, vec2(0.0), vec2(0.9999));
    uint x = min(uint(floor(gameUv.x * float(size.x))), size.x - 1u);
    uint y = min(uint(floor(gameUv.y * float(size.y))), size.y - 1u);
    uint idx = ramByte(VGA_FB_BYTE + y * size.x + x) & 0x0Fu;
    return vgaPalRam(idx);
}

vec3 dosCgaColor(uint idx) {
    const vec3 PAL[4] = vec3[4](
        vec3(0.0, 0.0, 0.0),
        vec3(0.0, 0.67, 0.0),
        vec3(0.67, 0.0, 0.0),
        vec3(0.67, 0.67, 0.0));
    return PAL[idx & 3u];
}

vec3 dosSampleModeCga(vec2 gameUv, uint vmode) {
    gameUv = clamp(gameUv, vec2(0.0), vec2(0.9999));
    if (vmode == 6u) {
        uint x = min(uint(floor(gameUv.x * 640.0)), 639u);
        uint y = min(uint(floor(gameUv.y * 200.0)), 199u);
        uint byteOff = y * 80u + (x >> 3);
        uint bit = 0x80u >> (x & 7u);
        uint on = (ramByte(VGA_FB_BYTE + byteOff) & bit) != 0u ? 1u : 0u;
        return mix(vec3(0.0), vec3(1.0), float(on));
    }
    uint x = min(uint(floor(gameUv.x * 320.0)), 319u);
    uint y = min(uint(floor(gameUv.y * 200.0)), 199u);
    uint byteOff = y * 80u + (x >> 2);
    uint shift = (3u - (x & 3u)) * 2u;
    uint idx = (ramByte(VGA_FB_BYTE + byteOff) >> shift) & 3u;
    if (vmode == 5u)
        idx = ((ramByte(VGA_FB_BYTE + byteOff) >> ((x & 1u) * 4u)) & 0x0Fu) & 3u;
    return dosCgaColor(idx);
}

vec3 dosSampleModeSvga(vec2 gameUv) {
    uvec2 size = dosVideoMetaSize();
    gameUv = clamp(gameUv, vec2(0.0), vec2(0.9999));
    uint x = min(uint(floor(gameUv.x * float(size.x))), size.x - 1u);
    uint y = min(uint(floor(gameUv.y * float(size.y))), size.y - 1u);
    uint bpp = max(uint(ramByte(VGA_META_BYTE + 4u)), 8u);
    uint idx;
    if (bpp <= 4u) {
        uint byteOff = y * size.x + (x >> 1);
        idx = (ramByte(VGA_LFB_BYTE + byteOff) >> ((x & 1u) * 4u)) & 0x0Fu;
    } else {
        idx = ramByte(VGA_LFB_BYTE + y * size.x + x);
    }
    return vgaPalRam(idx);
}

vec3 dosSampleGraphics(vec2 gameUv, uint vmode) {
    if (vmode == VGA_MODE_13 || vmode == VGA_MODE_VOODOO || die.video_mode == VGA_MODE_13)
        return dosSampleMode13(gameUv);
    if (vmode == VGA_MODE_EGA0D)
        return dosSampleModeEga(gameUv, uvec2(320u, 200u));
    if (vmode == VGA_MODE_EGA12)
        return dosSampleModeEga(gameUv, uvec2(640u, 480u));
    if (vmode == VGA_MODE_SVGA)
        return dosSampleModeSvga(gameUv);
    if (vmode == 4u || vmode == 5u || vmode == 6u)
        return dosSampleModeCga(gameUv, vmode);
    uvec2 meta = dosVideoMetaSize();
    if (meta.x >= 640u && meta.y >= 400u)
        return dosSampleModeEga(gameUv, meta);
    return dosSampleMode13(gameUv);
}

const uint FIELD_LAYER_VGA = 1u;
const uint FIELD_LAYER_FAT = 2u;
const uint FIELD_LAYER_MSCDEX = 4u;
const float FIELD_HUD_H = 12.0;
const float FIELD_HUD_GW = 7.0;

float fieldHudGlyph(uint ch, vec2 uv, float x0) {
    return fontGlyphInk(ch, uv, x0, 0.0, vec2(FIELD_HUD_GW, FIELD_HUD_H));
}

vec3 fieldLayerHudColor(vec2 hudUv, uint layerMask, ThemePal th) {
    if (layerMask == 0u) return vec3(-1.0);
    vec3 bg = th.panel * 0.24 + vec3(0.045);
    vec3 fg = AOS_INK_BLACK;
    float ink = 0.0;
    float x = 2.0;
    const uint PREFIX[7] = uint[7](70u, 73u, 69u, 76u, 68u, 58u, 32u);
    for (int i = 0; i < 7; ++i) {
        ink = max(ink, fieldHudGlyph(PREFIX[i], hudUv, x));
        x += FIELD_HUD_GW;
    }
    bool first = true;
    if ((layerMask & FIELD_LAYER_VGA) != 0u) {
        const uint TAG[3] = uint[3](86u, 71u, 65u);
        for (int i = 0; i < 3; ++i) {
            ink = max(ink, fieldHudGlyph(TAG[i], hudUv, x));
            x += FIELD_HUD_GW;
        }
        first = false;
    }
    if ((layerMask & FIELD_LAYER_FAT) != 0u) {
        if (!first) {
            ink = max(ink, fieldHudGlyph(43u, hudUv, x));
            x += FIELD_HUD_GW;
        }
        const uint TAG[3] = uint[3](70u, 65u, 84u);
        for (int i = 0; i < 3; ++i) {
            ink = max(ink, fieldHudGlyph(TAG[i], hudUv, x));
            x += FIELD_HUD_GW;
        }
        first = false;
    }
    if ((layerMask & FIELD_LAYER_MSCDEX) != 0u) {
        if (!first) {
            ink = max(ink, fieldHudGlyph(43u, hudUv, x));
            x += FIELD_HUD_GW;
        }
        const uint TAG[6] = uint[6](77u, 83u, 67u, 68u, 69u, 88u);
        for (int i = 0; i < 6; ++i) {
            ink = max(ink, fieldHudGlyph(TAG[i], hudUv, x));
            x += FIELD_HUD_GW;
        }
    }
    return mix(bg, fg, clamp(ink, 0.0, 1.0));
}

vec3 aosMatBaseColor(uint matIdx) {
    if (matIdx == 36u) return vec3(0.96, 0.97, 0.99);
    if (matIdx == 37u) return vec3(0.97, 0.98, 0.99);
    if (matIdx == 38u) return vec3(0.98, 0.98, 0.99);
    if (matIdx == 1u)  return vec3(0.0, 0.47, 0.84);
    if (matIdx == 3u)  return vec3(0.92, 0.96, 1.00);
    return vec3(0.96, 0.97, 0.99);
}

vec3 aosMatEmissive(uint matIdx) {
    if (matIdx == 1u) return vec3(0.02, 0.08, 0.14);
    if (matIdx == 3u) return vec3(0.15, 0.25, 0.40);
    return vec3(0.0);
}

vec3 aosMaterialTint(vec2 uv, uint matIdx, vec3 under, ThemePal th, float t) {
    vec3 base = aosMatBaseColor(matIdx);
    vec3 emis = aosMatEmissive(matIdx);
    float thinFilm = (matIdx == 38u) ? 1.0 : ((matIdx == 1u) ? 0.65 : 0.0);
    float haze = (matIdx == 36u || matIdx == 37u || matIdx == 38u) ? 0.22 : 0.12;
    float ior = (matIdx == 1u) ? 1.95 : 1.52;
    float fresnel = pow(1.0 - clamp(length(uv - 0.5) * 1.2, 0.0, 1.0), 2.0) * ior * 0.15;
    vec3 col = mix(under * 0.35, base * 0.55 + th.panel * 0.25, 0.72);
    col += emis * (0.25 + 0.15 * sin(t * 2.1 + uv.x * 8.0));
    if (thinFilm > 0.01) {
        col.r += thinFilm * 0.08 * sin(t * 3.2 + uv.y * 12.0);
        col.g += thinFilm * 0.08 * sin(t * 2.8 + uv.y * 12.0 + 2.1);
        col.b += thinFilm * 0.08 * sin(t * 3.0 + uv.y * 12.0 + 4.2);
    }
    col += th.gemTint * fresnel * 0.35;
    col += base * haze * 0.08 * sin(uv.y * 24.0 + t * 1.6);
    return clamp(col, 0.0, 1.0);
}

vec3 dosGlassPanel(vec2 winLocal, vec2 winSize, float titleH, float hudH, ThemePal th) {
    float uiSc = max(winSize.x / 1920.0, 0.75) * 1.35;
    return aosSdWindowShell(winLocal, winSize, titleH, hudH, th.accent, th.border, uiSc);
}

vec4 sampleAosIconRgba(uint slot, vec2 uv) {
    ivec2 dim = imageSize(aosStartTex);
    if (dim.x <= 0 || dim.y <= 0) return vec4(-1.0);
    const float ICON_CELL = 64.0;
    float cols = float(dim.x) / ICON_CELL;
    float rows = ceil(float(dim.y) / ICON_CELL);
    float c = mod(float(slot), cols);
    float r = floor(float(slot) / cols);
    vec2 atlasUv = (vec2(c, r) + clamp(uv, 0.0, 1.0)) / vec2(cols, rows);
    ivec2 px = clamp(ivec2(atlasUv * vec2(dim)), ivec2(0), dim - ivec2(1));
    return imageLoad(aosStartTex, px);
}

vec3 sampleAosIcon(uint slot, vec2 uv) {
    return sampleAosIconRgba(slot, uv).rgb;
}

vec3 aosBlendIcon(vec3 base, vec4 icon) {
    if (icon.a < 0.04) return base;
    return mix(base, icon.rgb, clamp(icon.a, 0.0, 1.0));
}

float rtxWmTitleH(vec2 img) {
    uint aosBits = field.data_bus[42];
    if (!aosChromeActive()) return 0.0;
    bool consoleShell = (aosBits & (1u << 29u)) != 0u;
    if ((aosBits & (1u << 25u)) != 0u && !consoleShell) return 0.0;
    return 32.0 * max(img.x / 1920.0, 0.75) * 1.35;
}

#include "aos_wm_ascii.inc"
#include "aos_wm_system.inc"

float rtxWmMenuDrop(vec2 winLocal, float x0, float y0, float rowH, int row,
        vec2 cell, uint c0, uint c1, uint c2, uint c3, uint c4, uint c5) {
    return dosHudRun(winLocal, x0, y0 + rowH * float(row) + 5.0, cell,
        c0, c1, c2, c3, c4, c5, 32u, 32u);
}

const uint AOS_WM_DROPDOWN_RAM = 0x000BA780u;

vec3 rtxWmNesMenuDropdown(vec2 winLocal, vec2 winSize, float titleH, ThemePal th) {
    uint wmPack = field.data_bus[52];
    uint openMenu = (wmPack >> 8u) & 7u;
    if (openMenu == 0u) return vec3(-1.0);
    float uiSc = max(winSize.x / 1920.0, 0.75) * 1.35;
    vec2 cell = vec2(8.0, 14.0) * uiSc;
    float dropH = 28.0 * uiSc;
    float dropW = 220.0 * uiSc;
    float iconBand = titleH * 0.58 + 18.0 * uiSc;
    float dx = 10.0 * uiSc + iconBand;
    if (openMenu == 2u) dx += 44.0 * uiSc;
    else if (openMenu == 3u) dx += 88.0 * uiSc;
    else if (openMenu == 5u) dx += 132.0 * uiSc;
    else if (openMenu == 4u) dx += 176.0 * uiSc;
    int nRows = 2;
    if (openMenu == 2u) nRows = int(ramByte(AOS_WM_DROPDOWN_RAM));
    else if (openMenu == 3u) nRows = 7;
    else if (openMenu == 5u) nRows = 2;
    else if (openMenu == 4u) nRows = 1;
    nRows = max(nRows, 1);
    if (winLocal.y < titleH || winLocal.y >= titleH + dropH * float(nRows)
            || winLocal.x < dx - 4.0 * uiSc || winLocal.x >= dx + dropW)
        return vec3(-1.0);
    vec3 drop = mix(th.panel * 0.62, th.accent * 0.18 + th.panel * 0.42, 0.55);
    float edge = min(min(winLocal.x - (dx - 4.0 * uiSc), dx + dropW - winLocal.x),
                     min(winLocal.y - titleH, titleH + dropH * float(nRows) - winLocal.y));
    drop = mix(drop, th.accent * 0.28 + th.title * 0.12, smoothstep(0.0, 2.5 * uiSc, edge));
    uint hoverRow = (wmPack >> 11u) & 0xFu;
    if (hoverRow < uint(nRows)) {
        float hy0 = titleH + dropH * float(hoverRow);
        if (winLocal.y >= hy0 && winLocal.y < hy0 + dropH)
            drop = mix(drop, th.accent * 0.32 + th.gemTint * 0.18, 0.72);
    }
    float dInk = 0.0;
    if (openMenu == 1u) {
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 0, cell, 79u, 112u, 101u, 110u, 46u, 46u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 1, cell, 69u, 120u, 105u, 116u, 32u, 32u));
    } else if (openMenu == 2u) {
        for (int r = 0; r < nRows; ++r) {
            uint rowBase = AOS_WM_DROPDOWN_RAM + 0x10u + uint(r) * 40u;
            dInk = max(dInk, dosHudRamStr(winLocal, dx, titleH + dropH * float(r) + 5.0, cell, rowBase, 36u));
        }
    } else if (openMenu == 3u) {
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 0, cell, 80u, 97u, 117u, 115u, 101u, 32u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 1, cell, 82u, 101u, 115u, 117u, 109u, 101u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 2, cell, 82u, 101u, 115u, 101u, 116u, 32u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 3, cell, 70u, 114u, 97u, 109u, 101u, 32u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 4, cell, 65u, 100u, 118u, 97u, 110u, 99u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 5, cell, 84u, 117u, 114u, 98u, 111u, 32u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 6, cell, 85u, 110u, 108u, 105u, 109u, 105u));
    } else if (openMenu == 5u) {
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 0, cell, 83u, 101u, 116u, 116u, 105u, 110u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 1, cell, 67u, 111u, 110u, 116u, 114u, 111u));
    } else if (openMenu == 4u) {
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 0, cell, 65u, 98u, 111u, 117u, 116u, 32u));
    }
    return mixHudInk(drop, dInk, 0.0, AOS_INK_BLACK);
}

vec3 rtxWmMenuDropdown(vec2 winLocal, vec2 winSize, float titleH, ThemePal th) {
    uint wmPack = field.data_bus[52];
    if ((wmPack & (1u << 16u)) != 0u)
        return rtxWmNesMenuDropdown(winLocal, winSize, titleH, th);
    uint openMenu = (wmPack >> 8u) & 7u;
    if (openMenu == 6u)
        return rtxWmSystemMenuDropdown(winLocal, winSize, titleH, th);
    if (openMenu == 0u) return vec3(-1.0);
    float uiSc = max(winSize.x / 1920.0, 0.75) * 1.35;
    vec2 cell = vec2(8.0, 14.0) * uiSc;
    float iconBand = titleH * 0.58 + 18.0 * uiSc;
    float menuX0 = 10.0 * uiSc + iconBand;
    float menuX1 = menuX0 + 50.0 * uiSc;
    float menuX2 = menuX1 + 50.0 * uiSc;
    float menuX3 = menuX2 + 50.0 * uiSc;
    float dropH = 28.0 * uiSc;
    float dx = (openMenu == 1u) ? menuX0 : ((openMenu == 2u) ? menuX1 : ((openMenu == 3u) ? menuX2 : menuX3));
    int nRows = 3;
    if (openMenu == 3u) nRows = 4;
    if (openMenu == 4u) nRows = 2;
    float dropW = 196.0 * uiSc;
    if (winLocal.y < titleH || winLocal.y >= titleH + dropH * float(nRows)
            || winLocal.x < dx - 4.0 * uiSc || winLocal.x >= dx + dropW)
        return vec3(-1.0);
    vec3 drop = mix(th.panel * 0.62, th.accent * 0.18 + th.panel * 0.42, 0.55);
    float edge = min(min(winLocal.x - (dx - 4.0 * uiSc), dx + dropW - winLocal.x),
                     min(winLocal.y - titleH, titleH + dropH * float(nRows) - winLocal.y));
    drop = mix(drop, th.accent * 0.28 + th.title * 0.12, smoothstep(0.0, 2.5 * uiSc, edge));
    uint hoverRow = (wmPack >> 11u) & 0xFu;
    if (hoverRow < uint(nRows)) {
        float hy0 = titleH + dropH * float(hoverRow);
        if (winLocal.y >= hy0 && winLocal.y < hy0 + dropH)
            drop = mix(drop, th.accent * 0.32 + th.gemTint * 0.18, 0.72);
    }
    float dInk = 0.0;
    if (openMenu == 1u) {
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 0, cell, 78u, 101u, 119u, 32u, 83u, 101u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 1, cell, 83u, 97u, 118u, 101u, 32u, 76u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 2, cell, 69u, 120u, 105u, 116u, 32u, 32u));
    } else if (openMenu == 2u) {
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 0, cell, 67u, 111u, 112u, 121u, 32u, 32u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 1, cell, 67u, 108u, 101u, 97u, 114u, 32u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 2, cell, 83u, 101u, 108u, 101u, 99u, 116u));
    } else if (openMenu == 3u) {
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 0, cell, 83u, 99u, 114u, 111u, 108u, 108u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 1, cell, 83u, 99u, 114u, 111u, 108u, 108u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 2, cell, 76u, 111u, 103u, 32u, 80u, 97u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 3, cell, 84u, 104u, 101u, 109u, 101u, 115u));
    } else if (openMenu == 4u) {
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 0, cell, 72u, 101u, 108u, 112u, 32u, 84u));
        dInk = max(dInk, rtxWmMenuDrop(winLocal, dx, titleH, dropH, 1, cell, 65u, 98u, 111u, 117u, 116u, 32u));
    }
    float dBorder = 0.0;
    if (openMenu == 1u) {
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 0.0 + 5.0, cell, 78u, 101u, 119u, 32u, 83u, 101u, 32u, 32u));
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 1.0 + 5.0, cell, 83u, 97u, 118u, 101u, 32u, 76u, 32u, 32u));
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 2.0 + 5.0, cell, 69u, 120u, 105u, 116u, 32u, 32u, 32u, 32u));
    } else if (openMenu == 2u) {
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 0.0 + 5.0, cell, 67u, 111u, 112u, 121u, 32u, 32u, 32u, 32u));
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 1.0 + 5.0, cell, 67u, 108u, 101u, 97u, 114u, 32u, 32u, 32u));
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 2.0 + 5.0, cell, 83u, 101u, 108u, 101u, 99u, 116u, 32u, 32u));
    } else if (openMenu == 3u) {
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 0.0 + 5.0, cell, 83u, 99u, 114u, 111u, 108u, 108u, 32u, 32u));
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 1.0 + 5.0, cell, 83u, 99u, 114u, 111u, 108u, 108u, 32u, 32u));
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 2.0 + 5.0, cell, 76u, 111u, 103u, 32u, 80u, 97u, 110u, 101u));
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 3.0 + 5.0, cell, 84u, 104u, 101u, 109u, 101u, 115u, 32u, 32u));
    } else if (openMenu == 4u) {
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 0.0 + 5.0, cell, 72u, 101u, 108u, 112u, 32u, 84u, 111u, 112u));
        dBorder = max(dBorder, dosHudRunBorder(winLocal, dx, titleH + dropH * 1.0 + 5.0, cell, 65u, 98u, 111u, 117u, 116u, 32u, 32u, 32u));
    }
    return mixHudInk(drop, dInk, dBorder, AOS_INK_BLACK);
}

vec3 rtxWmTitleBar(vec2 winLocal, vec2 winSize, float titleH, ThemePal th) {
    float t = field.sealed_time;
    float uiSc = max(winSize.x / 1920.0, 0.75) * 1.35;
    vec2 muv = vec2(winLocal.x / max(winSize.x, 1.0), winLocal.y / max(titleH, 1.0));
    uint wmPack = field.data_bus[52];
    bool gnomeSkin = (wmPack & (1u << 15u)) != 0u;
    vec3 base = aosSdTitleBarWin31(winLocal, winSize, titleH, gnomeSkin);
    if (base.x < 0.0) base = mix(vec3(0.20, 0.20, 0.22), vec3(0.28, 0.28, 0.30), muv.y);
    vec2 cell = vec2(8.0, 14.0) * uiSc;
    float rowY = titleH * 0.5 - 7.0 * uiSc;
    float ink = 0.0;
    float inkB = 0.0;
    uint openMenu = (wmPack >> 8u) & 7u;
    bool nesMenu = (wmPack & (1u << 16u)) != 0u;
    rtxWmTitleAppIcon(winLocal, titleH, uiSc, th, base);
    float iconBand = titleH * 0.58 + 18.0 * uiSc;
    if (!gnomeSkin) {
        if (nesMenu) {
            float menuX0 = 10.0 * uiSc + iconBand;
            float menuX1 = menuX0 + 44.0 * uiSc;
            float menuX2 = menuX1 + 44.0 * uiSc;
            float menuX3 = menuX2 + 44.0 * uiSc;
            float menuX4 = menuX3 + 44.0 * uiSc;
            ink = max(ink, dosHudRun(winLocal, menuX0, rowY, cell, 70u, 105u, 108u, 101u, 32u, 32u, 32u, 32u));
            ink = max(ink, dosHudRun(winLocal, menuX1, rowY, cell, 82u, 101u, 99u, 101u, 110u, 116u, 32u, 32u));
            ink = max(ink, dosHudRun(winLocal, menuX2, rowY, cell, 69u, 109u, 117u, 108u, 32u, 32u, 32u, 32u));
            ink = max(ink, dosHudRun(winLocal, menuX3, rowY, cell, 79u, 112u, 116u, 115u, 32u, 32u, 32u, 32u));
            ink = max(ink, dosHudRun(winLocal, menuX4, rowY, cell, 72u, 101u, 108u, 112u, 32u, 32u, 32u, 32u));
            if (openMenu == 1u && winLocal.x >= menuX0 - 2.0 * uiSc && winLocal.x < menuX0 + 42.0 * uiSc)
                base = mix(base, th.accent * 0.22 + th.panel * 0.45, 0.55);
            if (openMenu == 2u && winLocal.x >= menuX1 - 2.0 * uiSc && winLocal.x < menuX1 + 42.0 * uiSc)
                base = mix(base, th.accent * 0.22 + th.panel * 0.45, 0.55);
            if (openMenu == 3u && winLocal.x >= menuX2 - 2.0 * uiSc && winLocal.x < menuX2 + 42.0 * uiSc)
                base = mix(base, th.accent * 0.22 + th.panel * 0.45, 0.55);
            if (openMenu == 5u && winLocal.x >= menuX3 - 2.0 * uiSc && winLocal.x < menuX3 + 42.0 * uiSc)
                base = mix(base, th.accent * 0.22 + th.panel * 0.45, 0.55);
            if (openMenu == 4u && winLocal.x >= menuX4 - 2.0 * uiSc && winLocal.x < menuX4 + 42.0 * uiSc)
                base = mix(base, th.accent * 0.22 + th.panel * 0.45, 0.55);
        } else {
            float menuX0 = 10.0 * uiSc + iconBand;
            float menuX1 = menuX0 + 50.0 * uiSc;
            float menuX2 = menuX1 + 50.0 * uiSc;
            float menuX3 = menuX2 + 50.0 * uiSc;
            ink = max(ink, dosHudRun(winLocal, menuX0, rowY, cell, 70u, 105u, 108u, 101u, 32u, 32u, 32u, 32u));
            inkB = max(inkB, dosHudRunBorder(winLocal, menuX0, rowY, cell, 70u, 105u, 108u, 101u, 32u, 32u, 32u, 32u));
            ink = max(ink, dosHudRun(winLocal, menuX1, rowY, cell, 69u, 100u, 105u, 116u, 32u, 32u, 32u, 32u));
            inkB = max(inkB, dosHudRunBorder(winLocal, menuX1, rowY, cell, 69u, 100u, 105u, 116u, 32u, 32u, 32u, 32u));
            ink = max(ink, dosHudRun(winLocal, menuX2, rowY, cell, 86u, 105u, 101u, 119u, 32u, 32u, 32u, 32u));
            inkB = max(inkB, dosHudRunBorder(winLocal, menuX2, rowY, cell, 86u, 105u, 101u, 119u, 32u, 32u, 32u, 32u));
            ink = max(ink, dosHudRun(winLocal, menuX3, rowY, cell, 72u, 101u, 108u, 112u, 32u, 32u, 32u, 32u));
            inkB = max(inkB, dosHudRunBorder(winLocal, menuX3, rowY, cell, 72u, 101u, 108u, 112u, 32u, 32u, 32u, 32u));
            if (openMenu == 1u && winLocal.x >= menuX0 - 2.0 * uiSc && winLocal.x < menuX0 + 46.0 * uiSc)
                base = mix(base, th.accent * 0.22 + th.panel * 0.45, 0.55);
            if (openMenu == 2u && winLocal.x >= menuX1 - 2.0 * uiSc && winLocal.x < menuX1 + 46.0 * uiSc)
                base = mix(base, th.accent * 0.22 + th.panel * 0.45, 0.55);
            if (openMenu == 3u && winLocal.x >= menuX2 - 2.0 * uiSc && winLocal.x < menuX2 + 46.0 * uiSc)
                base = mix(base, th.accent * 0.22 + th.panel * 0.45, 0.55);
            if (openMenu == 4u && winLocal.x >= menuX3 - 2.0 * uiSc && winLocal.x < menuX3 + 46.0 * uiSc)
                base = mix(base, th.accent * 0.22 + th.panel * 0.45, 0.55);
        }
    }
    uint titleTab = (field.data_bus[54] >> 24u) & 0xFFu;
    float titleX = gnomeSkin ? (48.0 * uiSc) : (220.0 * uiSc + iconBand);
    if (titleTab < 255u) {
        uint titleBase = AOS_TASKBAR_RAM + 0x10u + titleTab * AOS_TAB_STRIDE;
        ink = max(ink, dosHudRamStr(winLocal, titleX, rowY, cell, titleBase, 22u));
        inkB = max(inkB, dosHudRamStrBorder(winLocal, titleX, rowY, cell, titleBase, 22u));
    }
    if (ink < 0.01) {
        ink = max(ink, dosHudRun(winLocal, titleX, rowY, cell, 82u, 84u, 88u, 32u, 83u, 104u, 101u, 108u));
        inkB = max(inkB, dosHudRunBorder(winLocal, titleX, rowY, cell, 82u, 84u, 88u, 32u, 83u, 104u, 101u, 108u));
    }
    vec3 c = rtxWmTitleAsciiControls(winLocal, winSize, titleH, wmPack, th);
    if (c.x > -1.5) return c;
    return mixHudInk(base, ink, inkB, AOS_INK_BLACK);
}

vec3 rtxWmResizeGrip(vec2 winLocal, vec2 winSize, float titleH, float hudH, ThemePal th) {
    float g = 10.0;
    float bot = winSize.y - hudH;
    bool bottom = winLocal.y >= bot - g;
    bool left = winLocal.x < g;
    bool right = winLocal.x >= winSize.x - g;
    float uiSc = max(winSize.x / 1920.0, 0.75) * 1.35;
    float iconBand = titleH * 0.58 + 18.0 * uiSc;
    if (winLocal.y < titleH) {
        if (winLocal.x < 10.0 * uiSc + iconBand) left = false;
        float btn = clamp(titleH - 6.0, 26.0, 34.0);
        float bx = winSize.x - btn * 3.0 - 8.0;
        if (winLocal.x >= bx - g) right = false;
    }
    bool edge = bottom && (left || right || winLocal.x >= g && winLocal.x < winSize.x - g)
             || (left || right) && winLocal.y >= titleH + g && winLocal.y < bot - g;
    if (!edge) return vec3(-1.0);
    float rel = min(min(winLocal.x, winSize.x - winLocal.x),
                    min(winLocal.y - titleH, bot - winLocal.y)) / g;
    vec3 col = mix(th.panel * 0.22, th.accent * 0.18 + th.gemTint * 0.12, smoothstep(1.0, 0.0, rel));
    return clamp(col, 0.0, 1.0);
}

const uint RTX_WIDGET_RAM = 0x000BB000u;
const uint RTX_WIDGET_POOL = 0x000BB400u;
vec3 rtxPanelBg(ThemePal th) {
    return mix(th.void_ * 1.35, th.panel, 0.72);
}
vec3 rtxPanelEdge(ThemePal th) {
    return mix(th.border, th.zebra, 0.55);
}
const vec3 RTX_WIDGET_FG = vec3(0.10, 0.10, 0.12);
const vec3 RTX_WIDGET_DIM = vec3(0.45, 0.45, 0.48);

bool rtxWidgetsActive() {
    return ramByte(RTX_WIDGET_RAM) > 0u;
}

uint rtxWidgetCount() {
    return min(ramByte(RTX_WIDGET_RAM), 48u);
}

vec2 rtxWidgetContentOrg(vec2 winSize, float titleH, float hudH) {
    return vec2(4.0, titleH + 2.0);
}

vec2 rtxWidgetContentSize(vec2 winSize, float titleH, float hudH) {
    float top = titleH + 2.0;
    float bot = winSize.y - hudH - 2.0;
    float left = 4.0;
    float right = winSize.x - 18.0;
    return max(vec2(right - left, bot - top), vec2(1.0));
}

vec2 rtxWidgetContentUv(vec2 winLocal, vec2 winSize, float titleH, float hudH) {
    vec2 rel = (winLocal - rtxWidgetContentOrg(winSize, titleH, hudH))
        / rtxWidgetContentSize(winSize, titleH, hudH);
    return clamp(rel, vec2(0.0), vec2(1.0));
}

vec4 rtxWidgetRect(uint idx) {
    uint base = RTX_WIDGET_RAM + 0x10u + idx * 16u;
    float x0 = float(ramByte(base + 2u) | (uint(ramByte(base + 3u)) << 8u)) / 1024.0;
    float y0 = float(ramByte(base + 4u) | (uint(ramByte(base + 5u)) << 8u)) / 1024.0;
    float x1 = float(ramByte(base + 6u) | (uint(ramByte(base + 7u)) << 8u)) / 1024.0;
    float y1 = float(ramByte(base + 8u) | (uint(ramByte(base + 9u)) << 8u)) / 1024.0;
    return vec4(x0, y0, x1, y1);
}

float rtxWidgetRoundBox(vec2 p, vec2 halfSize, float r) {
    vec2 q = abs(p) - halfSize + r;
    return length(max(q, 0.0)) + min(max(q.x, q.y), 0.0) - r;
}

float rtxWidgetRamStr(vec2 pix, vec2 p0pix, vec2 cellPix, uint strOff, uint maxLen, float clipRight) {
    float ink = 0.0;
    float x = p0pix.x;
    for (uint i = 0u; i < maxLen; ++i) {
        if (x + cellPix.x > clipRight) break;
        uint ch = ramByte(RTX_WIDGET_POOL + strOff + i);
        if (ch == 0u) break;
        if (ch < 32u || ch >= 0x80u) continue;
        ink = max(ink, dosHudGlyph(ch, pix, x, p0pix.y, cellPix));
        x += cellPix.x;
    }
    return ink;
}

vec2 rtxWidgetTextCell(vec2 contentSz) {
    float uiSc = max(contentSz.y / 540.0, 0.75) * 1.35;
    return aosHudTextCell(uiSc);
}

float rtxWidgetInk(vec2 pix, vec2 p0pix, vec2 cellPix, uint strOff, uint maxLen, float clipRight) {
    float ink = rtxWidgetRamStr(pix, p0pix, cellPix, strOff, maxLen, clipRight);
    float border = 0.0;
    border = max(border, rtxWidgetRamStr(pix + vec2(-1.0, 0.0), p0pix, cellPix, strOff, maxLen, clipRight));
    border = max(border, rtxWidgetRamStr(pix + vec2(1.0, 0.0), p0pix, cellPix, strOff, maxLen, clipRight));
    border = max(border, rtxWidgetRamStr(pix + vec2(0.0, -1.0), p0pix, cellPix, strOff, maxLen, clipRight));
    border = max(border, rtxWidgetRamStr(pix + vec2(0.0, 1.0), p0pix, cellPix, strOff, maxLen, clipRight));
    return max(ink, border * 0.92);
}

vec3 rtxPaintWidget(uint idx, vec2 winLocal, vec2 uv, vec2 contentOrg, vec2 contentSz,
        ThemePal th, int hoverId, vec3 underCol) {
    uint base = RTX_WIDGET_RAM + 0x10u + idx * 16u;
    uint wtype = ramByte(base);
    uint wflags = ramByte(base + 1u);
    uint wstyle = ramByte(base + 11u);
    vec4 r = rtxWidgetRect(idx);
    if (uv.x < r.x || uv.x >= r.z || uv.y < r.y || uv.y >= r.w) return vec3(-1.0);
    vec2 cen = (r.xy + r.zw) * 0.5;
    vec2 halfSz = (r.zw - r.xy) * 0.5;
    vec2 lp = uv - cen;
    bool hov = int(idx) == hoverId;
    uint strOff = uint(ramByte(base + 12u) | (uint(ramByte(base + 13u)) << 8u));
    uint state = uint(ramByte(base + 10u));
    int ex0 = int(ramByte(base + 14u));
    int ex1 = int(ramByte(base + 15u));
    if (ex0 > 127) ex0 -= 256;
    if (ex1 > 127) ex1 -= 256;
    vec2 rPix0 = contentOrg + r.xy * contentSz;
    vec2 rPix1 = contentOrg + r.zw * contentSz;
    vec2 halfSzPix = (rPix1 - rPix0) * 0.5;
    vec2 cenPix = (rPix0 + rPix1) * 0.5;
    vec2 cell = rtxWidgetTextCell(contentSz);
    float uiSc = max(contentSz.y / 540.0, 0.75) * 1.35;
    vec2 txtTop = vec2(rPix0.x + 8.0 * uiSc, rPix0.y + 6.0 * uiSc);
    vec2 txtMid = vec2(rPix0.x + 8.0 * uiSc, cenPix.y - cell.y * 0.5);

    if (wtype == 0u) {
        float d = rtxWidgetRoundBox(lp, halfSz, 0.012);
        vec3 face = (wstyle == 1u) ? mix(rtxPanelBg(th), th.zebra, 0.42) : rtxPanelBg(th);
        vec3 edge = rtxPanelEdge(th);
        vec3 col = mix(face, edge, smoothstep(0.0, -0.004, d));
        if (wstyle == 1u && lp.y < -halfSz.y + 0.020)
            col = mix(col, th.accent * 0.50 + vec3(0.10, 0.12, 0.16), 0.82);
        col = mix(col, th.accent * 0.22 + th.zebra, hov ? 0.35 : 0.0);
        return clamp(col, 0.0, 1.0);
    }
    if (wtype == 1u) {
        float clipR = rPix1.x - 4.0 * uiSc;
        vec2 lblCell = (wstyle == 1u) ? cell * 1.05 : cell;
        float ink = rtxWidgetInk(winLocal, txtTop, lblCell, strOff, 64u, clipR);
        if (ink < 0.02) return vec3(-1.0);
        vec3 inkCol = (wstyle == 1u)
            ? mix(th.accent * 0.55 + th.title * 0.45, AOS_INK_BLACK, 0.62)
            : mix(th.label, AOS_INK_BLACK, 0.78);
        return mixHudInk(underCol, ink, 0.0, inkCol);
    }
    if (wtype == 2u) {
        float box = 14.0 * uiSc;
        vec2 b0pix = vec2(rPix0.x + 8.0, txtTop.y);
        vec2 buv = (winLocal - b0pix) / box;
        vec3 col = underCol;
        if (all(greaterThanEqual(buv, vec2(0.0))) && all(lessThan(buv, vec2(1.0)))) {
            float d = rtxWidgetRoundBox(buv - 0.5, vec2(0.42), 0.08);
            vec3 boxCol = mix(rtxPanelEdge(th), th.accent * 0.65 + vec3(0.28, 0.28, 0.30),
                smoothstep(0.04, -0.02, d) * (((wflags & 8u) != 0u || state != 0u) ? 1.0 : 0.0));
            boxCol = mix(rtxPanelBg(th), boxCol, smoothstep(0.06, -0.02, d));
            col = mix(col, boxCol, smoothstep(0.06, -0.02, d));
        }
        float ink = rtxWidgetInk(winLocal, vec2(b0pix.x + box + 6.0 * uiSc, txtTop.y),
            cell, strOff, 48u, rPix1.x - 4.0);
        if (ink > 0.02)
            col = mixHudInk(col, ink, 0.0, AOS_INK_BLACK);
        return col;
    }
    if (wtype == 3u) {
        bool focused = (wflags & 4u) != 0u;
        float d = rtxWidgetRoundBox(lp, halfSz * 0.95, 0.01);
        vec3 col = mix(rtxPanelEdge(th), th.accent * 0.45 + vec3(0.22, 0.22, 0.24),
            (hov || focused) ? 0.78 : 0.35);
        col = mix(underCol, col, smoothstep(0.02, -0.01, d));
        float ink = rtxWidgetInk(winLocal, txtTop, cell, strOff, 36u, rPix1.x - 8.0 * uiSc);
        return mixHudInk(col, ink, 0.0, AOS_INK_BLACK);
    }
    if (wtype == 4u) {
        float d = rtxWidgetRoundBox(lp, halfSz * 0.95, 0.008);
        vec3 col = mix(underCol, rtxPanelEdge(th), smoothstep(0.015, -0.01, d));
        if (hov) col = mix(col, th.accent * 0.35 + vec3(0.20, 0.20, 0.22), 0.55);
        float ink = rtxWidgetInk(winLocal, txtTop, cell, strOff, 40u, rPix1.x - 20.0 * uiSc);
        col = mixHudInk(col, ink, 0.0, AOS_INK_BLACK);
        float ax = r.z - 0.02;
        if (uv.x > ax - 0.015 && uv.x < ax && uv.y > cen.y - 0.012 && uv.y < cen.y + 0.012)
            col = mix(col, RTX_WIDGET_DIM, 0.8);
        return col;
    }
    if (wtype == 5u) {
        vec3 track = mix(vec3(0.12, 0.12, 0.14), th.panel * 0.35, 0.5);
        uint top = uint(ramByte(RTX_WIDGET_RAM + 2u) | (uint(ramByte(RTX_WIDGET_RAM + 3u)) << 8u));
        uint total = uint(ramByte(RTX_WIDGET_RAM + 4u) | (uint(ramByte(RTX_WIDGET_RAM + 5u)) << 8u));
        float frac = float(top) / max(float(total), 1.0);
        float thumbH = max(halfSz.y * 0.35, 0.04);
        float thumbY = -halfSz.y + thumbH + frac * (halfSz.y * 2.0 - thumbH * 2.0);
        float d = abs(lp.y - thumbY) - thumbH;
        vec3 col = track;
        if (d < 0.0) col = mix(th.accent, th.gemTint, 0.48);
        return col;
    }
    if (wtype == 6u) {
        vec3 col = underCol;
        float fill = float(state) / 255.0;
        vec2 fp = lp + vec2(halfSz.x * (fill * 2.0 - 1.0), 0.0);
        float d = rtxWidgetRoundBox(fp, vec2(halfSz.x * fill, halfSz.y * 0.55), 0.006);
        col = mix(col, th.accent * 0.55 + vec3(0.24, 0.24, 0.26), smoothstep(0.01, -0.01, d));
        float ink = rtxWidgetInk(winLocal, vec2(rPix0.x + 8.0 * uiSc, txtTop.y), cell, strOff, 32u, rPix1.x - 4.0);
        return mixHudInk(col, ink, 0.0, AOS_INK_BLACK);
    }
    if (wtype == 7u) {
        float rad = min(halfSz.x, halfSz.y) * 0.82;
        float d = length(lp) - rad;
        vec3 col = mix(underCol, rtxPanelEdge(th), smoothstep(0.01, -0.01, d));
        vec2 dot = vec2(float(ex0) / 127.0, float(ex1) / 127.0) * rad * 0.72;
        if (length(lp - dot) < rad * 0.14) col = mix(col, th.accent * 0.7 + vec3(0.30, 0.30, 0.32), 0.9);
        float ink = rtxWidgetInk(winLocal, vec2(rPix0.x, txtTop.y), cell, strOff, 24u, rPix1.x - 4.0);
        return mixHudInk(col, ink * 0.7, 0.0, AOS_INK_DIM);
    }
    if (wtype == 8u) {
        vec3 col = rtxPanelBg(th);
        float sz = min(halfSz.x, halfSz.y) * 0.22;
        uint mask = state | (uint(ex0) << 8);
        vec2 dirs[4] = vec2[4](vec2(0.0, -sz), vec2(0.0, sz), vec2(-sz, 0.0), vec2(sz, 0.0));
        for (int i = 0; i < 4; ++i) {
            vec2 p = dirs[i];
            float d = rtxWidgetRoundBox(lp - p, vec2(sz * 0.85), 0.02);
            bool on = (mask & (1u << uint(i))) != 0u;
            vec3 c = on ? th.accent * 0.6 + vec3(0.26, 0.26, 0.28) : rtxPanelEdge(th);
            col = mix(col, c, smoothstep(0.01, -0.01, d));
        }
        return col;
    }
    return vec3(-1.0);
}

vec3 rtxWidgetPanelColor(vec2 winLocal, vec2 winSize, float titleH, float hudH, ThemePal th) {
    if (!rtxWidgetsActive()) return vec3(-1.0);
    vec2 contentOrg = rtxWidgetContentOrg(winSize, titleH, hudH);
    vec2 contentSz = rtxWidgetContentSize(winSize, titleH, hudH);
    vec2 uv = (winLocal - contentOrg) / contentSz;
    uv = clamp(uv, vec2(0.0), vec2(1.0));
    int hoverId = int(ramByte(RTX_WIDGET_RAM + 6u));
    if (hoverId >= int(rtxWidgetCount())) hoverId = -1;
    vec3 col = rtxPanelBg(th);
    uint cnt = rtxWidgetCount();
    for (uint i = 0u; i < cnt; ++i) {
        uint wtype = ramByte(RTX_WIDGET_RAM + 0x10u + i * 16u);
        if (wtype != 0u) continue;
        vec3 w = rtxPaintWidget(i, winLocal, uv, contentOrg, contentSz, th, hoverId, col);
        if (w.x >= 0.0) col = w;
    }
    for (uint i = 0u; i < cnt; ++i) {
        uint wtype = ramByte(RTX_WIDGET_RAM + 0x10u + i * 16u);
        if (wtype == 0u) continue;
        vec3 w = rtxPaintWidget(i, winLocal, uv, contentOrg, contentSz, th, hoverId, col);
        if (w.x >= 0.0) col = w;
    }
    return clamp(col, 0.0, 1.0);
}

vec3 termScrollChrome(vec2 winLocal, vec2 winSize, float titleH, float hudH, ThemePal th) {
    float barW = 14.0;
    float contentTop = titleH;
    float contentBot = winSize.y - hudH;
    if (winLocal.x < winSize.x - barW) return vec3(-1.0);
    if (winLocal.y < contentTop || winLocal.y >= contentBot) return vec3(-1.0);
    float relY = (winLocal.y - contentTop) / max(contentBot - contentTop, 1.0);
    uint pack = field.data_bus[50];
    uint total = pack >> 24u;
    uint off = (pack >> 8u) & 0xFFFFu;
    vec3 track = mix(vec3(0.12, 0.12, 0.14), th.panel * 0.35, 0.5);
    vec3 col = track;
    if (total > 25u) {
        float frac = float(off) / max(float(total - 25u), 1.0);
        float thumbH = max((25.0 / float(total)) * (contentBot - contentTop), 14.0);
        float thumbY0 = frac * (contentBot - contentTop - thumbH);
        if (winLocal.y >= contentTop + thumbY0 && winLocal.y < contentTop + thumbY0 + thumbH)
            col = mix(th.accent, th.gemTint, 0.48);
    }
    float mmX = winLocal.x - (winSize.x - barW);
    if (mmX < 4.0) {
        float line = floor(relY * min(float(total), 96.0));
        float dens = fract(line * 0.31 + float(off) * 0.013);
        col = mix(col, th.title * (0.28 + dens * 0.55), 0.75);
    }
    return col;
}

vec3 rtxDosViewportColor(vec2 pix, vec2 img, ThemePal th) {
    if (aosChromeActive() && aosPanelHidden() && (field.control & CTRL_DOS_PANEL_STRETCH) == 0u)
        return vec3(-1.0);
    float hudH = max(float(field.data_bus[58]), 1.0);
    bool panelStretch = (field.control & CTRL_DOS_PANEL_STRETCH) != 0u;
    vec2 winP0;
    vec2 winP1;
    if (panelStretch) {
        vec2 vp = aosPanelViewport(img);
        float taskH = aosTaskbarHeightPx(img);
        winP0 = vec2(0.0);
        winP1 = vec2(vp.x, vp.y - taskH);
    } else {
        winP0 = vec2(float(field.data_bus[46]), float(field.data_bus[47]));
        winP1 = winP0 + aosFocusedSurfaceSize();
        if (aosChromeActive()) {
            uint surfCount = uint(ramByte(AOS_SURFACE_RAM));
            int focusTab = int(ramByte(AOS_SURFACE_RAM + 1u));
            if (surfCount > 0u && focusTab >= 0) {
                uint sbase = AOS_SURFACE_RAM + 0x10u + uint(focusTab) * 16u;
                uint sflags = ramByte(sbase + 11u);
                if ((sflags & 4u) != 0u) {
                    float ox = float(uint(ramByte(sbase)) | (uint(ramByte(sbase + 1u)) << 8u));
                    float oy = float(uint(ramByte(sbase + 2u)) | (uint(ramByte(sbase + 3u)) << 8u));
                    float pw = float(uint(ramByte(sbase + 4u)) | (uint(ramByte(sbase + 5u)) << 8u));
                    float ph = float(uint(ramByte(sbase + 6u)) | (uint(ramByte(sbase + 7u)) << 8u));
                    if (pw > 8.0 && ph > 8.0) {
                        winP0 = vec2(ox, oy);
                        winP1 = winP0 + vec2(pw, ph);
                    }
                }
            }
        }
        if (winP1.x <= winP0.x + 1.0 || winP1.y <= winP0.y + 1.0)
            winP1 = winP0 + vec2(DOOM_VIEW_W, DOOM_VIEW_H + hudH);
    }
    if (pix.x < winP0.x || pix.y < winP0.y || pix.x >= winP1.x || pix.y >= winP1.y)
        return vec3(-1.0);
    vec2 winLocal = pix - winP0;
    vec2 winSize = winP1 - winP0;
    float titleH = rtxWmTitleH(vec2(img));
    bool aosWm = aosChromeActive();
    float uiSc = max(winSize.x / 1920.0, 0.75) * 1.35;
    vec3 shell = aosWm
        ? aosSdfComposeWindow(winLocal, winSize, titleH, hudH, th, uiSc, true)
        : vec3(-1.0);
    if (aosWm && titleH > 0.0 && winLocal.y < titleH) {
        vec3 tb = rtxWmTitleBar(winLocal, winSize, titleH, th);
        if (tb.x >= -1.5) return tb;
    }
    if (aosWm && titleH > 0.0) {
        vec3 menuDrop = rtxWmMenuDropdown(winLocal, winSize, titleH, th);
        if (menuDrop.x >= 0.0) return menuDrop;
    }
    if (aosWm) {
        vec3 grip = rtxWmResizeGrip(winLocal, winSize, titleH, hudH, th);
        if (grip.x >= 0.0) return grip;
    }
    vec3 scrollCol = termScrollChrome(winLocal, winSize, titleH, hudH, th);
    if (scrollCol.x >= 0.0) return scrollCol;
    if (winLocal.y >= winSize.y - hudH) {
        vec3 status = aosSdStatusBar(winLocal, winSize, hudH, th.border);
        if (status.x >= 0.0)
            return mixHudInk(status, dosHudRamStr(winLocal, 10.0 * uiSc,
                winSize.y - hudH * 0.5 - 8.0 * uiSc, aosHudTextCell(uiSc),
                AOS_FOOTER_RAM + 1u, AOS_FOOTER_LEN),
                dosHudRamStrBorder(winLocal, 10.0 * uiSc,
                winSize.y - hudH * 0.5 - 8.0 * uiSc, aosHudTextCell(uiSc),
                AOS_FOOTER_RAM + 1u, AOS_FOOTER_LEN), AOS_INK_BLACK);
        return dosStatusHudColor(winLocal, winSize, hudH, th);
    }
    bool inWidgetContent = winLocal.y >= titleH && winLocal.y < winSize.y - hudH;
    if (aosChromeActive() && rtxWidgetsActive() && !aosPanelHidden() && inWidgetContent)
        return rtxWidgetPanelColor(winLocal, winSize, titleH, hudH, th);
    vec3 widgetCol = vec3(-1.0);
    if (aosChromeActive() && rtxWidgetsActive())
        widgetCol = rtxWidgetPanelColor(winLocal, winSize, titleH, hudH, th);
    if (widgetCol.x >= 0.0 && !aosPanelHidden() && inWidgetContent)
        return widgetCol;
    DoomViewport v = doomViewportMap(pix, img);
    if (!v.inside) {
        if (widgetCol.x >= 0.0) return widgetCol;
        if (shell.x >= 0.0) return shell;
        return vec3(0.02, 0.02, 0.03);
    }
    if (dosPanelBorderHit(pix, v))
        return th.border;
    if (v.letterbox)
        return vec3(0.02, 0.02, 0.03);
    uint vmode = ramByte(0x449u);
    if (vmode == VGA_MODE_13 || vmode == VGA_MODE_VOODOO || vmode == VGA_MODE_EGA0D
        || vmode == VGA_MODE_EGA12 || vmode == VGA_MODE_SVGA
        || vmode == 4u || vmode == 5u || vmode == 6u || die.video_mode == VGA_MODE_13)
        return clamp(dosSampleGraphics(v.gameUv, vmode), 0.0, 1.0);
    uint cols = vgaCols();
    uint rows = vgaRows();
    float fontScale = max(float(field.data_bus[48]) / 256.0, 1.0);
    uint dispFlags = field.data_bus[49];
    bool crisp = true;
    bool scanOn = false;
    bool aosBiz = aosChromeActive();
    float gridX = v.gameUv.x * float(cols);
    float gridY = v.gameUv.y * float(rows);
    uint col = uint(clamp(floor(gridX), 0.0, float(cols) - 1.0));
    uint row = uint(clamp(floor(gridY), 0.0, float(rows) - 1.0));
    uint ch = vgaCharAt(row, col);
    uint attr = vgaAttrAt(row, col);
    vec2 cell = vec2(fract(gridX), fract(gridY));
    uint bgNibble = (attr >> 4) & 0x7u;
    vec3 fg = aosBiz ? RTX_WIDGET_FG : vgaAttrFgColor(attr & 0xFu, th);
    vec3 bg = aosBiz ? rtxPanelBg(th) : vgaAttrBgColor(bgNibble, th);
    if (!aosBiz) {
        uint footerMode = ramByte(AOS_FOOTER_RAM);
        float matMix = (footerMode == 1u) ? 0.02 : ((footerMode == 2u) ? 0.0 : 0.18);
        if (bgNibble >= 15u) matMix = 0.0;
        bg = mix(bg, aosMaterialTint(v.gameUv, AOS_MAT_PANEL, th.void_, th, field.sealed_time), matMix);
    }
    float glyph = 0.0;
    if (ch >= 32u && ch < 127u) {
        uint px = uint(clamp(floor(cell.x * 8.0), 0.0, 7.0));
        uint py = uint(clamp(floor(cell.y * 16.0), 0.0, 15.0));
        glyph = fontOn(ch, px, py) ? 1.0 : 0.0;
        if (!crisp && fontScale > 1.01)
            glyph = fontInkAA(ch, cell * vec2(8.0, 16.0));
    }
    float cursor = 0.0;
    if (row == vgaCursorRow() && col == vgaCursorCol())
        cursor = step(0.45, fract(field.sealed_time * 2.0)) * 0.35;
    float ink = clamp(glyph + cursor, 0.0, 1.0);
    float outline = 0.0;
    if (ch >= 32u && ch < 127u) {
        uint px = uint(clamp(floor(cell.x * 8.0), 0.0, 7.0));
        uint py = uint(clamp(floor(cell.y * 16.0), 0.0, 15.0));
        outline = clamp(vgaGlyphBorder(ch, cell, px, py) - glyph, 0.0, 1.0);
    }
    vec3 colOut = mix(bg, vec3(0.0), outline * 0.88);
    colOut = mix(colOut, fg, ink);
    return clamp(colOut, 0.0, 1.0);
}

vec3 vgaConsoleViz(vec2 uv, ThemePal th) {
    uint col = uint(clamp(uv.x, 0.0, 0.999) * 80.0);
    uint row = uint(clamp(uv.y, 0.0, 0.999) * 25.0);
    uint ch = vgaCharAt(row, col);
    uint attr = vgaAttrAt(row, col);
    vec3 fg = vgaAttrColor(attr, th);
    vec2 cell = fract(vec2(uv.x * 80.0, uv.y * 25.0));
    float glyph = 0.0;
    if (ch >= 32u && ch < 127u) {
        uint px = uint(cell.x * 8.0);
        uint py = uint(cell.y * 16.0);
        glyph = fontOn(ch, px, py) ? 1.0 : 0.0;
    }
    float cursor = 0.0;
    if (row == vgaCursorRow() && col == vgaCursorCol())
        cursor = step(0.45, fract(field.sealed_time * 2.0)) * 0.35;
    return fg * (glyph + cursor) + th.rule * smoothstep(0.48, 0.5, max(cell.x, cell.y)) * 0.04;
}

vec3 bottomPanelViz(vec2 lp, uint kind, bool live, float t, ThemePal th) {
    ivec4 R = panelPixelRect(kind, live);
    if (!inPixelRect(ivec2(lp), R)) return vec3(0.0);
    vec2 uv = (lp - vec2(R.xy) + 0.5) / vec2(float(R.z - R.x), float(R.w - R.y));
    vec3 col = graphGrid(uv, th);
    if (kind == 1u) col += fieldPhiVizAt(fabricUvFromPanel(uv, 1u), th);
    else if (kind == 2u) col += fieldThermoVizAt(fabricUvFromPanel(uv, 2u), th);
    else if (kind == 3u) {
        col = vgaConsoleViz(uv, th);
        col += chipPackageFrac(lp, t, th, live) * 0.12;
    }
    else if (kind == 4u) col += fieldFlowVizAt(fabricUvFromPanel(uv, 4u), uv, th);
    else {
        vec3 m = memHeatStrip(ivec2(lp), t, th, live);
        col += (m != vec3(0.0)) ? m : busWaveform(ivec2(lp), t, th, live);
    }
    col += debugPanelOverlay(uv, kind, live, t, th);
    return clamp(col, 0.0, 1.35);
}

vec3 graphicLayerFrac(vec2 lp, uint row, uint col, float t, ThemePal th, uint hoverSec) {
    uint kind = panelKindAt(row, col);
    if (kind == 0u) return vec3(0.0);
    return bottomPanelViz(lp, kind, isLiveImgRow(row), t, th);
}

uint helpStrId(uint hoverSec) {
    if (hoverSec == SEC_PHI) return 91u;
    if (hoverSec == SEC_THERMO) return 92u;
    if (hoverSec == SEC_DIE) return 93u;
    if (hoverSec == SEC_FLOW) return 94u;
    if (hoverSec == SEC_MEM) return 95u;
    if (hoverSec == SEC_BUS) return 96u;
    if (hoverSec == SEC_GPR) return 97u;
    if (hoverSec == SEC_FCC) return 98u;
    return 0u;
}

uint helpPopupRow(uint row, uint col, uint hoverSec) {
    if (hoverSec == SEC_NONE || row != HELP_R0) return 0u;
    uint id = helpStrId(hoverSec);
    if (id == 0u) return 0u;
    uint len = (id == 91u || id == 92u || id == 93u || id == 94u || id == 98u) ? 42u : 43u;
    return strField(col, 2u, id, len);
}

uint imgBandLabels(uint row, uint col) {
    if (row == IMG_LABEL_ROW) {
        uint s = strField(col, IMG_PHI_C0, 100u, 8u); if (s != 0u) return s;
        s = strField(col, IMG_THM_C0, 101u, 8u); if (s != 0u) return s;
        s = strField(col, IMG_DIE_C0, 102u, 8u); if (s != 0u) return s;
        s = strField(col, IMG_FLW_C0, 103u, 8u); if (s != 0u) return s;
        s = strField(col, IMG_AUX_C0, 104u, 9u); if (s != 0u) return s;
    }
    if (row == IMG_LIVE_LABEL_ROW) {
        uint s = strField(col, IMG_PHI_C0, 105u, 8u); if (s != 0u) return s;
        s = strField(col, IMG_THM_C0, 106u, 8u); if (s != 0u) return s;
        s = strField(col, IMG_DIE_C0, 107u, 8u); if (s != 0u) return s;
        s = strField(col, IMG_FLW_C0, 108u, 8u); if (s != 0u) return s;
        s = strField(col, IMG_AUX_C0, 109u, 9u); if (s != 0u) return s;
    }
    return 0u;
}

// =============================================================================
// Gap-fill text — punctuate every spare cell with live die/socket data
// =============================================================================
uint gapDataText(uint row, uint col) {
    uint s = fieldOpsLabels(row, col);
    if (s != 0u) return s;
    if (row == MEM_ROW0) {
        s = strField(col, 2u, 38u, 4u); if (s != 0u) return s;
        s = strField(col, 11u, 85u, 8u); if (s != 0u) return s;
        s = strField(col, 46u, 86u, 5u); if (s != 0u) return s;
        s = strField(col, MEM_ASCII0, 86u, 5u); if (s != 0u) return s;
    }
    if (row >= 24u && row <= 28u && col >= 46u && col < 120u) {
        s = strField(col, 46u, 19u, 7u); if (s != 0u) return s;
    }
    return 0u;
}

// =============================================================================
// Layout — every field bounded by GRID_COLS / GRID_ROWS
// =============================================================================
uint getChar(uint row, uint col, uint hoverSec) {
    if (row >= GRID_ROWS || col >= GRID_COLS) return 32u;
    if (isAmmoBoxCell(row, col)) return 32u;
    if (isGraphicZone(row, col, hoverSec)) return 32u;
    if (row == 0u) {
        uint s = strField(col, 2u, 0u, 9u);
        if (s != 0u) return s;
        s = strField(col, 14u, 1u, 22u);
        if (s != 0u) return s;
        s = strField(col, GFX_C0, 79u, 10u);
        if (s != 0u) return s;
        s = strField(col, GFX_C1 + 4u, 80u, 9u);
        if (s != 0u) return s;
        return 32u;
    }
    if (row == IMG_LABEL_ROW || row == IMG_LIVE_LABEL_ROW) {
        uint s = imgBandLabels(row, col);
        if (s != 0u) return s;
    }
    if (row >= HELP_R0 && row <= HELP_R1) {
        uint s = debugConsoleRow(row, col);
        if (s != 0u) return s;
    }
    if (row == 2u) {
        uint s = pipelineStageRow(row, col);
        if (s != 0u) return s;
    }
    if (row == 1u || row == 2u || row == 14u || row == 17u || row == 20u) {
        uint s = fieldOpsLabels(row, col);
        if (s != 0u) return s;
    }
    if (row == 21u) {
        uint s = strField(col, 2u, 14u, 18u);
        if (s != 0u) return s;
        s = strField(col, 46u, 85u, 8u);
        if (s != 0u) return s;
        s = strField(col, 72u, 86u, 5u);
        if (s != 0u) return s;
        s = strField(col, 120u, 51u, 7u);
        if (s != 0u) return s;
    }

    if (row == 3u) {
        uint s;
        s = statusDispatchRow(row, col); if (s != 0u) return s;
        s = acctDispatchRow(row, col, hoverSec); if (s != 0u) return s;
    }
    if (row == 4u) {
        uint s = fccDispatchRow(row, col, hoverSec);
        if (s != 0u) return s;
        if (col < PHI_C1 && hoverSec != SEC_FCC) {
            s = strField(col, PHI_C0 + 29u, 31u, 5u); if (s != 0u) return s;
            s = hexAt(inertiaHex(), col, PHI_C0 + 34u, 4u); if (s != 0u) return s;
        }
    }
    if (row == 5u) {
        uint s;
        s = lit4(col, CA, 71u,80u,82u,45u); if (s != 0u) return s;
        s = lit4(col, CB, 71u,80u,82u,45u); if (s != 0u) return s;
        s = lit4(col, CC, 71u,80u,82u,45u); if (s != 0u) return s;
        s = lit4(col, CD, 71u,80u,82u,45u); if (s != 0u) return s;
        s = lit4(col, CE, 83u,89u,83u,45u); if (s != 0u) return s;
        s = lit4(col, CF, 83u,89u,83u,45u); if (s != 0u) return s;
        s = lit4(col, CG, 83u,89u,83u,45u); if (s != 0u) return s;
        s = lit4(col, CH, 83u,89u,83u,45u); if (s != 0u) return s;
    }
    if (row >= 6u && row <= 13u)
        return gprRow(row, col);
    if (row >= 16u && row <= 18u && hoverSec == SEC_GPR) {
        uint ch = zmmExtRow(row, col);
        if (ch != 32u) return ch;
    }
    if (row >= MEM_ROW0 && row <= MEM_ROW1) {
        uint s = memDumpRow(row, col, hoverSec);
        if (s != 0u) return s;
    }
    if (row >= 24u && row <= 26u) {
        uint s = instrExtRow(row, col);
        if (s != 32u) return s;
    }
    if (row == 15u) {
        uint s = strField(col, CA, 49u, 7u);
        if (s != 0u) return s;
        s = strField(col, GFX_C0, 50u, 8u);
        if (s != 0u) return s;
        s = strField(col, CE, 52u, 7u);
        if (s != 0u) return s;
    }
    if (row == 19u) {
        uint s = fieldProbeRow(row, col);
        if (s != 0u) return s;
    }
    if (row == 21u) {
        uint s = strField(col, 2u, 14u, 18u);
        if (s != 0u) return s;
        s = strField(col, 120u, 20u, 6u);
        if (s != 0u) return s;
        s = strField(col, 120u, 51u, 7u);
        if (s != 0u) return s;
    }
    if (row == BUS_LABEL_ROW) {
        uint s = busSlotLabelRow(row, col);
        if (s != 0u) return s;
        s = strField(col, BUS_C0, 53u, 7u);
        if (s != 0u) return s;
    }
    if (row == 36u) {
        uint s = strField(col, 2u, 15u, 22u);
        if (s != 0u) return s;
        s = strField(col, 120u, 35u, 4u);
        if (s != 0u) return s;
    }
    if (row == 43u) {
        uint s = strField(col, 2u, 19u, 7u);
        if (s != 0u) return s;
        s = strField(col, 22u, 5u, 3u);
        if (s != 0u) return s;
        s = strField(col, 112u, 16u, 11u);
        if (s != 0u) return s;
    }
    if (row >= 37u && row <= 42u && col >= 120u && col < 126u) {
        uint s = lit4(col, 120u, 90u,77u,77u,32u);
        if (s != 0u) return s;
    }
    if (row >= BUS_HEX_R0 && row <= BUS_HEX_R1) {
        uint s = busHexRow(row, col, hoverSec);
        if (s != 0u) return s;
    }
    if (row == BUS_HEX_R1) {
        uint s;
        s = lit4(col, 114u, 83u,84u,80u,58u); if (s != 0u) return s;
        s = hexAt(field.data_bus[28], col, 118u, 8u); if (s != 0u) return s;
    }
    uint gap = gapDataText(row, col);
    if (gap != 0u) return gap;
    return 32u;
}

uint cellKind(uint row, uint col, uint ascii) {
    if (row == 0u || row == 1u || row == 2u || row == 14u || row == 17u || row == 20u || row == 21u || row == BUS_LABEL_ROW) return 3u;
    if (row == IMG_LABEL_ROW || row == IMG_LIVE_LABEL_ROW) return 3u;
    if (row >= HELP_R0 && row <= HELP_R1) return 3u;
    if (row == 0u) return 2u;
    if (row == 2u || row == 5u || row == 15u || row == 17u || row == 21u || row == MEM_ROW0 || row == BUS_LABEL_ROW) return 3u;
    if (ascii >= 48u && ascii <= 57u) return 4u;
    if (ascii >= 65u && ascii <= 70u) return 4u;
    if (col >= MEM_ASCII0 && col < 120u && row >= MEM_ROW0 && row <= MEM_ROW1) return 5u;
    if (col >= 46u && col < MEM_ASCII0 && row >= MEM_ROW0 && row <= MEM_ROW1) return 5u;
    if (ascii == 124u || ascii == 45u) return 6u;
    if (col >= 78u && col < 84u && row == 22u) return 3u;
    if (row == 43u && col >= 2u && col < 16u) return 3u;
    if (col >= GFX_C0 && col < GFX_C1 && row == 4u) return 1u;
    return 0u;
}

