ivec4 cellPixelRect(uint row, uint col) {
    return ivec4(
        int(col * COL_PITCH), int(row * ROW_PITCH),
        int((col + 1u) * COL_PITCH), int((row + 1u) * ROW_PITCH));
}

bool inPixelRect(ivec2 p, ivec4 r) {
    return p.x >= r.x && p.y >= r.y && p.x < r.z && p.y < r.w;
}

uint regStream(uint i) {
    uint s = i % 24u;
    if (s == 0u) return die.EAX; if (s == 1u) return die.EBX; if (s == 2u) return die.ECX;
    if (s == 3u) return die.EDX; if (s == 4u) return die.ESI; if (s == 5u) return die.EDI;
    if (s == 6u) return die.EBP; if (s == 7u) return die.ESP;
    if (s == 8u) return die.R8;  if (s == 9u) return die.R9;  if (s == 10u) return die.R10;
    if (s == 11u) return die.R11; if (s == 12u) return die.R12; if (s == 13u) return die.R13;
    if (s == 14u) return die.R14; if (s == 15u) return die.R15;
    if (s == 16u) return field.data_bus[i % 16u];
    if (s == 17u) return field.address_bus[i % 16u];
    if (s == 18u) return die.ZMM1024[i % 32u][0];
    if (s == 19u) return die.TLB[i % 2048u];
    if (s == 20u) return die.PML4[i % 512u];
    if (s == 21u) return die.PDPT[i % 512u];
    if (s == 22u) return die.PD[i % 512u];
    return die.PT[i % 512u];
}

vec2 project3D(vec3 p, float yaw, float pitch) {
    float cy = cos(yaw); float sy = sin(yaw);
    float cx = cos(pitch); float sx = sin(pitch);
    vec3 r = p;
    r.xz = mat2(cy, -sy, sy, cy) * r.xz;
    r.yz = mat2(cx, -sx, sx, cx) * r.yz;
    float persp = 1.0 / (2.15 - r.z);
    return r.xy * persp * 0.42 + 0.5;
}

float seg2D(vec2 uv, vec2 a, vec2 b) {
    vec2 pa = uv - a; vec2 ba = b - a;
    float h = clamp(dot(pa, ba) / max(dot(ba, ba), 0.0001), 0.0, 1.0);
    return length(pa - ba * h);
}

vec3 vizRot3DChart(vec2 uv, uint slot, float t, ThemePal th) {
    vec3 col = mix(th.void_, th.panel, 0.22);
    float yaw = t * (0.55 + float(slot) * 0.07);
    float pitch = t * 0.38 + float(slot) * 0.31;
    vec2 prev = vec2(-1.0);
    for (uint i = 0u; i < 14u; ++i) {
        uint v = regStream(i + slot * 3u);
        vec3 p = vec3(float(i) / 13.0 - 0.5,
                      float(v & 0xFFu) / 255.0 - 0.5,
                      float((v >> 8) & 0xFFu) / 255.0 - 0.5);
        vec2 pt = project3D(p, yaw, pitch);
        if (prev.x >= 0.0) {
            float ln = seg2D(uv, prev, pt);
            col = mix(col, quantumInduct(wordEntropy(v), float(i) * 0.06 + t * 0.12 + float(slot) * 0.1, th) * 1.35,
                      smoothstep(0.028, 0.0, ln));
        }
        float dot = smoothstep(0.018, 0.0, length(uv - pt));
        col += quantumInduct(wordEntropy(v), float(i) * 0.09 + float(slot) * 0.17, th) * dot * 1.4;
        prev = pt;
    }
    return col;
}

vec3 vizRadar(vec2 uv, uint slot, float t, ThemePal th) {
    vec2 c = vec2(0.5);
    vec3 col = mix(th.panel, th.void_, 0.3);
    float spokes = 0.0;
    for (uint i = 0u; i < 8u; ++i) {
        float ang = float(i) / 8.0 * 6.28318 + t * 0.2;
        uint v = regStream(i + slot * 5u);
        float r = (0.12 + float(v & 0xFFu) / 255.0 * 0.36);
        vec2 pt = c + vec2(cos(ang), sin(ang)) * r;
        spokes = max(spokes, smoothstep(0.016, 0.0, seg2D(uv, c, pt)));
        col += quantumInduct(wordEntropy(v), float(i) * 0.11 + t * 0.05, th) * smoothstep(0.014, 0.0, length(uv - pt));
    }
    col = mix(col, quantumInduct(wordEntropy(regStream(slot * 5u)), t * 0.08 + float(slot) * 0.2, th), spokes * 0.85);
    return col;
}

vec3 vizDotMatrix(vec2 uv, uint slot, float t, ThemePal th) {
    vec3 col = mix(th.panel, th.void_, 0.25);
    for (uint i = 0u; i < 12u; ++i) {
        uint v = regStream(i + slot * 7u);
        vec2 pt = vec2(fract(float(v) * 0.00011 + float(i) * 0.073 + float(slot) * 0.02),
                       fract(float(v >> 9) * 0.00017 + float(i) * 0.051 + t * 0.03));
        float pulse = 0.6 + 0.4 * sin(t * 4.0 + float(i) + float(v & 0xFu));
        col += quantumInduct(wordEntropy(v), float(i) * 0.08 + float(slot) * 0.13, th) *
               smoothstep(0.02, 0.0, length(uv - pt)) * pulse;
    }
    return col;
}

vec3 vizTLBGrid(vec2 uv, uint row, uint cellCol, float t, ThemePal th) {
    vec3 col = mix(th.panel, th.void_, 0.3);
    uint idx = ((row * 3u + cellCol) * 137u + die.EIP) % 2048u;
    for (uint dy = 0u; dy < 4u; ++dy) {
        for (uint dx = 0u; dx < 4u; ++dx) {
            uint tlb = die.TLB[(idx + dy * 4u + dx) % 2048u];
            vec2 pt = vec2((float(dx) + 0.5) / 4.0, (float(dy) + 0.5) / 4.0);
            float on = float(tlb & 1u);
            float h = fract(float(tlb >> 4) * 0.0001 + float(dy + dx) * 0.1);
            col = mix(col, quantumInduct(wordEntropy(tlb), h + t * 0.04, th), smoothstep(0.09, 0.04, length(uv - pt)) * on);
        }
    }
    return col;
}

vec3 vizZMMStrip(vec2 uv, uint row, float t, ThemePal th) {
    vec3 col = mix(th.panel, th.void_, 0.28);
    uint zrow = (row + die.cycle_count) % 32u;
    float lastY = 0.85;
    for (uint i = 0u; i < 10u; ++i) {
        uint v = die.ZMM1024[zrow][i];
        float samp = float(v & 0xFFu) / 255.0;
        float x0 = float(i) / 9.0;
        float x1 = float(i + 1u) / 9.0;
        float y0 = 0.85 - samp * 0.7;
        if (uv.x >= x0 && uv.x < x1) {
            float y = mix(lastY, y0, (uv.x - x0) / max(x1 - x0, 0.001));
            float ln = smoothstep(0.014, 0.0, abs(uv.y - y));
            col = mix(col, quantumInduct(wordEntropy(v), float(i) * 0.07 + float(zrow) * 0.03 + t * 0.1, th), ln);
        }
        lastY = y0;
    }
    return col;
}

vec3 vizWideScope(vec2 uv, float t, ThemePal th) {
    vec3 col = mix(th.panel, th.void_, 0.32);
    float lastY = 0.5;
    for (uint i = 0u; i < 24u; ++i) {
        uint v = field.data_bus[i % 16u] ^ die.ZMM1024[i % 32u][i % 8u];
        float samp = float(v & 0xFFu) / 255.0;
        float x0 = float(i) / 23.0;
        float x1 = float(i + 1u) / 23.0;
        float y0 = 0.5 + (samp - 0.5) * 0.8;
        if (uv.x >= x0 && uv.x < x1) {
            float y = mix(lastY, y0, (uv.x - x0) / max(x1 - x0, 0.001));
            col = mix(col, quantumInduct(wordEntropy(v), float(i) * 0.04 + t * 0.08, th), smoothstep(0.016, 0.0, abs(uv.y - y)));
        }
        lastY = y0;
    }
    return col;
}

vec3 vizPipelineStack(vec2 uv, uint slot, float t, ThemePal th) {
    vec3 col = mix(th.panel, th.void_, 0.3);
    float yaw = t * 0.9 + float(slot) * 0.5;
    for (uint stage = 0u; stage < 6u; ++stage) {
        uint v = die.RAM[(die.EIP / 4u + stage) % uint(die.RAM.length())];
        float h = float(stage) / 5.0;
        for (uint k = 0u; k < 6u; ++k) {
            float ang = float(k) / 6.0 * 6.28318;
            vec3 p = vec3(cos(ang) * 0.22, h - 0.5, sin(ang) * 0.22);
            p.x += float(v & 0xFu) * 0.01;
            vec2 pt = project3D(p, yaw, 0.65);
            col += quantumInduct(wordEntropy(v), h + float(k) * 0.05 + t * 0.06, th) *
                   smoothstep(0.02, 0.0, length(uv - pt)) * 0.9;
        }
    }
    return col;
}

uint vizKind(uint row, uint col, uint hoverSec) {
    return panelKindAt(row, col);
}

vec3 fieldPhiVizAt(vec2 fuv, ThemePal th) {
    ivec2 fs = imageSize(fieldPhi);
    ivec2 fc = fieldMapCoord(fuv);
    float phi = imageLoad(fieldPhi, fc).r;
    float phiX = imageLoad(fieldPhi, clamp(fc + ivec2(1, 0), ivec2(0), fs - ivec2(1))).r
               - imageLoad(fieldPhi, clamp(fc - ivec2(1, 0), ivec2(0), fs - ivec2(1))).r;
    float phiY = imageLoad(fieldPhi, clamp(fc + ivec2(0, 1), ivec2(0), fs - ivec2(1))).r
               - imageLoad(fieldPhi, clamp(fc - ivec2(0, 1), ivec2(0), fs - ivec2(1))).r;
    float n = clamp(phi * 0.5 + 0.5, 0.0, 1.0);
    vec3 col = mix(vec3(0.0, 0.08, 0.22), quantumInduct(n, phi * 6.28318, th), 0.97);
    float grad = length(vec2(phiX, phiY));
    col += th.title * grad * 0.45;
    col = clamp(col * (0.88 + grad * 0.35), 0.0, 1.0);
    return col;
}

vec3 fieldThermoVizAt(vec2 fuv, ThemePal th) {
    ivec2 fc = fieldMapCoord(fuv);
    float h = imageLoad(fieldThermo, fc).r;
    vec3 col = mix(vec3(0.0, 0.04, 0.10), quantumInduct(h, float(fc.x + fc.y) * 0.02, th), 0.98);
    col += th.warn * smoothstep(0.55, 0.92, h) * 0.35;
    col += th.title * smoothstep(0.35, 0.75, h) * 0.12;
    return clamp(col * 0.92, 0.0, 1.0);
}

vec3 fieldFlowVizAt(vec2 fuv, vec2 cellUv, ThemePal th) {
    ivec2 fc = fieldMapCoord(fuv);
    vec4 f = imageLoad(fieldFlow, fc);
    float mag = length(f.yz);
    vec3 col = mix(vec3(0.0, 0.02, 0.08), quantumInduct(f.x, mag * 8.0, th), 0.96);
    col += th.copper * mag * 0.42;
    float ln = smoothstep(0.018, 0.0, abs(cellUv.y - (0.5 + f.y * 0.38)));
    col = mix(col, th.title, ln * clamp(mag * 0.9, 0.0, 1.0));
    col += th.accent * smoothstep(0.01, 0.0, abs(cellUv.x - (0.5 + f.z * 0.22))) * mag * 0.35;
    return clamp(col * 0.9, 0.0, 1.0);
}

vec3 gapViz(ivec2 lp, uint row, uint col, uint kind, float t, ThemePal th, uint hoverSec) {
    ivec4 R = cellPixelRect(row, col);
    if (!inPixelRect(lp, R)) return vec3(0.0);
    vec2 cellUv = (vec2(lp - R.xy) + 0.5) / vec2(float(R.z - R.x), float(R.w - R.y));
    vec2 fuv = fabricUvFromCell(cellUv, row, col, hoverSec);
    if (kind == 1u) return fieldPhiVizAt(fuv, th);
    if (kind == 2u) return fieldThermoVizAt(fuv, th);
    if (kind == 3u) return fieldFlowVizAt(fuv, cellUv, th);
    return vec3(0.0);
}

ivec4 imgPanelRect(uint c0, uint c1, uint r0, uint r1) {
    return ivec4(
        int(c0 * COL_PITCH), int(r0 * ROW_PITCH),
        int(c1 * COL_PITCH), int((r1 + 1u) * ROW_PITCH));
}

ivec4 panelPixelRect(uint kind, bool live) {
    uint r0 = live ? IMG_LIVE_R0 : IMG_STATIC_R0;
    uint r1 = live ? IMG_LIVE_R1 : IMG_STATIC_R1;
    if (kind == 1u) return imgPanelRect(IMG_PHI_C0, IMG_PHI_C1, r0, r1);
    if (kind == 2u) return imgPanelRect(IMG_THM_C0, IMG_THM_C1, r0, r1);
    if (kind == 3u) return imgPanelRect(IMG_DIE_C0, IMG_DIE_C1, r0, r1);
    if (kind == 4u) return imgPanelRect(IMG_FLW_C0, IMG_FLW_C1, r0, r1);
    return imgPanelRect(IMG_AUX_C0, IMG_AUX_C1, r0, r1);
}

float pinSignal(uint pin, float t) {
    uint bus = (pin < 16u) ? field.address_bus[pin] : field.data_bus[pin - 16u];
    float e = field_entropy(t, bus ^ die.cycle_count ^ pin);
    float act = float((bus ^ die.EAX ^ die.EBX) & 0xFu) / 15.0;
    return clamp(0.2 + e * 0.55 + act * 0.4, 0.0, 1.0);
}

vec3 ramHeat(uint idx, float t, ThemePal th) {
    uint w = die.RAM[idx % 512u];
    float dens = wordEntropy(w);
    float phase = float(idx) * 0.31 + t * 0.42 + float((w >> 16) & 0xFFu) * 0.01;
    return quantumInduct(dens, phase, th) * (0.32 + dens * 0.68);
}

float gemFacets(vec2 uv, float steps, float sharp) {
    float a = atan(uv.y, uv.x);
    float r = length(uv);
    float facet = abs(sin(a * steps + floor(r * 9.0) * 0.62));
    return pow(facet, sharp);
}

vec3 gemCore(vec2 coreUV, uint reg, float t, ThemePal th) {
    float steps = 11.0 * th.facetMul;
    float facets = gemFacets(coreUV, steps, 2.8);
    float fresnel = pow(1.0 - clamp(length(coreUV) * 1.35, 0.0, 1.0), 2.2) * th.ior * 0.12;
    float fire = facets * th.dispersion * 10.0;
    vec3 base = th.gemTint * (0.35 + facets * 0.65);
    base.r += fire * sin(t * 3.1 + float(reg) * 0.00011);
    base.g += fire * sin(t * 2.6 + float(reg) * 0.00007 + 1.2);
    base.b += fire * cos(t * 2.9 + float(reg) * 0.00009);
    return base + th.accent * fresnel + vec3(facets * 0.08);
}

vec4 socBlockUv(uint id) {
    if (id == SOC_CORE0) return vec4(0.04, 0.06, 0.26, 0.30);
    if (id == SOC_CORE1) return vec4(0.28, 0.06, 0.50, 0.30);
    if (id == SOC_CORE2) return vec4(0.54, 0.06, 0.76, 0.30);
    if (id == SOC_CORE3) return vec4(0.78, 0.06, 0.96, 0.30);
    if (id == SOC_L2)    return vec4(0.04, 0.34, 0.48, 0.58);
    if (id == SOC_MC)    return vec4(0.52, 0.34, 0.96, 0.58);
    if (id == SOC_IO)    return vec4(0.04, 0.62, 0.30, 0.88);
    if (id == SOC_NOC)   return vec4(0.34, 0.62, 0.66, 0.88);
    if (id == SOC_VEC)   return vec4(0.70, 0.62, 0.96, 0.88);
    if (id == SOC_TLB)   return vec4(0.04, 0.90, 0.48, 0.98);
    if (id == SOC_BUS)   return vec4(0.52, 0.90, 0.96, 0.98);
    return vec4(0.5, 0.5, 0.51, 0.51);
}

vec2 socBlockCenter(uint id) {
    vec4 b = socBlockUv(id);
    return vec2((b.x + b.z) * 0.5, (b.y + b.w) * 0.5);
}

uint socBlockHeatWord(uint id) {
    if (id == SOC_CORE0) return die.EAX ^ die.cycle_count;
    if (id == SOC_CORE1) return die.EBX ^ (die.cycle_count >> 2);
    if (id == SOC_CORE2) return die.ECX ^ die.EIP;
    if (id == SOC_CORE3) return die.EDX ^ die.ESP;
    if (id == SOC_L2)    return die.CR3 ^ die.TLB[(die.EIP >> 12) & 2047u];
    if (id == SOC_MC)    return die.ESP ^ die.RAM[(die.EIP / 4u) % 512u];
    if (id == SOC_IO)    return field.data_bus[0] ^ field.data_bus[1] ^ field.data_bus[2];
    if (id == SOC_NOC)   return field.address_bus[0] ^ field.address_bus[1] ^ die.CR3;
    if (id == SOC_VEC)   return die.ZMM1024[0][0] ^ die.ZMM1024[1][0];
    if (id == SOC_TLB)   return die.TLB[0] ^ die.TLB[127] ^ die.TLB[255];
    if (id == SOC_BUS)   return field.data_bus[4] ^ field.data_bus[8] ^ die.EDX;
    return die.cycle_count;
}

vec2 socBlockCenterPuv(uint id) {
    vec2 buv = socBlockCenter(id);
    vec2 c = gridCenter(IMG_DIE_C0, IMG_DIE_C1, IMG_STATIC_R0, IMG_STATIC_R1);
    vec2 h = gridHalf(IMG_DIE_C0, IMG_DIE_C1, IMG_STATIC_R0, IMG_STATIC_R1);
    return c + (buv - vec2(0.5)) * h * 2.0;
}

vec3 rtxHotspotTrace(vec2 puv, float t, ThemePal th, uint hoverSec) {
    if (hoverSec != SEC_DIE && hoverSec != SEC_FLOW) return vec3(0.0);
    vec3 acc = vec3(0.0);
    for (uint id = SOC_CORE0; id <= SOC_BUS; ++id) {
        vec2 hot = socBlockCenterPuv(id);
        vec2 L = hot - puv;
        float dist = length(L);
        if (dist < 0.001) continue;
        vec2 dir = L / dist;
        float march = 0.0;
        float dens = wordEntropy(socBlockHeatWord(id));
        for (int s = 0; s < 16; ++s) {
            vec2 sp = puv + dir * float(s) * 0.006;
            float gate = fbm(sp * 18.0 + vec2(t * 0.08, float(id) * 0.17));
            march += gate * exp(-float(s) * (0.12 + (1.0 - dens) * 0.08));
        }
        acc += quantumInduct(dens, float(id) * 0.41 + t * 0.25, th) *
               march * smoothstep(0.42, 0.0, dist) * dens * 0.06;
    }
    vec2 grin = gridCenter(IMG_DIE_C0 + 12u, IMG_DIE_C0 + 24u, IMG_STATIC_R0 + 2u, IMG_STATIC_R0 + 4u);
    vec2 v = puv - grin;
    float spec = pow(max(0.0, 1.0 - length(v) * 2.8), th.ior * 2.0);
    acc += th.grin * spec * 0.08;
    return acc;
}

vec3 rtxFabricMarch(vec2 puv, float t, ThemePal th, uint hoverSec) {
    vec3 acc = vec3(0.0);
    vec2 light = mouseFabricUv();
    for (int i = 0; i < 6; ++i) {
        float fi = float(i);
        vec2 dir = normalize(puv - light + vec2(0.0012, 0.0007));
        vec2 sp = clamp(puv - dir * fi * 0.010, vec2(0.0), vec2(1.0));
        ivec2 fc = fieldMapCoord(sp);
        float phi = imageLoad(fieldPhi, fc).r;
        float thermo = imageLoad(fieldThermo, fc).r;
        vec4 flow = imageLoad(fieldFlow, fc);
        float dens = abs(phi) * 0.42 + thermo * 0.48 + length(flow.yz) * 0.38;
        acc += quantumInduct(dens, fi * 0.27 + t * 0.18, th) * exp(-fi * 0.22);
    }
    acc += rtxHotspotTrace(puv, t, th, hoverSec);
    float boost = (hoverSec != SEC_NONE) ? 1.25 : 1.0;
    return acc * boost;
}

vec3 applyRtxFinish(vec2 puv, vec3 color, float t, ThemePal th, uint hoverSec) {
    color += rtxFabricMarch(puv, t, th, hoverSec) * rtxGain();
    return max(color, vec3(0.0));
}

vec3 compositeGlass(vec2 puv, vec3 base, ThemePal th) {
    return base;
}

uint socLabelCol0(uint id) {
    vec4 b = socBlockUv(id);
    float mid = (b.x + b.z) * 0.5;
    return GFX_C0 + uint(mid * float(GFX_C1 - GFX_C0));
}

uint labelHoverBlock(uint row, uint col) {
    if (row < 6u || row > 18u || col < GFX_C0 || col >= GFX_C1) return 0u;
    for (uint id = SOC_CORE0; id <= SOC_BUS; ++id) {
        uint c0 = socLabelCol0(id);
        uint len = (id <= SOC_CORE3) ? 6u : (id <= SOC_MC) ? 3u : (id == SOC_IO) ? 4u :
                   (id == SOC_NOC) ? 4u : (id == SOC_VEC) ? 4u : (id == SOC_TLB) ? 4u : 8u;
        if (col >= c0 && col < c0 + len) return id;
    }
    return 0u;
}

float socBlockSdf(vec2 uv, vec4 b, float r) {
    vec2 h = (vec2(b.z, b.w) - vec2(b.x, b.y)) * 0.5 - vec2(r);
    vec2 c = (vec2(b.x, b.y) + vec2(b.z, b.w)) * 0.5;
    vec2 p = abs(uv - c) - h;
    return length(max(p, 0.0)) + min(max(p.x, p.y), 0.0) - r;
}

vec3 socFloorplan(vec2 uv, float t, ThemePal th, float detail) {
    vec3 col = mix(vec3(0.0, 0.02, 0.05), th.pcb * 0.55, 0.65);
    float pkg = socBlockSdf(uv, vec4(0.02, 0.04, 0.98, 0.98), 0.018);
    float pkgBody = 1.0 - smoothstep(0.0, 0.012, pkg);
    col = mix(col, th.silicon * 0.55, pkgBody * 0.7);

    float finest = max(detail, 1.0);
    vec2 fractUv = uv * vec2(48.0, 28.0) * finest;
    vec2 gf = fract(fractUv) - 0.5;
    float mesh = 1.0 - smoothstep(0.42, 0.48, max(abs(gf.x), abs(gf.y)));
    col += th.rule * mesh * pkgBody * 0.18;

    float hotspot = 0.0;
    for (uint id = SOC_CORE0; id <= SOC_BUS; ++id) {
        vec4 b = socBlockUv(id);
        float d = socBlockSdf(uv, b, 0.012);
        float body = 1.0 - smoothstep(0.0, 0.008 / finest, d);
        float edge = smoothstep(0.014, 0.0, abs(d));
        uint hw = socBlockHeatWord(id);
        vec2 buv = (vec2(b.x, b.y) + vec2(b.z, b.w)) * 0.5;
        float thermo = imageLoad(fieldThermo, fieldMapCoord(buv)).r;
        float heat = clamp(wordEntropy(hw) * 0.45 + thermo * 0.55, 0.0, 1.0);
        float pulse = 0.82 + 0.18 * sin(vizStaticPhase() + float(id) * 1.7);
        vec3 blockCol = quantumInduct(heat, float(hw & 0xFFu) * 0.02 + t * 0.15, th);
        blockCol *= 0.65 + heat * 0.95 + pulse * heat * 0.35;
        col = mix(col, blockCol, body * 0.97);
        col += th.title * edge * (0.55 + heat * 0.85);
        hotspot = max(hotspot, body * heat);

        if (id <= SOC_CORE3) {
            vec2 cu = (uv - vec2(b.x, b.y)) / vec2(b.z - b.x, b.w - b.y);
            vec2 gUV = cu * vec2(6.0, 5.0) * finest;
            vec2 cg = fract(gUV) - 0.5;
            float cgLn = 1.0 - smoothstep(0.38, 0.46, max(abs(cg.x), abs(cg.y)));
            col = mix(col, ramHeat(hw & 511u, t, th), body * cgLn * 0.55);
        }
    }

    for (uint i = 0u; i < 8u; ++i) {
        uint bus = field.data_bus[i];
        vec2 a = socBlockCenter(SOC_CORE0 + (i & 3u));
        vec2 b = (i < 4u) ? socBlockCenter(SOC_L2) : socBlockCenter(SOC_MC);
        float ln = seg2D(uv, a, b);
        float flow = wordEntropy(bus);
        col += quantumInduct(flow, float(i) * 0.31 + t * 0.2, th) *
               smoothstep(0.012 / finest, 0.0, ln) * flow * 0.35;
    }

    for (uint i = 0u; i < 6u; ++i) {
        uint ab = field.address_bus[i];
        vec2 a = socBlockCenter(SOC_IO);
        vec2 b = socBlockCenter(SOC_NOC);
        float ln = seg2D(uv, a, b);
        col += quantumInduct(wordEntropy(ab), float(i) * 0.2, th) *
               smoothstep(0.010 / finest, 0.0, ln) * 0.28;
    }

    float topPin = step(uv.y, 0.025) * step(0.3, fract(uv.x * 64.0 * finest));
    float botPin = step(0.975, uv.y) * step(0.3, fract(uv.x * 64.0));
    uint pinId = uint(fract(uv.x * 64.0) * 64.0);
    float sig = pinSignal(pinId, t);
    col = mix(col, quantumInduct(sig, float(pinId) * 0.07 + t * 0.1, th),
              max(topPin, botPin) * (0.5 + sig * 0.5));

    col += th.warn * hotspot * hotspot * 0.12;
    if (die.irq_vector != 0u)
        col = mix(col, th.warn, pkgBody * 0.35);
    return col;
}

float debugScrollPhase(float t, bool live);

vec3 chipPackageFrac(vec2 lp, float t, ThemePal th, bool live) {
    ivec4 R = panelPixelRect(3u, live);
    vec2 Rf = vec2(R.xy);
    vec2 Rs = vec2(float(R.z - R.x), float(R.w - R.y));
    if (lp.x < Rf.x || lp.y < Rf.y || lp.x >= Rf.x + Rs.x || lp.y >= Rf.y + Rs.y) return vec3(0.0);
    vec2 uv = (lp - Rf + 0.5) / Rs;
    float vt = live ? vizLiveT(t) : vizStaticPhase();
    return socFloorplan(uv, vt, th, live ? 1.15 : 1.0);
}

vec3 memHeatStrip(ivec2 lp, float t, ThemePal th, bool live) {
    ivec4 R = panelPixelRect(5u, live);
    int halfH = (R.w - R.y) / 2;
    ivec4 subR = ivec4(R.x, R.y, R.z, R.y + halfH);
    if (!inPixelRect(lp, subR)) return vec3(0.0);
    vec2 uv = (vec2(lp - subR.xy) + 0.5) / vec2(float(subR.z - subR.x), float(subR.w - subR.y));
    uint cellY = uint(floor(uv.y * 8.0));
    uint cellX = uint(floor(uv.x * 8.0));
    uint memrow = min(cellY, 7u);
    uint base = memPageBase() + memrow * 16u;
    uint idx = base / 4u + cellX + (die.ESP >> 6);
    float vt = live ? vizLiveT(t) : vizStaticPhase();
    vec3 heat = ramHeat(idx, vt, th);
    vec2 gf = fract(uv * vec2(8.0, 8.0)) - 0.5;
    float cellEdge = 1.0 - smoothstep(0.38, 0.48, max(abs(gf.x), abs(gf.y)));
    float espPulse = live ? (0.88 + 0.12 * sin(vt * 6.28318)) : 0.94;
    vec3 col = heat * (0.55 + cellEdge * 0.45) * espPulse;
    float scroll = debugScrollPhase(t, live);
    float spark = 0.0;
    float lastY = 0.92;
    for (uint i = 0u; i < 24u; ++i) {
        uint v = die.ZMM1024[i % 32u][cellX % 32u] ^ die.RAM[TRACE_RAM_BASE + TRACE_SLOTS + (i % TRACE_SLOTS)];
        float samp = float(v & 0xFFu) / 255.0;
        float x0 = float(i) / 23.0;
        float x1 = float(i + 1u) / 23.0;
        float y0 = 0.92 - samp * 0.38;
        float fx0 = fract(x0 + scroll * 0.45);
        float fx1 = fract(x1 + scroll * 0.45);
        if (fract(uv.x + scroll * 0.45) >= fx0 && fract(uv.x + scroll * 0.45) < fx1) {
            float y = mix(lastY, y0, (fract(uv.x + scroll * 0.45) - fx0) / max(fx1 - fx0, 0.001));
            spark = smoothstep(0.012, 0.0, abs(uv.y - y));
        }
        lastY = y0;
    }
    col = mix(col, mix(th.value, th.gemTint, 0.45), spark * 0.75);
    return col;
}

vec3 busWaveform(ivec2 lp, float t, ThemePal th, bool live) {
    ivec4 R = panelPixelRect(5u, live);
    int halfH = (R.w - R.y) / 2;
    ivec4 subR = ivec4(R.x, R.y + halfH, R.z, R.w);
    if (!inPixelRect(lp, subR)) return vec3(0.0);
    vec2 uv = (vec2(lp - subR.xy) + 0.5) / vec2(float(subR.z - subR.x), float(subR.w - subR.y));
    float vt = live ? vizLiveT(t) : vizStaticPhase();
    float scroll = debugScrollPhase(t, live);
    vec2 suv = vec2(fract(uv.x + scroll * 0.6), uv.y);
    vec3 bg = mix(th.panel, th.zebra, 0.5);
    float scope = 0.0;
    float lastY = 0.5;
    for (uint i = 0u; i < 64u; ++i) {
        uint word = field.data_bus[i % 16u] ^ die.RAM[TRACE_RAM_BASE + (i % TRACE_SLOTS)];
        float busVal = float((word >> ((i % 4u) * 8u)) & 0xFFu) / 255.0;
        float x0 = float(i) / 63.0;
        float x1 = float(i + 1u) / 63.0;
        float y0 = 0.5 + (busVal - 0.5) * 0.82;
        float fx0 = fract(x0 + scroll * 0.6);
        float fx1 = fract(x1 + scroll * 0.6);
        if (suv.x >= fx0 && suv.x < fx1) {
            float y = mix(lastY, y0, (suv.x - fx0) / max(fx1 - fx0, 0.001));
            scope = smoothstep(0.018, 0.0, abs(suv.y - y));
        }
        lastY = y0;
    }
    float ax = float(die.EAX & 0xFFu) / 255.0 * 3.5 + 1.0;
    float ay = float(die.EBX & 0xFFu) / 255.0 * 3.5 + 1.0;
    float liss = 0.0;
    for (int s = 0; s < 20; ++s) {
        float ph = float(s) / 19.0 * 6.28318;
        vec2 pt = vec2(0.5 + 0.36 * sin(ax * ph + vt * 1.4),
                       0.5 + 0.30 * sin(ay * ph + vt * 1.1 + float(die.ECX) * 0.00003));
        liss += smoothstep(0.014, 0.0, length(uv - pt)) * 0.35;
    }
    vec3 trace = quantumInduct(wordEntropy(die.EAX ^ die.EBX ^ die.cycle_count),
                               field_entropy(t, die.cycle_count), th);
    float pinRail = step(0.92, fract(uv.x * 24.0)) * 0.25;
    vec3 col = mix(bg, trace, scope * 0.95) + th.copper * pinRail;
    col = mix(col, th.gemTint, liss * 0.55);
    return col;
}

vec3 regGemBar(vec2 uv, uint val, float t, ThemePal th) {
    vec3 col = mix(th.void_, th.panel, 0.14);
    for (uint i = 0u; i < 8u; ++i) {
        uint nib = (val >> ((7u - i) * 4u)) & 0xFu;
        float h = (float(nib) + 0.5) / 16.0;
        float x0 = float(i) / 8.0;
        float x1 = float(i + 1u) / 8.0;
        if (uv.x >= x0 && uv.x < x1) {
            float yTop = 0.90 - h * 0.78;
            float fill = step(uv.y, yTop);
            float cap = smoothstep(0.0, 0.05, abs(uv.y - yTop));
            vec3 gem = quantumInduct(nibbleEntropy(nib), float(nib) + float(i) * 0.31 + t * 0.02, th);
            gem *= 0.75 + h * 0.65;
            col = mix(col, gem, fill);
            col += th.title * cap * 0.55;
            float facet = gemFacets(vec2(uv.x * 8.0, h), th.facetMul * 9.0, 3.4);
            col += th.gemTint * facet * fill * 0.22;
        }
    }
    return col;
}

vec3 panelDataLayer(ivec2 lp, uint row, uint col, float t, ThemePal th) {
    ivec4 R = cellPixelRect(row, col);
    if (!inPixelRect(lp, R)) return vec3(0.0);
    vec2 uv = (vec2(lp - R.xy) + 0.5) / vec2(float(R.z - R.x), float(R.w - R.y));
    uint val = gprValueAt(row, col);
    if (val != 0xFFFFFFFFu) return regGemBar(uv, val, t, th);
    val = sysValueAt(row, col);
    if (val != 0xFFFFFFFFu) return regGemBar(uv, val, t, th);
    val = zmmValueAt(row, col);
    if (val != 0xFFFFFFFFu) return regGemBar(uv, val, t, th);
    if (row == 3u && col >= 10u) {
        uint idx = (col - 10u) % 16u;
        uint st = (idx < 4u) ? die.cycle_count : (idx < 7u) ? die.EIP :
                  (idx < 9u) ? die.irq_vector : (idx < 10u) ? die.video_mode :
                  (idx < 12u) ? die.EFLAGS : (idx < 14u) ? die.CR3 : die.ESP;
        return regGemBar(uv, st, t, th);
    }
    if (row >= 22u && row <= 35u) {
        uint memrow = row - 22u;
        uint base = memPageBase() + memrow * 16u;
        uint addr = base + (col - 2u) % 16u;
        uint w = (addr / 4u < uint(die.RAM.length())) ? die.RAM[addr / 4u] : 0u;
        return regGemBar(uv, w, t, th);
    }
    if (row >= 45u) {
        uint slot = (row - 45u) * 16u + (col - 2u) / 8u;
        uint v = (slot < 16u) ? field.data_bus[slot] : field.address_bus[slot - 16u];
        return regGemBar(uv, v, t, th);
    }
    return vec3(0.0);
}

bool isAmmoBoxCell(uint row, uint col) {
    return row >= AMMO_R0 && row <= AMMO_R1 && col >= AMMO_C0 && col < AMMO_C1;
}

ivec4 ammoBoxPixelRect() {
    return ivec4(
        int(AMMO_C0 * COL_PITCH), int(AMMO_R0 * ROW_PITCH),
        int(AMMO_C1 * COL_PITCH), int((AMMO_R1 + 1u) * ROW_PITCH));
}

vec3 sampleAmmo(vec2 uv) {
    ivec2 dim = imageSize(ammoTex);
    if (dim.x <= 0 || dim.y <= 0) return vec3(0.0);
    ivec2 px = clamp(ivec2(uv * vec2(dim)), ivec2(0), dim - ivec2(1));
    return imageLoad(ammoTex, px).rgb;
}

vec3 ammoBoxViz(vec2 lp, float t, ThemePal th) {
    ivec4 R = ammoBoxPixelRect();
    if (!inPixelRect(ivec2(lp), R)) return vec3(0.0);
    vec2 uv = (lp - vec2(R.xy) + 0.5) / vec2(float(R.z - R.x), float(R.w - R.y));
    vec3 col = vec3(0.0);
    float edge = smoothstep(0.02, 0.0, min(min(uv.x, 1.0 - uv.x), min(uv.y, 1.0 - uv.y)));
    col += th.accent * edge * 0.65;
    col += th.title * smoothstep(0.006, 0.0, abs(uv.x - 0.5)) * 0.12;
    col += th.title * smoothstep(0.006, 0.0, abs(uv.y - 0.5)) * 0.12;
    float angle = mod(t, AMMO_ROT_PERIOD) / AMMO_ROT_PERIOD * 6.2831853;
    vec2 p = (uv - 0.5) * 0.86;
    float c = cos(angle);
    float s = sin(angle);
    p = mat2(c, -s, s, c) * p + 0.5;
    if (p.x > 0.06 && p.x < 0.94 && p.y > 0.06 && p.y < 0.94) {
        vec3 tex = sampleAmmo(p);
        col = mix(col, tex, 0.96);
    }
    return col;
}

vec3 graphGrid(vec2 uv, ThemePal th) {
    float g = smoothstep(0.004, 0.0, abs(fract(uv.x * 16.0) - 0.5)) * 0.06;
    g += smoothstep(0.004, 0.0, abs(fract(uv.y * 10.0) - 0.5)) * 0.05;
    return th.rule * g;
}

float debugScrollPhase(float t, bool live) {
    float vt = live ? vizLiveT(t) : vizStaticPhase();
    return vt * 2.2 + float(die.cycle_count) * 0.0011;
}

vec3 debugScrollStrip(vec2 uv, float scroll, uint stream, ThemePal th) {
    if (uv.y > 0.16) return vec3(0.0);
    vec2 suv = vec2(fract(uv.x + scroll), uv.y / 0.16);
    vec3 col = vec3(0.0);
    float lastY = 0.5;
    for (uint i = 0u; i < 96u; ++i) {
        float x0 = float(i) / 95.0;
        float x1 = float(i + 1u) / 95.0;
        uint v = regStream(i + stream * 9u) ^ die.cycle_count;
        float samp = float((v >> ((i % 4u) * 8u)) & 0xFFu) / 255.0;
        float y0 = 0.5 + (samp - 0.5) * 0.88;
        if (suv.x >= fract(x0 + scroll) && suv.x < fract(x1 + scroll)) {
            float y = mix(lastY, y0, (suv.x - fract(x0 + scroll)) / max(fract(x1 + scroll) - fract(x0 + scroll), 0.001));
            float ln = smoothstep(0.016, 0.0, abs(suv.y - y));
            col += quantumInduct(wordEntropy(v), float(i) * 0.04 + scroll * 6.28, th) * ln;
        }
        lastY = y0;
    }
    float sweep = smoothstep(0.018, 0.0, abs(fract(suv.x - scroll * 1.7) - 0.5));
    col += th.warn * sweep * 0.4;
    return col;
}

vec3 debugOpcodeBars(vec2 uv, float scroll, ThemePal th) {
    if (uv.y < 0.80) return vec3(0.0);
    vec2 buv = vec2(fract(uv.x - scroll * 0.35), (uv.y - 0.80) / 0.20);
    vec3 col = vec3(0.0);
    for (uint i = 0u; i < TRACE_SLOTS; ++i) {
        uint idx = (die.cycle_count + TRACE_SLOTS - i) % TRACE_SLOTS;
        uint packed = die.RAM[TRACE_RAM_BASE + TRACE_SLOTS + idx];
        uint op = packed >> 24u;
        float x0 = float(i) / float(TRACE_SLOTS);
        float x1 = float(i + 1u) / float(TRACE_SLOTS);
        if (buv.x >= x0 && buv.x < x1) {
            float h = float(op) / 255.0;
            if (buv.y < h * 0.92 + 0.04)
                col = quantumInduct(h, float(i) * 0.19 + scroll * 3.0, th) * 1.25;
        }
    }
    return col;
}

vec3 debugTlbHeat(vec2 uv, ThemePal th) {
    uint tx = uint(clamp(uv.x, 0.0, 0.999) * 63.0);
    uint ty = uint(clamp(uv.y, 0.0, 0.999) * 31.0);
    uint idx = (ty * 64u + tx) % 2048u;
    uint e = die.TLB[idx];
    float v = float(e & 1u) * (0.3 + float((e >> 4) & 0xFFu) / 255.0);
    return quantumInduct(v, float(idx) * 0.003, th) * v;
}

vec3 debugPanelOverlay(vec2 uv, uint kind, bool live, float t, ThemePal th) {
    float scroll = debugScrollPhase(t, live);
    vec3 col = vec3(0.0);
    col += debugScrollStrip(vec2(uv.x, 1.0 - uv.y), scroll, kind, th);
    col += debugOpcodeBars(uv, scroll, th);
    if (kind == 3u || kind == 5u)
        col += debugTlbHeat(uv, th) * 0.3 * step(0.52, uv.x) * step(uv.y, 0.48);
    float tick = smoothstep(0.003, 0.0, abs(fract(uv.x * 28.0 + scroll * 4.0) - 0.5));
    col += th.value * tick * 0.1;
    return col;
}

uint vgaCols() {
    uint ramCols = ramByte(0x44Au);
    if (ramCols >= 40u && ramCols <= 200u) return ramCols;
    return max(field.data_bus[44], 40u);
}

uint vgaRows() {
    return max(field.data_bus[45], 25u);
}

uint vgaCharAt(uint row, uint col) {
    uint cols = vgaCols();
    uint off = VGA_BASE + (row * cols + col) * 2u;
    return ramByte(off);
}

uint vgaAttrAt(uint row, uint col) {
    uint cols = vgaCols();
    uint off = VGA_BASE + (row * cols + col) * 2u + 1u;
    return ramByte(off);
}

uint vgaCursorCol() { return ramByte(0x450u); }
uint vgaCursorRow() { return ramByte(0x451u); }

vec3 vgaAttrFgColor(uint fg, ThemePal th) {
    if (fg == 0u) return vec3(0.02, 0.02, 0.02);
    if (fg == 1u) return vec3(0.0, 0.0, 0.75);
    if (fg == 2u) return vec3(0.0, 0.82, 0.18);
    if (fg == 3u) return vec3(0.0, 0.65, 0.65);
    if (fg == 4u) return vec3(0.75, 0.0, 0.0);
    if (fg == 5u) return vec3(0.75, 0.0, 0.75);
    if (fg == 6u) return vec3(0.75, 0.5, 0.0);
    if (fg == 7u) return vec3(0.72, 0.72, 0.72);
    if (fg == 8u) return vec3(0.35, 0.35, 0.35);
    if (fg == 9u) return vec3(0.35, 0.35, 0.95);
    if (fg == 10u) return vec3(0.35, 0.95, 0.35);
    if (fg == 11u) return vec3(0.35, 0.95, 0.95);
    if (fg == 12u) return vec3(0.95, 0.35, 0.35);
    if (fg == 13u) return vec3(0.95, 0.35, 0.95);
    if (fg == 14u) return vec3(0.95, 0.85, 0.35);
    if (fg >= 15u) return vec3(0.98, 0.98, 0.98);
    return th.label;
}

vec3 vgaAttrBgColor(uint bg, ThemePal th) {
    if (bg == 0u) return vec3(0.02, 0.02, 0.03);
    if (bg == 1u) return vec3(0.0, 0.0, 0.55);
    if (bg == 2u) return vec3(0.0, 0.28, 0.06);
    if (bg == 7u) return vec3(0.78, 0.78, 0.80);
    if (bg >= 15u) return vec3(0.98, 0.98, 0.99);
    return mix(th.panel * 0.35, th.void_ * 0.65, 0.5);
}

vec3 vgaAttrColor(uint attr, ThemePal th) {
    return vgaAttrFgColor(attr & 0xFu, th);
}

const uint CTRL_DOS_PANEL_FS = 256u;
const uint CTRL_DOS_PANEL_STRETCH = 512u;
const uint CTRL_FIELD_DEBUG = 2048u;
const uint DOOM_W = 320u;
const uint DOOM_H = 200u;
const float DOOM_VIEW_W = 640.0;
const float DOOM_VIEW_H = 480.0;
const float DOOM_PIXEL_SCALE = 2.0;

bool aosChromeActive() {
    uint b = field.data_bus[42];
    if ((b & 4096u) != 0u || (b & (1u << 29u)) != 0u) return true;
    if ((field.control & CTRL_RTXDOS) != 0u && (b & (1u << 25u)) != 0u) return true;
    return false;
}

bool aosDesktopActive() {
    return (field.data_bus[42] & 4096u) != 0u;
}

bool aosConsoleShell() {
    return (field.data_bus[42] & (1u << 29u)) != 0u;
}

vec2 aosPanelViewport(vec2 refImg) {
    float vw = field.viewport_w;
    float vh = field.viewport_h;
    if (vw >= 2.0 && vh >= 2.0) return vec2(vw, vh);
    return refImg;
}

float aosTaskbarHeightPx(vec2 refImg) {
    float refW = field.viewport_w;
    if (refW < 2.0) refW = refImg.x;
    return 52.0 * max(refW / 1920.0, 0.75) * 1.35;
}

float aosStretchTaskbarH(vec2 img) {
    if (!aosChromeActive()) return 0.0;
    return aosTaskbarHeightPx(img);
}

bool aosPanelHidden() {
    return (field.data_bus[42] & (1u << 25u)) != 0u;
}

vec2 aosFocusedSurfaceSize() {
    uint packW = field.data_bus[60];
    uint packH = field.data_bus[61];
    float pw = float(packW & 0xFFFFu);
    float ph = float(packH & 0xFFFFu);
    if ((packW >> 24u) == 0u && pw < 2.0)
        pw = float(packW);
    if ((packH >> 24u) == 0u && ph < 2.0)
        ph = float(packH);
    return vec2(pw, ph);
}

struct DoomViewport {
    bool inside;
    bool letterbox;
    vec2 gameUv;
    vec2 p0;
    vec2 p1;
};

float rtxWmTitleH(vec2 img);

DoomViewport doomViewportMap(vec2 pix, vec2 img) {
    DoomViewport v;
    v.inside = false;
    v.letterbox = false;
    v.gameUv = vec2(0.0);
    v.p0 = vec2(0.0);
    v.p1 = vec2(0.0);
    if (aosChromeActive() && aosPanelHidden() && (field.control & CTRL_DOS_PANEL_STRETCH) == 0u)
        return v;
    float hudH = max(float(field.data_bus[58]), 1.0);
    bool panelStretch = (field.control & CTRL_DOS_PANEL_STRETCH) != 0u;
    vec2 winP0;
    vec2 winP1;
    if (panelStretch) {
        vec2 vp = aosPanelViewport(img);
        float taskH = aosTaskbarHeightPx(img);
        winP0 = vec2(0.0);
        winP1 = vec2(vp.x, vp.y - taskH);
    } else {
        winP0 = vec2(float(field.data_bus[46]), float(field.data_bus[47]));
        winP1 = winP0 + aosFocusedSurfaceSize();
        if (aosChromeActive()) {
            const uint surfRam = 0x000B9000u;
            uint surfCount = uint(ramByte(surfRam));
            int focusTab = int(ramByte(surfRam + 1u));
            if (surfCount > 0u && focusTab >= 0) {
                uint sbase = surfRam + 0x10u + uint(focusTab) * 16u;
                uint sflags = ramByte(sbase + 11u);
                if ((sflags & 4u) != 0u) {
                    float ox = float(uint(ramByte(sbase)) | (uint(ramByte(sbase + 1u)) << 8u));
                    float oy = float(uint(ramByte(sbase + 2u)) | (uint(ramByte(sbase + 3u)) << 8u));
                    float pw = float(uint(ramByte(sbase + 4u)) | (uint(ramByte(sbase + 5u)) << 8u));
                    float ph = float(uint(ramByte(sbase + 6u)) | (uint(ramByte(sbase + 7u)) << 8u));
                    if (pw > 8.0 && ph > 8.0) {
                        winP0 = vec2(ox, oy);
                        winP1 = winP0 + vec2(pw, ph);
                    }
                }
            }
        }
        if (winP1.x <= winP0.x + 1.0 || winP1.y <= winP0.y + 1.0)
            winP1 = winP0 + vec2(DOOM_VIEW_W, DOOM_VIEW_H + hudH);
    }
    float titleH = 0.0;
    uint aosBits = field.data_bus[42];
    if (aosChromeActive() && (aosBits & (1u << 25u)) == 0u)
        titleH = rtxWmTitleH(img);
    vec2 p0 = winP0 + vec2(0.0, titleH);
    vec2 p1 = winP1 - vec2(0.0, hudH);
    v.p0 = p0;
    v.p1 = p1;
    if (pix.x < p0.x || pix.y < p0.y || pix.x >= p1.x || pix.y >= p1.y)
        return v;
    v.inside = true;
    vec2 vpSize = p1 - p0;
    vec2 local = (pix - p0) / vpSize;
    uint vmode = ramByte(0x449u);
    float gameW = float(DOOM_W) * DOOM_PIXEL_SCALE;
    float gameH = float(DOOM_H) * DOOM_PIXEL_SCALE;
    if (vmode == 0x12u) {
        gameW = 1280.0;
        gameH = 960.0;
    } else if (vmode == 0xFEu) {
        float mw = float(uint(ramByte(0x98FF0u)) | (uint(ramByte(0x98FF1u)) << 8u));
        float mh = float(uint(ramByte(0x98FF2u)) | (uint(ramByte(0x98FF3u)) << 8u));
        if (mw < 8.0) mw = 800.0;
        if (mh < 8.0) mh = 600.0;
        gameW = mw * DOOM_PIXEL_SCALE;
        gameH = mh * DOOM_PIXEL_SCALE;
    } else if (vmode == 0x0Du || vmode == 4u || vmode == 5u) {
        gameW = 640.0;
        gameH = 400.0;
    } else if (vmode == 6u) {
        gameW = 640.0;
        gameH = 200.0;
    }
    if (vmode == 0x13u || vmode == 0xA0u || vmode == 0x0Du || vmode == 0x12u || vmode == 0xFEu
        || vmode == 4u || vmode == 5u || vmode == 6u) {
        float scale = min(vpSize.x / gameW, vpSize.y / gameH);
        float drawW = gameW * scale;
        float drawH = gameH * scale;
        float padX = (vpSize.x - drawW) * 0.5;
        float padY = (vpSize.y - drawH) * 0.5;
        vec2 lp = local * vpSize;
        if (lp.x < padX || lp.x >= vpSize.x - padX || lp.y < padY || lp.y >= vpSize.y - padY) {
            v.letterbox = true;
            return v;
        }
        v.gameUv = vec2((lp.x - padX) / max(drawW, 1.0), (lp.y - padY) / max(drawH, 1.0));
    } else {
        v.gameUv = local;
    }
    return v;
}

bool doomPixelInViewport(vec2 pix, vec2 img) {
    return doomViewportMap(pix, img).inside;
}

bool aosGuestLetterbox(vec3 c) {
    return c.x >= 0.0 && c.x < 0.05 && c.y < 0.05 && c.z < 0.06;
}

vec3 aosComposeProgramWindow(vec3 shell, vec3 guest, vec2 panelPos, vec2 img) {
    if (guest.x < 0.0) return shell;
    if (doomPixelInViewport(panelPos, img)) {
        if (!aosGuestLetterbox(guest)) return guest;
        return shell;
    }
    return guest;
}

bool dosPanelBorderHit(vec2 pix, DoomViewport v) {
    vec2 vpSize = v.p1 - v.p0;
    vec2 lp = pix - v.p0;
    return lp.x < 1.5 || lp.y < 1.5 || lp.x >= vpSize.x - 1.5 || lp.y >= vpSize.y - 1.5;
}

bool dosWindowBorderHit(vec2 local, vec2 size) {
    return local.x < 1.0 || local.y < 1.0 || local.x >= size.x - 1.0 || local.y >= size.y - 1.0;
}

float dosTitleGlyph(uint ch, vec2 uv, float x0, vec2 cell) {
    return fontGlyphInk(ch, uv, x0, 3.0, cell);
}

float dosTitleRun(vec2 uv, float x0, vec2 cell, uint c0, uint c1, uint c2, uint c3, uint c4, uint c5, uint c6, uint c7) {
    float ink = 0.0;
    float x = x0;
    ink = max(ink, dosTitleGlyph(c0, uv, x, cell)); x += cell.x;
    ink = max(ink, dosTitleGlyph(c1, uv, x, cell)); x += cell.x;
    ink = max(ink, dosTitleGlyph(c2, uv, x, cell)); x += cell.x;
    ink = max(ink, dosTitleGlyph(c3, uv, x, cell)); x += cell.x;
    ink = max(ink, dosTitleGlyph(c4, uv, x, cell)); x += cell.x;
    ink = max(ink, dosTitleGlyph(c5, uv, x, cell)); x += cell.x;
    ink = max(ink, dosTitleGlyph(c6, uv, x, cell)); x += cell.x;
    ink = max(ink, dosTitleGlyph(c7, uv, x, cell));
    return ink;
}

float dosHudGlyph(uint ch, vec2 uv, float x0, float rowY, vec2 cell) {
    return fontGlyphInk(ch, uv, x0, rowY, cell);
}

vec2 aosHudTextCell(float sc) { return vec2(8.0 * sc, 16.0 * sc); }
vec2 aosHudTextCellSm(float sc) { return vec2(8.0 * sc, 14.0 * sc); }

float dosHudRun(vec2 uv, float x0, float rowY, vec2 cell,
    uint c0, uint c1, uint c2, uint c3, uint c4, uint c5, uint c6, uint c7) {
    float ink = 0.0;
    float x = x0;
    ink = max(ink, dosHudGlyph(c0, uv, x, rowY, cell)); x += cell.x;
    ink = max(ink, dosHudGlyph(c1, uv, x, rowY, cell)); x += cell.x;
    ink = max(ink, dosHudGlyph(c2, uv, x, rowY, cell)); x += cell.x;
    ink = max(ink, dosHudGlyph(c3, uv, x, rowY, cell)); x += cell.x;
    ink = max(ink, dosHudGlyph(c4, uv, x, rowY, cell)); x += cell.x;
    ink = max(ink, dosHudGlyph(c5, uv, x, rowY, cell)); x += cell.x;
    ink = max(ink, dosHudGlyph(c6, uv, x, rowY, cell)); x += cell.x;
    ink = max(ink, dosHudGlyph(c7, uv, x, rowY, cell));
    return ink;
}

