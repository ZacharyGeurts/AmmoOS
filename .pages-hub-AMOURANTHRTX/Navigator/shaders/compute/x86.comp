uint strField(uint col, uint start, uint id, uint len) {
    if (col < start || col >= start + len) return 0u;
    return strAt(id, col - start);
}

// =============================================================================
// Entropy / CPU core
// =============================================================================
float field_entropy(float t, uint seed) {
    float phase = t * 137.036;
    float s = sin(phase + float(seed) * 0.6180339887);
    float c = cos(phase * 0.73 + float(seed) * 1.6180339887);
    return fract(s * c * 42.0 * 1.6180339887);
}

void field_trigger_1024(uint seed) {
    float ent = field_entropy(field.sealed_time, seed);
    uint mod = uint(ent * 4294967295.0);
    for (int r = 0; r < 32; ++r)
        for (int w = 0; w < 32; ++w)
            die.ZMM1024[r][w] ^= mod ^ ((r * 137u) ^ (w * seed) ^ (die.cycle_count * 73u));
}

#include "rtx_font_render.inc"

uint toHexChar(uint nibble) {
    nibble &= 0xFu;
    return (nibble < 10u) ? (48u + nibble) : (55u + nibble);
}

uint hexAt(uint val, uint col, uint start, uint digits) {
    if (col < start || col >= start + digits) return 0u;
    return toHexChar(val >> ((digits - 1u - (col - start)) * 4u));
}

uint lit4(uint col, uint start, uint a, uint b, uint c, uint d) {
    if (col < start || col >= start + 4u) return 0u;
    if (col == start) return a;
    if (col == start+1u) return b;
    if (col == start+2u) return c;
    return d;
}

uint ruleChar(uint col) {
    if (col == 0u || col >= GRID_COLS - 1u) return 124u;
    return 45u;
}

uint regLabel(uint col, uint lblC, uint a, uint b, uint c, uint d) {
    return lit4(col, lblC, a, b, c, d);
}

uint regValue(uint col, uint valC, uint val) {
    return hexAt(val, col, valC, 8u);
}

uint regPair(uint col, uint lblC, uint valC, uint a, uint b, uint c, uint d, uint val) {
    uint ch = regLabel(col, lblC, a, b, c, d);
    if (ch != 0u) return ch;
    return regValue(col, valC, val);
}

bool colInVal(uint col, uint valC);
uint sysValueAt(uint row, uint col);

uint zmmIdLabel(uint col, uint lblC, uint zmmId) {
    if (col < lblC || col >= lblC + 4u) return 0u;
    if (col == lblC) return 90u;
    if (zmmId < 10u) {
        if (col == lblC + 1u) return 48u + zmmId;
        if (col == lblC + 2u) return 58u;
        return 32u;
    }
    if (col == lblC + 1u) return 49u;
    if (col == lblC + 2u) return (zmmId == 10u) ? 48u : 49u;
    return 58u;
}

