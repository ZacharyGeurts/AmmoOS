// =============================================================================
// Chip die · pins · RAM heat — procedural silicon art
// =============================================================================
float hash21(vec2 p) {
    return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
}

vec3 hsv2rgb(vec3 c) {
    vec3 k = vec3(1.0, 2.0 / 3.0, 1.0 / 3.0);
    vec3 p = abs(fract(c.xxx + k.xyz) * 6.0 - k.zxy);
    return c.z * mix(vec3(1.0), clamp(p - 1.0, 0.0, 1.0), c.y);
}

float nibbleEntropy(uint nib) {
    nib &= 0xFu;
    uint c = 0u;
    for (uint i = 0u; i < 4u; ++i) c += (nib >> i) & 1u;
    return float(c) / 4.0;
}

float wordEntropy(uint w) {
    uint c = 0u;
    for (uint i = 0u; i < 32u; ++i) c += (w >> i) & 1u;
    return float(c) / 32.0;
}

// Field telemetry palette — high contrast cold/hot (real fabric samples)
vec3 quantumInduct(float density, float phase, ThemePal th) {
    vec3 cold = vec3(0.0, 0.42, 1.00);
    vec3 hot  = vec3(1.00, 0.22, 0.02);
    float coil = sin(phase * 6.28318 + field.maxwell_entropy_seed * 9.0) * 0.5 + 0.5;
    float mixv = clamp(pow(density * 0.95 + coil * 0.05, 0.82), 0.0, 1.0);
    return mix(cold, hot, mixv) * 0.72;
}

vec3 fuelHue(float h, ThemePal th) {
    return quantumInduct(fract(h), h, th);
}

// Slow architectural inertia — page/EIP/CR3 thermal drift (changes gradually as die runs)
float slowInertia() {
    uint pc = die.EIP / 4u;
    uint ramw = (pc < uint(die.RAM.length())) ? die.RAM[pc] : 0u;
    uint s = (die.cycle_count >> 2) ^ (die.EIP >> 6) ^ die.CR3 ^ (die.ESP >> 8) ^ (ramw >> 4);
    return float(s & 0xFFFFu) / 65535.0;
}

uint inertiaHex() {
    uint pc = die.EIP / 4u;
    uint ramw = (pc < uint(die.RAM.length())) ? die.RAM[pc] : 0u;
    return ((die.cycle_count >> 2) ^ (die.EIP >> 6) ^ die.CR3 ^ (die.ESP >> 8) ^ (ramw >> 4)) & 0xFFFFu;
}

float hash11(float p) { return fract(sin(p) * 43758.5453123); }

float noise2(vec2 p) {
    vec2 i = floor(p);
    vec2 f = fract(p);
    f = f * f * (3.0 - 2.0 * f);
    float a = hash11(dot(i, vec2(1.0, 57.0)));
    float b = hash11(dot(i + vec2(1.0, 0.0), vec2(1.0, 57.0)));
    float c = hash11(dot(i + vec2(0.0, 1.0), vec2(1.0, 57.0)));
    float d = hash11(dot(i + vec2(1.0, 1.0), vec2(1.0, 57.0)));
    return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
}

float fbm(vec2 p) {
    float v = 0.0;
    float a = 0.5;
    for (int i = 0; i < 5; ++i) {
        v += a * noise2(p);
        p = p * 2.13 + vec2(1.7, 9.2);
        a *= 0.5;
    }
    return v;
}

#include "aos_sdf.inc"
#include "aos_sdf_wm.inc"
float sdRoundBox(vec2 p, vec2 halfSize, float radius) {
    return aosSdRoundBox(p, halfSize, radius);
}

struct HudLayout {
    ivec2 panelSize;
    ivec2 offset;
    vec2 puv;
    bool inside;
};

HudLayout mapHud16x9(ivec2 gid, ivec2 img) {
    HudLayout h;
    h.panelSize = img;
    h.offset = ivec2(0);
    h.inside = gid.x >= 0 && gid.y >= 0 && gid.x < img.x && gid.y < img.y;
    h.puv = vec2(gid) / vec2(max(img, ivec2(1)));
    return h;
}

vec3 fluidWater(vec2 uv, float slowT, float inertia, ThemePal th) {
    vec2 flow = vec2(slowT * 0.11, slowT * 0.07);
    float n1 = fbm(uv * 2.4 + flow);
    float n2 = fbm(uv * 4.2 - flow * 0.6 + inertia * 2.5);
    float n3 = fbm(uv * 7.0 + vec2(inertia, slowT * 0.04));
    float surface = n1 * 0.5 + n2 * 0.32 + n3 * 0.18;
    float caustic = pow(clamp(abs(sin((surface + slowT * 0.2) * 9.0)), 0.0, 1.0), 2.8);
    vec3 deep = mix(th.void_, th.silicon * 0.6, 0.35 + inertia * 0.4);
    vec3 shallow = th.accent * 0.18 + th.gemTint * 0.12 + th.section * 0.08;
    vec3 col = mix(deep, shallow, surface * 0.45 + 0.12);
    col += th.accent * caustic * 0.10;
    col += th.gemTint * fbm(uv * 12.0 + slowT) * 0.04;
    return col;
}

vec2 gridCenter(uint c0, uint c1, uint r0, uint r1) {
    float invC = 1.0 / float(GRID_COLS);
    float invR = 1.0 / float(GRID_ROWS);
    return vec2((float(c0) + float(c1)) * 0.5 * invC,
                (float(r0) + float(r1)) * 0.5 * invR);
}

vec2 gridHalf(uint c0, uint c1, uint r0, uint r1) {
    float invC = 1.0 / float(GRID_COLS);
    float invR = 1.0 / float(GRID_ROWS);
    return vec2((float(c1) - float(c0)) * 0.5 * invC,
                (float(r1) - float(r0)) * 0.5 * invR);
}

vec3 glassSheet(vec2 puv, vec2 center, vec2 halfSize, float depth, ThemePal th, vec3 under) {
    vec2 lp = (puv - center) / halfSize;
    float d = sdRoundBox(lp, vec2(1.0), 0.09);
    float body = 1.0 - smoothstep(0.0, 0.014, d);
    float rim = smoothstep(0.035, 0.0, abs(d));
    float bevel = smoothstep(0.08, -0.12, d);
    float inner = smoothstep(0.22, -0.04, d);
    vec3 glass = mix(under * 0.22, th.panel * 0.55 + th.void_ * 0.45, 0.55 + depth * 0.25);
    glass += th.border * rim * 0.72;
    glass += th.accent * rim * 0.28;
    glass += vec3(0.06 + depth * 0.35) * bevel;
    glass += th.gemTint * inner * 0.04;
    return mix(under, glass, body * (0.82 + depth * 0.10));
}

vec3 dotGodRays(vec2 uv, float t, float inertia, ThemePal th) {
    vec2 light = vec2(0.50 + sin(t * 0.04 + inertia * 6.28318) * 0.06, 0.36);
    vec3 acc = vec3(0.0);
    for (uint i = 0u; i < 32u; ++i) {
        uint seed = field.data_bus[i % 16u] ^ die.ZMM1024[i % 32u][0] ^ (i * 73u);
        vec2 pt = vec2(
            fract(float(seed) * 0.00017 + float(i) * 0.031 + inertia * 0.12),
            fract(float(seed >> 8) * 0.00023 + float(i) * 0.019));
        pt = pt * 0.78 + vec2(0.11, 0.14);
        float dot = smoothstep(0.016, 0.0, length(uv - pt));
        vec2 dir = pt - light;
        float len = length(dir);
        if (len > 0.001) dir /= len;
        float shafts = 0.0;
        for (int s = 0; s < 10; ++s) {
            vec2 sp = light + dir * float(s) * 0.035;
            shafts += smoothstep(0.025, 0.0, length(uv - sp)) * exp(-float(s) * 0.18);
        }
        acc += quantumInduct(wordEntropy(seed), fract(float(seed) * 0.00011) + float(i) * 0.04 + t * 0.05, th) *
               dot * (1.2 + shafts * 0.85);
    }
    vec2 v = uv - light;
    float ang = atan(v.y, v.x);
    float beam = exp(-length(v) * 2.8) * pow(0.55 + 0.45 * sin(ang * 6.0 + t * 0.15), 2.0);
    acc += th.accent * beam * 0.18;
    return acc;
}

uint vizKind(uint row, uint col, uint hoverSec);

bool colInVal(uint col, uint valC) {
    return col >= valC && col < valC + 8u;
}

bool colInBankVals(uint col) {
    return colInVal(col, VA) || colInVal(col, VB) || colInVal(col, VC) || colInVal(col, VD)
        || colInVal(col, VE) || colInVal(col, VF) || colInVal(col, VG) || colInVal(col, VH);
}

uint gprValueAt(uint row, uint col) {
    uint r = row - 6u;
    if (r > 3u) return 0xFFFFFFFFu;
    if (colInVal(col, VA)) {
        if (r == 0u) return die.EAX; if (r == 1u) return die.ESI;
        if (r == 2u) return die.R8;  return die.R12;
    }
    if (colInVal(col, VB)) {
        if (r == 0u) return die.EBX; if (r == 1u) return die.EDI;
        if (r == 2u) return die.R9;  return die.R13;
    }
    if (colInVal(col, VC)) {
        if (r == 0u) return die.ECX; if (r == 1u) return die.EBP;
        if (r == 2u) return die.R10; return die.R14;
    }
    if (colInVal(col, VD)) {
        if (r == 0u) return die.EDX; if (r == 1u) return die.ESP;
        if (r == 2u) return die.R11; return die.R15;
    }
    return 0xFFFFFFFFu;
}

uint sysValueAt(uint row, uint col) {
    uint r = row - 6u;
    if (r > 7u) return 0xFFFFFFFFu;
    if (colInVal(col, VE)) {
        if (r == 0u) return die.GDTR; if (r == 1u) return die.DR0; if (r == 2u) return die.CR0;
        if (r == 3u) return die.CR8; if (r == 4u) return die.PDPT[0]; if (r == 5u) return field.data_bus[1];
        if (r == 6u) return field.address_bus[2]; return field.address_bus[6];
    }
    if (colInVal(col, VF)) {
        if (r == 0u) return die.IDTR; if (r == 1u) return die.DR1; if (r == 2u) return die.CR2;
        if (r == 3u) return die.DR6; if (r == 4u) return die.PD[0]; if (r == 5u) return field.data_bus[2];
        if (r == 6u) return field.address_bus[3]; return field.address_bus[7];
    }
    if (colInVal(col, VG)) {
        if (r == 0u) return die.LDTR; if (r == 1u) return die.DR2; if (r == 2u) return die.CR3;
        if (r == 3u) return die.DR7; if (r == 4u) return die.PT[0]; if (r == 5u) return field.address_bus[0];
        if (r == 6u) return field.address_bus[4]; return die.GDT[2];
    }
    if (colInVal(col, VH)) {
        if (r == 0u) return die.TR; if (r == 1u) return die.DR3; if (r == 2u) return die.CR4;
        if (r == 3u) return die.PML4[0]; if (r == 4u) return field.data_bus[0]; if (r == 5u) return field.address_bus[1];
        if (r == 6u) return field.address_bus[5]; return die.IDT[die.irq_vector * 2u];
    }
    return 0xFFFFFFFFu;
}

uint zmmValueAt(uint row, uint col) {
    if (row >= 10u && row <= 13u) {
        uint r = row - 10u;
        if (r == 3u) {
            if (colInVal(col, VA)) return field.data_bus[12];
            if (colInVal(col, VB)) return field.data_bus[13];
            if (colInVal(col, VC)) return field.data_bus[14];
            if (colInVal(col, VD)) return field.data_bus[15];
            return 0xFFFFFFFFu;
        }
        uint b = r * 4u;
        if (colInVal(col, VA)) return die.ZMM1024[b][0];
        if (colInVal(col, VB)) return die.ZMM1024[b + 1u][0];
        if (colInVal(col, VC)) return die.ZMM1024[b + 2u][0];
        if (colInVal(col, VD)) return die.ZMM1024[b + 3u][0];
    }
    if (row >= 16u && row <= 18u) {
        uint b = 12u + (row - 16u) * 4u;
        if (colInVal(col, VA)) return die.ZMM1024[b][0];
        if (colInVal(col, VB)) return die.ZMM1024[b + 1u][0];
        if (colInVal(col, VC)) return die.ZMM1024[b + 2u][0];
        if (colInVal(col, VD)) return die.ZMM1024[b + 3u][0];
    }
    return 0xFFFFFFFFu;
}

