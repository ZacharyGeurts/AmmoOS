vec3 aosExitConfirmModal(vec2 pix, vec2 img, float taskH, ThemePal th) {
    if ((field.data_bus[42] & (1u << 27u)) == 0u) return vec3(-1.0);
    float scale = aosUiScale(img);
    vec2 vp = aosViewport(img);
    float panelW = 420.0 * scale;
    float panelH = 200.0 * scale;
    float panelX = (vp.x - panelW) * 0.5;
    float panelY = (vp.y - taskH - panelH) * 0.45;
    if (pix.x < panelX || pix.x >= panelX + panelW
            || pix.y < panelY || pix.y >= panelY + panelH)
        return vec3(-1.0);
    vec2 rel = pix - vec2(panelX, panelY);
    vec3 col = aosMenuPanelBg(rel, vec2(panelW, panelH), scale, th, field.sealed_time);
    col = mix(col, th.accent * 0.18 + vec3(0.12, 0.12, 0.14), 0.55);
    vec2 cell = vec2(8.0 * scale, 12.0 * scale);
    float titleY = panelY + 28.0 * scale;
    float titleInk = dosHudRun(pix, panelX + 24.0 * scale, titleY, cell,
        69u, 120u, 105u, 116u, 32u, 65u, 109u, 111u);
    float titleBorder = dosHudRunBorder(pix, panelX + 24.0 * scale, titleY, cell,
        69u, 120u, 105u, 116u, 32u, 65u, 109u, 111u);
    col = mixHudInk(col, titleInk, titleBorder, AOS_INK_BLACK);
    float bodyY = titleY + 30.0 * scale;
    float bodyInk = dosHudRun(pix, panelX + 24.0 * scale, bodyY, cell,
        83u, 104u, 117u, 116u, 32u, 100u, 111u, 119u);
    float bodyBorder = dosHudRunBorder(pix, panelX + 24.0 * scale, bodyY, cell,
        83u, 104u, 117u, 116u, 32u, 100u, 111u, 119u);
    col = mixHudInk(col, bodyInk, bodyBorder, AOS_INK_BLACK * 0.78);
    float btnW = 148.0 * scale;
    float btnH = 40.0 * scale;
    float btnY = panelY + panelH - btnH - 24.0 * scale;
    float midX = panelX + panelW * 0.5;
    float gap = 12.0 * scale;
    float yesX = midX - gap - btnW;
    float noX = midX + gap;
    if (pix.x >= yesX && pix.x < yesX + btnW && pix.y >= btnY && pix.y < btnY + btnH) {
        vec3 btnCol = aosSdRoundPanel(pix, vec2(yesX, btnY), vec2(yesX + btnW, btnY + btnH), 8.0 * scale,
            vec3(0.22, 0.22, 0.26), th.accent * 0.55 + vec3(0.30, 0.50, 0.72), th.title * 0.2, 1.5 * scale);
        if (btnCol.x < 0.0) return clamp(col, 0.0, 1.0);
        float yesInk = dosHudRun(pix, yesX + 52.0 * scale, btnY + 12.0 * scale, cell,
            89u, 101u, 115u, 32u, 32u, 32u, 32u, 32u);
        col = mixHudInk(btnCol, yesInk, 0.0, AOS_INK_TASKBAR);
        return clamp(col, 0.0, 1.0);
    }
    if (pix.x >= noX && pix.x < noX + btnW && pix.y >= btnY && pix.y < btnY + btnH) {
        vec3 btnCol = aosSdRoundPanel(pix, vec2(noX, btnY), vec2(noX + btnW, btnY + btnH), 8.0 * scale,
            vec3(0.14, 0.14, 0.18), vec3(0.24, 0.24, 0.30), vec3(0.38, 0.38, 0.42), 1.5 * scale);
        if (btnCol.x < 0.0) return clamp(col, 0.0, 1.0);
        float noInk = dosHudRun(pix, noX + 58.0 * scale, btnY + 12.0 * scale, cell,
            78u, 111u, 32u, 32u, 32u, 32u, 32u, 32u);
        col = mixHudInk(btnCol, noInk, 0.0, AOS_INK_BLACK);
        return clamp(col, 0.0, 1.0);
    }
    return clamp(col, 0.0, 1.0);
}

vec3 aosMenuDrawRow(vec2 pix, vec3 base, vec2 panelOrigin, float panelW, float rowY0, float rowH,
        float scale, uint rowBase, uint hoverRow, uint rowIdx, uint rowCount, ThemePal th,
        bool showChevron, bool showDesc) {
    if (pix.y < rowY0 || pix.y >= rowY0 + rowH) return base;
    if (pix.x < panelOrigin.x || pix.x >= panelOrigin.x + panelW) return base;

    uint rowType = ramByte(rowBase);
    if (rowType == 0xFFu) return base;

    vec2 cell = vec2(8.0 * scale, 12.0 * scale);
    vec3 col = base;
    bool hov = hoverRow < rowCount && hoverRow == rowIdx;
    if (hov)
        col = mix(col, vec3(0.20, 0.20, 0.26), 0.88);

    float labelY = showDesc ? rowY0 + 10.0 * scale : rowY0 + rowH * 0.5 - 5.0 * scale;
    float rowMidY = labelY;
    if (showChevron && rowType == 0u) {
        uint flyCat = ramByte(AOS_MENU_RAM + 2u);
        bool open = flyCat == ramByte(rowBase + 3u);
        float arrowInk = dosHudGlyph(62u, pix, panelOrigin.x + panelW - 14.0 * scale, rowMidY, cell);
        vec3 arrowCol = open ? vec3(0.55, 0.82, 0.95) : vec3(0.55, 0.55, 0.60);
        col = mix(col, arrowCol, clamp(arrowInk, 0.0, 1.0) * 0.75);
    }

    uint icon = ramByte(rowBase + 1u);
    float iconSz = (rowType == 0u) ? 22.0 * scale : 20.0 * scale;
    float iconX = panelOrigin.x + 10.0 * scale;
    vec2 icon0 = vec2(iconX, rowY0 + (rowH - iconSz) * 0.5);
    vec2 iuv = (pix - icon0) / iconSz;
    if (icon > 0u && all(greaterThanEqual(iuv, vec2(0.0))) && all(lessThan(iuv, vec2(1.0))))
        col = aosBlendIcon(col, sampleAosIconRgba(icon, iuv));

    float tx = icon0.x + iconSz + 6.0 * scale;
    float ink = dosHudRamStr(pix, tx, rowMidY, cell, rowBase + 4u, AOS_MENU_LABEL_LEN);
    float inkBorder = dosHudRamStrBorder(pix, tx, rowMidY, cell, rowBase + 4u, AOS_MENU_LABEL_LEN);
    vec3 inkCol = AOS_INK_BLACK;
    col = mix(col, vec3(0.0), clamp(inkBorder, 0.0, 1.0) * 0.96);
    col = mix(col, inkCol, clamp(ink, 0.0, 1.0) * 0.92);

    if (showDesc && rowType == 1u) {
        float descY = rowY0 + 28.0 * scale;
        float descInk = dosHudRamStr(pix, tx, descY, cell,
            rowBase + 4u + AOS_MENU_LABEL_LEN, AOS_MENU_DESC_LEN);
        float descBorder = dosHudRamStrBorder(pix, tx, descY, cell,
            rowBase + 4u + AOS_MENU_LABEL_LEN, AOS_MENU_DESC_LEN);
        col = mix(col, vec3(0.0), clamp(descBorder, 0.0, 1.0) * 0.88);
        col = mix(col, AOS_INK_BLACK * 0.65, clamp(descInk, 0.0, 1.0) * (hov ? 0.75 : 0.50));
    }
    return clamp(col, 0.0, 1.0);
}

vec3 aosSearchFlyout(vec2 pix, vec2 img, float taskH, ThemePal th) {
    if ((field.data_bus[42] & (1u << 26u)) == 0u) return vec3(-1.0);

    uint count = ramByte(AOS_FILE_SEARCH_RAM);
    if (count == 0u || count > AOS_SEARCH_MAX) return vec3(-1.0);

    float scale = aosUiScale(img);
    float pad = 6.0 * scale;
    float rootW = 196.0 * scale;
    float gap = 4.0 * scale;
    float panelW = 300.0 * scale;
    float rowH = 28.0 * scale;
    float panelH = pad * 2.0 + rowH * float(count);
    float panelX = pad + rootW + pad + gap;
    float panelTop = img.y - taskH - panelH;

    if (pix.x < panelX || pix.x >= panelX + panelW || pix.y < panelTop || pix.y >= panelTop + panelH)
        return vec3(-1.0);

    vec2 rel = pix - vec2(panelX, panelTop);
    float t = field.sealed_time;
    vec3 col = aosMenuPanelBg(rel, vec2(panelW, panelH), scale, th, t);
    vec2 cell = aosHudTextCellSm(scale);
    uint hoverRow = ramByte(AOS_FILE_SEARCH_RAM + 2u);
    float rowY0 = panelTop + pad;

    for (uint i = 0u; i < count; ++i) {
        uint rowBase = AOS_FILE_SEARCH_RAM + 0x40u + i * AOS_SEARCH_ROW_STRIDE;
        if (ramByte(rowBase) == 0xFFu) continue;
        float ry0 = rowY0 + float(i) * rowH;
        if (pix.y < ry0 || pix.y >= ry0 + rowH) continue;

        bool hov = hoverRow < count && hoverRow == i;
        if (hov)
            col = mix(col, vec3(0.20, 0.20, 0.26), 0.88);

        uint icon = ramByte(rowBase);
        float iconSz = 18.0 * scale;
        vec2 icon0 = vec2(panelX + 8.0 * scale, ry0 + (rowH - iconSz) * 0.5);
        vec2 iuv = (pix - icon0) / iconSz;
        if (icon > 0u && all(greaterThanEqual(iuv, vec2(0.0))) && all(lessThan(iuv, vec2(1.0))))
            col = aosBlendIcon(col, sampleAosIconRgba(icon, iuv));

        float tx = icon0.x + iconSz + 5.0 * scale;
        float nameY = ry0 + rowH * 0.5 - 8.0 * scale;
        float nameInk = dosHudRamStr(pix, tx, nameY, cell, rowBase + 8u, AOS_SEARCH_NAME_LEN);
        float nameBorder = dosHudRamStrBorder(pix, tx, nameY, cell, rowBase + 8u, AOS_SEARCH_NAME_LEN);
        col = mixHudInk(col, nameInk, nameBorder, AOS_INK_BLACK);

        float pathY = nameY + 10.0 * scale;
        float pathInk = dosHudRamStr(pix, tx, pathY, cell,
            rowBase + 8u + AOS_SEARCH_NAME_LEN, AOS_SEARCH_PATH_LEN);
        float pathBorder = dosHudRamStrBorder(pix, tx, pathY, cell,
            rowBase + 8u + AOS_SEARCH_NAME_LEN, AOS_SEARCH_PATH_LEN);
        col = mixHudInk(col, pathInk, pathBorder, AOS_INK_BLACK * 0.55);
        return clamp(col, 0.0, 1.0);
    }
    return clamp(col, 0.0, 1.0);
}

vec3 aosDnDGhost(vec2 pix, vec2 img, float taskH, ThemePal th) {
    if (ramByte(AOS_DND_RAM) != 1u) return vec3(-1.0);
    uint icon = ramByte(AOS_DND_RAM + 1u);
    if (icon == 0u) return vec3(-1.0);

    float scale = aosUiScale(img);
    float ghostSz = 40.0 * scale;
    uint mxBits = uint(ramByte(AOS_DND_RAM + 68u))
        | (uint(ramByte(AOS_DND_RAM + 69u)) << 8u)
        | (uint(ramByte(AOS_DND_RAM + 70u)) << 16u)
        | (uint(ramByte(AOS_DND_RAM + 71u)) << 24u);
    uint myBits = uint(ramByte(AOS_DND_RAM + 72u))
        | (uint(ramByte(AOS_DND_RAM + 73u)) << 8u)
        | (uint(ramByte(AOS_DND_RAM + 74u)) << 16u)
        | (uint(ramByte(AOS_DND_RAM + 75u)) << 24u);
    vec2 ghost0 = vec2(float(mxBits), float(myBits)) - vec2(ghostSz * 0.5);
    vec2 iuv = (pix - ghost0) / ghostSz;
    if (any(lessThan(iuv, vec2(0.0))) || any(greaterThanEqual(iuv, vec2(1.0))))
        return vec3(-1.0);
    vec3 col = mix(th.panel * 0.35, th.accent * 0.25, 0.4);
    col = aosBlendIcon(col, sampleAosIconRgba(icon, iuv));
    return clamp(col, 0.0, 1.0) * 0.82;
}

vec3 aosStartMenu(vec2 pix, vec2 img, float taskH, ThemePal th) {
    float scale = aosUiScale(img);
    float pad = 6.0 * scale;
    float rootW = 196.0 * scale;
    float flyW = 420.0 * scale;
    float gap = 4.0 * scale;
    float rowH = 50.0 * scale;
    float headH = 28.0 * scale;
    float searchW = 300.0 * scale;
    float searchRowH = 28.0 * scale;

    uint rootRows = (field.data_bus[54] >> 16u) & 0xFFu;
    if (rootRows == 0u) rootRows = max(ramByte(AOS_MENU_RAM), 1u);
    uint flyCat = ramByte(AOS_MENU_RAM + 2u);
    uint flyRows = ramByte(AOS_MENU_RAM + 4u);
    bool searchActive = ramByte(AOS_FILE_SEARCH_RAM + 3u) != 0u;
    uint searchCount = ramByte(AOS_FILE_SEARCH_RAM);
    bool flyOpen = flyCat < 4u && flyRows > 0u && !searchActive;

    vec2 vp = aosViewport(img);
    AosTbLayout tbL = aosTbLayout(vp);
    vec2 startB0, startB1;
    aosTbStartBounds(tbL, startB0, startB1);

    float rootH = headH + rowH * float(rootRows) + pad * 2.0;
    float flyH = rowH * float(flyRows) + pad * 2.0;
    float searchH = searchActive ? pad * 2.0 + searchRowH * float(searchCount) : 0.0;
    float rootTop = startB0.y - rootH;
    float flyTop = startB0.y - flyH;
    float searchTop = startB0.y - searchH;
    float rootLeft = startB0.x;
    float clipTop = rootTop;
    if (flyOpen) clipTop = min(clipTop, flyTop);
    if (searchActive) clipTop = min(clipTop, searchTop);
    float totalW = rootLeft + rootW + (flyOpen ? gap + flyW : 0.0)
        + (searchActive ? gap + searchW : 0.0);

    if (pix.x < rootLeft || pix.x > totalW || pix.y < clipTop || pix.y >= tbL.barY1)
        return vec3(-1.0);

    float t = field.sealed_time;
    vec3 col = vec3(-1.0);

    vec2 rootOrigin = vec2(rootLeft, rootTop);
    vec2 rootRel = pix - rootOrigin;
    if (rootRel.x >= 0.0 && rootRel.x < rootW && rootRel.y >= 0.0 && rootRel.y < rootH) {
        col = aosMenuPanelBg(rootRel, vec2(rootW, rootH), scale, th, t);
        vec2 cell = vec2(8.0 * scale, 12.0 * scale);
        float hx = rootOrigin.x + 12.0 * scale;
        float hy = rootTop + 8.0 * scale;
        uint qLen = ramByte(AOS_FILE_SEARCH_RAM + 1u);
        if (qLen > 0u) {
            float qink = dosHudRamStr(pix, hx, hy, cell, AOS_FILE_SEARCH_RAM + 4u, AOS_SEARCH_QUERY_LEN);
            float qborder = dosHudRamStrBorder(pix, hx, hy, cell, AOS_FILE_SEARCH_RAM + 4u, AOS_SEARCH_QUERY_LEN);
            col = mixHudInk(col, qink, qborder, AOS_INK_BLACK);
        } else {
            float hink = dosHudRun(pix, hx, hy, cell, 83u, 101u, 97u, 114u, 99u, 104u, 46u, 46u);
            float hborder = dosHudRunBorder(pix, hx, hy, cell, 83u, 101u, 97u, 114u, 99u, 104u, 46u, 46u);
            col = mixHudInk(col, hink, hborder, AOS_INK_BLACK * 0.72);
        }

        if (rootRel.y >= headH) {
            uint row = uint(clamp(floor((rootRel.y - headH) / rowH), 0.0, float(rootRows) - 1.0));
            uint hoverRow = field.data_bus[54] & 0xFFu;
            uint rowBase = AOS_MENU_RAM + 0x10u + row * AOS_MENU_ROW_STRIDE;
            float rowY0 = rootTop + headH + float(row) * rowH;
            col = aosMenuDrawRow(pix, col, rootOrigin, rootW, rowY0, rowH, scale,
                rowBase, hoverRow, row, rootRows, th, true, false);
        }
    }

    if (flyOpen) {
        vec2 flyOrigin = vec2(rootLeft + rootW + gap, flyTop);
        vec2 flyRel = pix - flyOrigin;
        if (flyRel.x >= 0.0 && flyRel.x < flyW && flyRel.y >= 0.0 && flyRel.y < flyH) {
            col = aosMenuPanelBg(flyRel, vec2(flyW, flyH), scale, th, t);

            uint row = uint(clamp(floor((flyRel.y - pad) / rowH), 0.0, float(flyRows) - 1.0));
            uint flyHover = ramByte(AOS_MENU_RAM + 3u);
            uint rowBase = AOS_MENU_RAM + AOS_MENU_FLYOUT_OFF + row * AOS_MENU_ROW_STRIDE;
            float rowY0 = flyTop + pad + float(row) * rowH;
            col = aosMenuDrawRow(pix, col, flyOrigin, flyW, rowY0, rowH, scale,
                rowBase, flyHover, row, flyRows, th, false, true);
        }
    }

    return col.x < 0.0 ? vec3(-1.0) : clamp(col, 0.0, 1.0);
}

vec3 aosFolderView(vec2 pix, vec2 img, float taskH, ThemePal th) {
    if ((field.data_bus[42] & (1u << 30u)) == 0u) return vec3(-1.0);
    float scale = aosDeskScale(img);
    float panelW = 640.0 * scale;
    float panelH = 480.0 * scale;
    float panelX = img.x * 0.5 - panelW * 0.5;
    float panelTop = img.y * 0.38 - panelH * 0.5;
    if (pix.x < panelX || pix.x >= panelX + panelW || pix.y < panelTop || pix.y >= panelTop + panelH)
        return vec3(-1.0);
    vec2 rel = pix - vec2(panelX, panelTop);
    vec3 col = aosMenuPanelBg(rel, vec2(panelW, panelH), scale, th, field.sealed_time);
    uint itemCount = ramByte(AOS_FOLDER_VIEW_RAM);
    uint cols = max(ramByte(AOS_FOLDER_VIEW_RAM + 2u), 1u);
    float pad = 16.0 * scale;
    float headH = 36.0 * scale;
    float cellW = 96.0 * scale;
    float cellH = 108.0 * scale;
    float hx = panelX + 14.0 * scale;
    float hy = panelTop + 9.0 * scale;
    float hink = dosHudRamStr(pix, hx, hy, aosHudTextCellSm(scale), AOS_FOLDER_VIEW_RAM + 4u, 20u);
    float hborder = dosHudRamStrBorder(pix, hx, hy, aosHudTextCellSm(scale), AOS_FOLDER_VIEW_RAM + 4u, 20u);
    col = mixHudInk(col, hink, hborder, AOS_INK_BLACK);
    uint hoverIdx = ramByte(AOS_FOLDER_VIEW_RAM + 1u);
    float gridY0 = panelTop + headH + pad;
    for (uint i = 0u; i < itemCount; ++i) {
        uint c = i % cols;
        uint r = i / cols;
        float cx0 = panelX + pad + float(c) * cellW;
        float cy0 = gridY0 + float(r) * cellH;
        if (pix.x < cx0 || pix.x >= cx0 + cellW || pix.y < cy0 || pix.y >= cy0 + cellH)
            continue;
        uint rowBase = AOS_FOLDER_VIEW_RAM + 0x40u + i * AOS_FOLDER_ROW_STRIDE;
        uint icon = ramByte(rowBase);
        bool hov = hoverIdx < itemCount && hoverIdx == i;
        vec3 tile = hov ? mix(vec3(0.20, 0.20, 0.22), th.accent * 0.42, 0.55) : vec3(0.0);
        col = mix(col, tile, hov ? 0.92 : 0.0);
        float iconSz = 52.0 * scale;
        vec2 icon0 = vec2(cx0 + (cellW - iconSz) * 0.5, cy0 + 6.0 * scale);
        vec2 iuv = (pix - icon0) / iconSz;
        if (all(greaterThanEqual(iuv, vec2(0.0))) && all(lessThan(iuv, vec2(1.0))))
            col = aosBlendIcon(col, sampleAosIconRgba(icon, iuv));
        float labelY = cy0 + iconSz + 10.0 * scale;
        float tx = cx0 + cellW * 0.5 - 20.0 * scale;
        vec2 lcell = aosHudTextCellSm(scale);
        float ink = dosHudRamStr(pix, tx, labelY, lcell, rowBase + 4u, AOS_FOLDER_NAME_LEN);
        float inkB = dosHudRamStrBorder(pix, tx, labelY, lcell, rowBase + 4u, AOS_FOLDER_NAME_LEN);
        col = mixHudInk(col, ink, inkB, AOS_INK_BLACK);
        return clamp(col, 0.0, 1.0);
    }
    return clamp(col, 0.0, 1.0);
}

vec3 aosFilesMenu(vec2 pix, vec2 img, float taskH, ThemePal th) {
    if ((field.data_bus[42] & (1u << 23u)) == 0u) return vec3(-1.0);

    float scale = aosUiScale(img);
    float pad = 10.0 * scale;
    float headH = 30.0 * scale;
    float cellW = 88.0 * scale;
    float cellH = 96.0 * scale;
    uint itemCount = ramByte(AOS_FILES_MENU_RAM);
    if (itemCount == 0u) itemCount = 12u;
    uint cols = max(ramByte(AOS_FILES_MENU_RAM + 2u), 1u);
    uint rows = (itemCount + cols - 1u) / cols;
    float panelW = pad * 2.0 + cellW * float(cols);
    float panelH = headH + pad * 2.0 + cellH * float(rows);

    vec2 b0, b1;
    vec2 vp = aosViewport(img);
    aosQuickLaunchBounds(vp, 0, b0, b1);
    float panelX = b0.x;
    float panelTop = b0.y - panelH - 6.0 * scale;
    if (pix.x < panelX || pix.x >= panelX + panelW || pix.y < panelTop || pix.y >= panelTop + panelH)
        return vec3(-1.0);

    vec2 rel = pix - vec2(panelX, panelTop);
    float t = field.sealed_time;
    vec3 col = aosMenuPanelBg(rel, vec2(panelW, panelH), scale, th, t);

    vec2 cell = aosHudTextCell(scale);
    float hx = panelX + 14.0 * scale;
    float hy = panelTop + 9.0 * scale;
    float hink = dosHudRun(pix, hx, hy, cell, 70u, 105u, 108u, 101u, 115u, 32u, 32u, 32u);
    float hborder = dosHudRunBorder(pix, hx, hy, cell, 70u, 105u, 108u, 101u, 114u, 32u, 32u, 32u);
    col = mixHudInk(col, hink, hborder, AOS_INK_BLACK);

    uint hoverIdx = ramByte(AOS_FILES_MENU_RAM + 1u);
    float gridY0 = panelTop + headH + pad;
    for (uint i = 0u; i < itemCount; ++i) {
        uint c = i % cols;
        uint r = i / cols;
        float cx0 = panelX + pad + float(c) * cellW;
        float cy0 = gridY0 + float(r) * cellH;
        if (pix.x < cx0 || pix.x >= cx0 + cellW || pix.y < cy0 || pix.y >= cy0 + cellH)
            continue;

        uint rowBase = AOS_FILES_MENU_RAM + 0x10u + i * AOS_FILES_ROW_STRIDE;
        uint icon = ramByte(rowBase);
        bool hov = hoverIdx < itemCount && hoverIdx == i;
        vec3 tile = hov ? mix(vec3(0.20, 0.20, 0.22), th.accent * 0.42, 0.55) : vec3(0.0);
        col = mix(col, tile, hov ? 0.92 : 0.0);

        float iconSz = 52.0 * scale;
        vec2 icon0 = vec2(cx0 + (cellW - iconSz) * 0.5, cy0 + 6.0 * scale);
        vec2 iuv = (pix - icon0) / iconSz;
        if (all(greaterThanEqual(iuv, vec2(0.0))) && all(lessThan(iuv, vec2(1.0))))
            col = aosBlendIcon(col, sampleAosIconRgba(icon, iuv));

        float labelY = cy0 + iconSz + 10.0 * scale;
        float tx = cx0 + cellW * 0.5 - 20.0 * scale;
        vec2 lcell = aosHudTextCellSm(scale);
        float ink = dosHudRamStr(pix, tx, labelY, lcell, rowBase + 3u, AOS_FILES_LABEL_LEN);
        float inkB = dosHudRamStrBorder(pix, tx, labelY, lcell, rowBase + 3u, AOS_FILES_LABEL_LEN);
        col = mixHudInk(col, ink, inkB, AOS_INK_BLACK);
        return clamp(col, 0.0, 1.0);
    }
    return clamp(col, 0.0, 1.0);
}

vec3 aosDesktopIcons(vec2 pix, vec2 img, float taskH, ThemePal th) {
    float scale = aosDeskScale(img);
    const uint DESK_ICONS[9] = uint[9](4u, 5u, 6u, 14u, 8u, 11u, 15u, 16u, 12u);
    const uint ICON_COUNT = 9u;
    float cellW = 108.0 * scale;
    float cellH = 118.0 * scale;
    float iconSz = 72.0 * scale;
    float padX = 28.0 * scale;
    float padY = 36.0 * scale;
    float topBar = 28.0 * scale;
    uint iconHover = ramByte(AOS_DESKTOP_RAM + 1u);

    for (uint i = 0u; i < ICON_COUNT; ++i) {
        float ix = padX;
        float iy = topBar + padY + float(i) * cellH;
        if (pix.x < ix || pix.y < iy || pix.x >= ix + cellW || pix.y >= iy + cellH)
            continue;
        vec3 col = vec3(0.0);
        bool hov = iconHover < ICON_COUNT && iconHover == i;
        if (hov)
            col = mix(vec3(0.16, 0.16, 0.18), th.accent * 0.45, 0.55);
        vec2 icon0 = vec2(ix + (cellW - iconSz) * 0.5, iy + 8.0 * scale);
        vec2 iuv = (pix - icon0) / iconSz;
        if (all(greaterThanEqual(iuv, vec2(0.0))) && all(lessThan(iuv, vec2(1.0))))
            col = aosBlendIcon(col, sampleAosIconRgba(DESK_ICONS[i], iuv));
        float labelY = iy + iconSz + 14.0 * scale;
        vec2 cell = vec2(6.5 * scale, 11.0 * scale);
        float tx = ix + cellW * 0.5 - 28.0 * scale;
        float ink = 0.0;
        if (i == 0u) ink = dosHudRun(pix, tx, labelY, cell, 82u, 84u, 88u, 32u, 83u, 104u, 108u, 108u);
        if (i == 1u) ink = max(ink, dosHudRun(pix, tx, labelY, cell, 65u, 109u, 109u, 111u, 67u, 111u, 100u, 101u));
        if (i == 2u) ink = max(ink, dosHudRun(pix, tx, labelY, cell, 70u, 105u, 108u, 101u, 115u, 32u, 32u, 32u));
        if (i == 3u) ink = max(ink, dosHudRun(pix, tx, labelY, cell, 68u, 79u, 79u, 77u, 32u, 32u, 32u, 32u));
        if (i == 4u) ink = max(ink, dosHudRun(pix, tx, labelY, cell, 81u, 66u, 65u, 83u, 73u, 67u, 32u, 32u));
        if (i == 5u) ink = max(ink, dosHudRun(pix, tx, labelY, cell, 78u, 69u, 83u, 32u, 32u, 32u, 32u, 32u));
        if (i == 6u) ink = max(ink, dosHudRun(pix, tx, labelY, cell, 87u, 97u, 108u, 108u, 32u, 32u, 32u, 32u));
        if (i == 7u) ink = max(ink, dosHudRun(pix, tx, labelY, cell, 68u, 101u, 115u, 107u, 116u, 111u, 112u, 32u));
        if (i == 8u) ink = max(ink, dosHudRun(pix, tx, labelY, cell, 83u, 101u, 116u, 116u, 105u, 110u, 103u, 115u));
        col = mix(col, AOS_INK_BLACK, clamp(ink, 0.0, 1.0) * 0.95);
        col += vec3(0.02) * (hov ? 0.06 : 0.02);
        return clamp(col, 0.0, 1.0);
    }
    return vec3(-1.0);
}

vec3 aosDesktopManagerPanel(vec2 pix, vec2 img, float taskH, ThemePal th) {
    uint bits = field.data_bus[42];
    if ((bits & ((1u << 26u) | (1u << 27u))) == 0u) return vec3(-1.0);

    float scale = aosDeskScale(img);
    float panelW = 520.0 * scale;
    float panelH = 440.0 * scale;
    float px = img.x - panelW - 48.0 * scale;
    float py = (img.y - taskH - panelH) * 0.42;
    vec2 p0 = vec2(px, py);
    vec2 p1 = p0 + vec2(panelW, panelH);
    if (any(lessThan(pix, p0)) || any(greaterThanEqual(pix, p1)))
        return vec3(-1.0);

    vec2 rel = pix - p0;
    vec3 bg = vec3(0.06, 0.05, 0.10);
    float edge = min(min(rel.x, panelW - rel.x), min(rel.y, panelH - rel.y));
    float frame = smoothstep(5.0 * scale, 0.0, edge);
    vec3 col = mix(bg, th.accent * 0.22 + th.title * 0.15, frame * 0.75);
    col += th.gemTint * 0.04 * sin(rel.x * 0.04 + field.sealed_time * 0.6);

    uint tabHover = (field.data_bus[54] >> 24u) & 0xFFu;
    uint activeTab = ((bits & (1u << 28u)) != 0u) ? 1u : (((bits & (1u << 26u)) != 0u) ? 0u : 2u);
    float tabY = 12.0 * scale;
    float tabH = 32.0 * scale;
    float tabW = 108.0 * scale;
    for (uint t = 0u; t < 3u; ++t) {
        float tx = 16.0 * scale + float(t) * (tabW + 8.0 * scale);
        if (pix.x >= px + tx && pix.x < px + tx + tabW && pix.y >= py + tabY && pix.y < py + tabY + tabH) {
            bool hov = tabHover < 3u && tabHover == t;
            bool act = activeTab == t;
            col = mix(col, th.accent * (act ? 0.55 : 0.28) + vec3(0.14, 0.14, 0.16), act || hov ? 0.82 : 0.35);
        }
    }

    vec2 cell = aosHudTextCell(scale);
    float hx = px + 20.0 * scale;
    float hy = py + tabY + tabH + 14.0 * scale;
    float hink = dosHudRun(pix, hx, hy, cell, 68u, 101u, 115u, 107u, 116u, 111u, 112u, 32u);
    col = mix(col, AOS_INK_BLACK, clamp(hink, 0.0, 1.0) * 0.9);

    if (activeTab == 0u) {
        uint thumbHover = (field.data_bus[54] >> 16u) & 0xFFu;
        float pad = 24.0 * scale;
        float thumbSz = 88.0 * scale;
        float gap = 14.0 * scale;
        float gridY = py + tabY + tabH + pad + 36.0 * scale;
        for (uint wi = 0u; wi < 8u; ++wi) {
            uint colIdx = wi % 4u;
            uint rowIdx = wi / 4u;
            float tx = px + pad + float(colIdx) * (thumbSz + gap);
            float ty = gridY + float(rowIdx) * (thumbSz + gap);
            if (pix.x < tx || pix.y < ty || pix.x >= tx + thumbSz || pix.y >= ty + thumbSz)
                continue;
            uint curWp = (bits >> 16u) & 0xFu;
            bool sel = curWp == wi;
            bool hov = thumbHover < 8u && thumbHover == wi;
            vec3 thumb = mix(vec3(0.14, 0.14, 0.16), th.accent * 0.35, 0.4);
            vec2 tuv = (pix - vec2(tx, ty)) / thumbSz;
            vec3 wallPx = sampleAosWall(tuv);
            if (wallPx.x >= 0.0) thumb = mix(thumb, wallPx, 0.88);
            if (sel) thumb = mix(thumb, th.gemTint, 0.25);
            if (hov) thumb = mix(thumb, th.accent * 0.5, 0.35);
            float tedge = smoothstep(0.0, 4.0 * scale, min(min(tuv.x, 1.0 - tuv.x), min(tuv.y, 1.0 - tuv.y)));
            return clamp(mix(col, thumb, tedge * 0.95), 0.0, 1.0);
        }
    }

    if (activeTab == 1u) {
        float sliderX = px + 24.0 * scale;
        float sliderY = py + 120.0 * scale;
        float sliderW = panelW - 48.0 * scale;
        float sliderH = 22.0 * scale;
        float ink = dosHudRun(pix, sliderX, sliderY - 28.0 * scale, cell, 85u, 73u, 32u, 83u, 99u, 97u, 108u, 101u);
        col = mix(col, th.label, clamp(ink, 0.0, 1.0));
        if (pix.y >= sliderY && pix.y < sliderY + sliderH && pix.x >= sliderX && pix.x < sliderX + sliderW) {
            float t = clamp((pix.x - sliderX) / sliderW, 0.0, 1.0);
            col = mix(col, th.accent * 0.4 + vec3(0.16, 0.16, 0.18), 0.75);
            if (abs(pix.y - (sliderY + sliderH * 0.5)) < 4.0 * scale && abs(pix.x - (sliderX + t * sliderW)) < 8.0 * scale)
                col = mix(col, th.gemTint, 0.65);
        }
        uint scaleQ = max(field.data_bus[31], 220u);
        float valInk = dosHudUintInk(pix, sliderX, sliderY + 32.0 * scale, cell, (scaleQ * 100u + 128u) / 256u / 100u, 1u);
        col = mix(col, th.value, clamp(valInk, 0.0, 1.0));
    }

    if (activeTab == 2u) {
        float ink = dosHudRun(pix, hx, hy + 36.0 * scale, cell, 65u, 109u, 111u, 117u, 114u, 97u, 110u, 116u);
        ink = max(ink, dosHudRun(pix, hx, hy + 58.0 * scale, cell, 68u, 101u, 118u, 75u, 105u, 116u, 32u, 51u));
        ink = max(ink, dosHudRun(pix, hx, hy + 80.0 * scale, cell, 82u, 84u, 88u, 32u, 50u, 50u, 50u, 32u));
        col = mix(col, AOS_INK_BLACK, clamp(ink, 0.0, 1.0));
    }

    float closeSz = 28.0 * scale;
    float closeX = p1.x - closeSz - 12.0 * scale;
    float closeY = p0.y + 10.0 * scale;
    if (pix.x >= closeX && pix.x < closeX + closeSz && pix.y >= closeY && pix.y < closeY + closeSz) {
        vec2 cuv = (pix - vec2(closeX, closeY)) / closeSz;
        col = aosBlendIcon(col, sampleAosIconRgba(1u, cuv));
    }

    return clamp(col, 0.0, 1.0);
}

const uint AOS_IDENTITY_RAM = 0x000BB800u;
const uint AOS_IDENTITY_STRIDE = 160u;
const uint AOS_IDENTITY_TAG_LEN = 44u;
const uint AOS_IDENTITY_RECENT1_OFF = 94u;
const uint AOS_IDENTITY_RECENT2_OFF = 126u;
const uint AOS_IDENTITY_SNAP_OFF = 158u;

vec3 rtxWmTitleBarForTab(vec2 winLocal, vec2 winSize, float titleH, uint tabIdx, ThemePal th) {
    float t = field.sealed_time;
    float uiSc = max(winSize.x / 1920.0, 0.75) * 1.35;
    vec2 muv = vec2(winLocal.x / max(winSize.x, 1.0), winLocal.y / max(titleH, 1.0));
    vec3 base = aosSdTitleBarWin31(winLocal, winSize, titleH, true);
    if (base.x < 0.0) base = mix(vec3(0.20, 0.20, 0.22), vec3(0.28, 0.28, 0.30), muv.y);
    vec2 cell = vec2(8.0, 14.0) * uiSc;
    float rowY = titleH * 0.5 - 7.0 * uiSc;
    float ink = 0.0;
    float inkB = 0.0;
    float titleX = 48.0 * uiSc;
    uint titleBase = AOS_TASKBAR_RAM + 0x10u + tabIdx * AOS_TAB_STRIDE;
    ink = max(ink, dosHudRamStr(winLocal, titleX, rowY, cell, titleBase, 22u));
    inkB = max(inkB, dosHudRamStrBorder(winLocal, titleX, rowY, cell, titleBase, 22u));
    float iconSz = titleH * 0.58;
    float iconX = 10.0 * uiSc;
    float iconY = (titleH - iconSz) * 0.5;
    if (winLocal.x >= iconX && winLocal.x < iconX + iconSz
            && winLocal.y >= iconY && winLocal.y < iconY + iconSz) {
        vec2 il = (winLocal - vec2(iconX, iconY)) / iconSz;
        uint iconSlot = uint(ramByte(titleBase + AOS_TAB_STRIDE - 1u));
        base = mix(base, aosBlendIcon(base, sampleAosIconRgba(iconSlot, il)), 0.88);
    }
    vec3 c = rtxWmTitleAsciiControls(winLocal, winSize, titleH, 0u, th);
    if (c.x > -1.5) return c;
    return mixHudInk(base, ink, inkB, AOS_INK_BLACK);
}

vec3 aosBackgroundWindowBody(vec2 winLocal, vec2 winSize, float titleH, float hudH,
        uint tabIdx, ThemePal th) {
    if (winLocal.y < titleH || winLocal.y >= winSize.y - hudH) return vec3(-1.0);
    if (rtxWidgetsActive()) {
        vec3 widgets = rtxWidgetPanelColor(winLocal, winSize, titleH, hudH, th);
        if (widgets.x >= 0.0) return widgets;
    }
    vec3 col = rtxPanelBg(th);
    float uiSc = max(winSize.x / 1920.0, 0.75) * 1.35;
    vec2 cell = aosHudTextCell(uiSc);
    uint idBase = AOS_IDENTITY_RAM + tabIdx * AOS_IDENTITY_STRIDE;
    float tagY = titleH + 28.0 * uiSc;
    float ink = 0.0;
    float inkB = 0.0;
    ink = max(ink, dosHudRamStr(winLocal, 24.0 * uiSc, tagY, cell, idBase, AOS_IDENTITY_TAG_LEN));
    inkB = max(inkB, dosHudRamStrBorder(winLocal, 24.0 * uiSc, tagY, cell, idBase, AOS_IDENTITY_TAG_LEN));
    float aboutY = tagY + 36.0 * uiSc;
    uint aboutBase = idBase + AOS_IDENTITY_TAG_LEN;
    ink = max(ink, dosHudRamStr(winLocal, 24.0 * uiSc, aboutY, cell, aboutBase, 48u));
    inkB = max(inkB, dosHudRamStrBorder(winLocal, 24.0 * uiSc, aboutY, cell, aboutBase, 48u));
    float recentY = aboutY + 44.0 * uiSc;
    uint recentBase = idBase + AOS_IDENTITY_RECENT1_OFF;
    ink = max(ink, dosHudRamStr(winLocal, 24.0 * uiSc, recentY, cell, recentBase, 32u));
    inkB = max(inkB, dosHudRamStrBorder(winLocal, 24.0 * uiSc, recentY, cell, recentBase, 32u));
    float recent2Y = recentY + 28.0 * uiSc;
    uint recent2Base = idBase + AOS_IDENTITY_RECENT2_OFF;
    ink = max(ink, dosHudRamStr(winLocal, 24.0 * uiSc, recent2Y, cell, recent2Base, 32u));
    inkB = max(inkB, dosHudRamStrBorder(winLocal, 24.0 * uiSc, recent2Y, cell, recent2Base, 32u));
    float snapY = recent2Y + 28.0 * uiSc;
    uint snapBase = idBase + AOS_IDENTITY_SNAP_OFF;
    ink = max(ink, dosHudRamStr(winLocal, 24.0 * uiSc, snapY, cell, snapBase, 24u));
    inkB = max(inkB, dosHudRamStrBorder(winLocal, 24.0 * uiSc, snapY, cell, snapBase, 24u));
    float hintY = winSize.y - hudH - 40.0 * uiSc;
    ink = max(ink, dosHudRun(winLocal, 24.0 * uiSc, hintY, cell,
        67u, 108u, 105u, 99u, 107u, 32u, 116u, 97u));
    inkB = max(inkB, dosHudRunBorder(winLocal, 24.0 * uiSc, hintY, cell,
        67u, 108u, 105u, 99u, 107u, 32u, 116u, 97u));
    ink = max(ink, dosHudRun(winLocal, 24.0 * uiSc + cell.x * 5.5, hintY, cell,
        98u, 97u, 114u, 32u, 116u, 111u, 32u, 102u));
    inkB = max(inkB, dosHudRunBorder(winLocal, 24.0 * uiSc + cell.x * 5.5, hintY, cell,
        98u, 97u, 114u, 32u, 116u, 111u, 32u, 102u));
    float iconSz = min(winSize.x, winSize.y - titleH - hudH) * 0.22;
    float iconX = winSize.x * 0.5 - iconSz * 0.5;
    float iconY = titleH + (winSize.y - titleH - hudH) * 0.42;
    if (winLocal.x >= iconX && winLocal.x < iconX + iconSz
            && winLocal.y >= iconY && winLocal.y < iconY + iconSz) {
        vec2 il = (winLocal - vec2(iconX, iconY)) / iconSz;
        uint titleBase = AOS_TASKBAR_RAM + 0x10u + tabIdx * AOS_TAB_STRIDE;
        uint iconSlot = uint(ramByte(titleBase + AOS_TAB_STRIDE - 1u));
        col = mix(col, aosBlendIcon(col, sampleAosIconRgba(iconSlot, il)), 0.92);
    }
    col = mixHudInk(col, ink, inkB, vec3(0.08, 0.08, 0.10));
    return max(col, vec3(0.0));
}

vec3 aosBackgroundWindowAt(vec2 pix, vec2 img, float taskH, uint tabIdx,
        vec2 p0, vec2 sz, ThemePal th) {
    if (pix.x < p0.x || pix.y < p0.y || pix.x >= p0.x + sz.x || pix.y >= p0.y + sz.y)
        return vec3(-1.0);
    vec2 winLocal = pix - p0;
    float titleH = rtxWmTitleH(img);
    float hudH = max(float(field.data_bus[58]), 1.0);
    float uiSc = max(sz.x / 1920.0, 0.75) * 1.35;
    vec3 shell = aosSdfComposeWindow(winLocal, sz, titleH, hudH, th, uiSc, false);
    if (winLocal.y < titleH)
        return rtxWmTitleBarForTab(winLocal, sz, titleH, tabIdx, th);
    if (winLocal.y >= sz.y - hudH) {
        vec3 status = aosSdStatusBarWin31(winLocal, sz, hudH);
        if (status.x >= 0.0) return status;
    }
    vec3 body = aosBackgroundWindowBody(winLocal, sz, titleH, hudH, tabIdx, th);
    if (body.x >= 0.0) return body;
    if (shell.x >= 0.0) return shell;
    return rtxPanelBg(th);
}

vec3 aosFocusedWindowLayer(vec2 pix, vec2 img, float taskH, ThemePal th) {
    if (!aosDesktopActive()) return vec3(-1.0);
    uint packW = field.data_bus[60];
    uint packH = field.data_bus[61];
    uint surfCount = packW >> 24u;
    if (surfCount == 0u) return vec3(-1.0);
    uint surfFlags = (packH >> 16u) & 0xFFu;
    if ((surfFlags & 1u) != 0u) return vec3(-1.0);
    int focusTab = int((packW >> 16u) & 0xFFu);
    if (focusTab < 0) focusTab = 0;
    float ox = float(field.data_bus[46]);
    float oy = float(field.data_bus[47]);
    float pw = float(packW & 0xFFFFu);
    float ph = float(packH & 0xFFFFu);
    if (pw < 8.0 || ph < 8.0) return vec3(-1.0);
    return aosBackgroundWindowAt(pix, img, taskH, uint(focusTab), vec2(ox, oy), vec2(pw, ph), th);
}

vec3 aosBackgroundWindows(vec2 pix, vec2 img, float taskH, ThemePal th) {
    if (!aosDesktopActive() || aosPanelHidden()) return vec3(-1.0);
    uint surfCount = uint(ramByte(AOS_SURFACE_RAM));
    if (surfCount <= 1u) return vec3(-1.0);
    int focusTab = int(ramByte(AOS_SURFACE_RAM + 1u));
    vec3 best = vec3(-1.0);
    for (uint i = 0u; i < surfCount && i < 8u; ++i) {
        if (int(i) == focusTab) continue;
        uint base = AOS_SURFACE_RAM + 0x10u + i * 16u;
        uint flags = ramByte(base + 11u);
        if ((flags & 1u) != 0u) continue;
        float ox = float(uint(ramByte(base)) | (uint(ramByte(base + 1u)) << 8u));
        float oy = float(uint(ramByte(base + 2u)) | (uint(ramByte(base + 3u)) << 8u));
        float pw = float(uint(ramByte(base + 4u)) | (uint(ramByte(base + 5u)) << 8u));
        float ph = float(uint(ramByte(base + 6u)) | (uint(ramByte(base + 7u)) << 8u));
        if (pw < 8.0 || ph < 8.0) continue;
        vec3 c = aosBackgroundWindowAt(pix, img, taskH, i, vec2(ox, oy), vec2(pw, ph), th);
        if (c.x >= 0.0) best = c;
    }
    return best;
}

// =============================================================================
// AMOURANTHOS DESKTOP TOGGLE (controlled from Options / data_bus[42] bit 12)
// =============================================================================
vec3 amouranthOsBackdrop(vec2 pix, vec2 img, ThemePal th) {
    if (!aosChromeActive())
        return vec3(-1.0);

    float taskH = aosTbTaskH(img);

    vec3 focusedWin = aosFocusedWindowLayer(pix, img, taskH, th);
    if (focusedWin.x >= 0.0) return focusedWin;

    vec3 bgWin = aosBackgroundWindows(pix, img, taskH, th);
    if (bgWin.x >= 0.0) return bgWin;

    if (aosInsidePanel(pix, img))
        return vec3(-1.0);

    return aosDarkDesktop(pix, img, taskH, th);
}

#include "aos_chrome_layers.inc"

// Layered top chrome: strip → flyouts → Start (topmost).
vec3 aosLayerChrome(vec3 base, vec2 pix, vec2 vp, ThemePal th) {
    AosTbLayout L = aosTbLayout(vp);
    float taskH = L.taskH;
    uint bits = field.data_bus[42];
    bool menuOpen = (bits & (1u << 20u)) != 0u;
    bool filesOpen = (bits & (1u << 23u)) != 0u;
    bool folderOpen = (bits & (1u << 30u)) != 0u;
    vec3 menu = menuOpen ? aosStartMenu(pix, vp, taskH, th) : vec3(-1.0);
    vec3 search = menuOpen ? aosSearchFlyout(pix, vp, taskH, th) : vec3(-1.0);
    vec3 files = filesOpen ? aosFilesMenu(pix, vp, taskH, th) : vec3(-1.0);
    vec3 folder = folderOpen ? aosFolderView(pix, vp, taskH, th) : vec3(-1.0);
    vec3 color = aosChromeComposite(base,
        aosTaskbarStrip(pix, vp, th),
        aosQuickLaunchStrip(pix, vp, th),
        menu,
        search,
        files,
        aosDnDGhost(pix, vp, taskH, th),
        folder,
        aosStartButtonPanel(pix, vp, th, menuOpen),
        aosExitConfirmModal(pix, vp, taskH, th));
    vec3 clk = aosTaskbarClock(pix, vp, th);
    if (clk.x >= 0.0) color = clk;
    return color;
}

vec3 finishHudColor(vec3 color, vec2 panelPos, vec2 img, vec2 puv, float t, ThemePal theme, uint hoverSec) {
    if (aosChromeActive()) {
        vec2 vp = aosViewport(img);
        float taskH = aosTbTaskH(vp);
        if (panelPos.y < vp.y - taskH)
            color = aosLayerChrome(color, panelPos, vp, theme);
        return displayMap(max(color, vec3(0.0)));
    }
    return displayMap(applyRtxFinish(puv, color, t, theme, hoverSec));
}

vec3 aosProductionDesktop(vec2 panelPos, vec2 vp, ThemePal theme, vec2 puv, float t, uint hoverSec) {
    vec3 aos = amouranthOsBackdrop(panelPos, vp, theme);
    if (aos.x >= 0.0)
        return finishHudColor(aos, panelPos, vp, puv, t, theme, hoverSec);
    return finishHudColor(vec3(0.02, 0.02, 0.03), panelPos, vp, puv, t, theme, hoverSec);
}

vec3 renderHudFrac(vec2 panelPos, ivec2 img, float t, ThemePal theme, uint hoverSec, uint hoverBlock) {
    HudLayout hud = mapHud16x9(ivec2(panelPos), img);
    if (!hud.inside) return theme.void_;
    vec2 vp = aosViewport(vec2(img));
    if (!aosPanelHidden()) {
        uint packW = field.data_bus[60];
        uint packH = field.data_bus[61];
        if ((packW >> 24u) > 0u) {
            float ox = float(field.data_bus[46]);
            float oy = float(field.data_bus[47]);
            float pw = float(packW & 0xFFFFu);
            float ph = float(packH & 0xFFFFu);
            if (pw > 8.0 && ph > 8.0
                    && panelPos.x >= ox && panelPos.y >= oy
                    && panelPos.x < ox + pw && panelPos.y < oy + ph) {
                vec3 guest = rtxDosViewportColor(panelPos, vec2(img), theme);
                vec3 shell = amouranthOsBackdrop(panelPos, vp, theme);
                vec3 col = shell.x >= 0.0 ? shell : vec3(0.72, 0.74, 0.78);
                col = aosComposeProgramWindow(col, guest, panelPos, vec2(img));
                return finishHudColor(col, panelPos, vec2(img), hud.puv, t, theme, hoverSec);
            }
        }
    }
    bool productionUi = aosChromeActive() || aosDesktopActive()
        || (field.control & CTRL_RTXDOS) != 0u;
    if (aosChromeActive()) {
        float taskH = aosTbTaskH(vp);
        if (panelPos.y >= vp.y - taskH) {
            vec3 desk = aosDarkDesktop(panelPos, vp, taskH, theme);
            vec3 chrome = aosLayerChrome(desk, panelPos, vp, theme);
            return displayMap(max(chrome, vec3(0.0)));
        }
    }
    if (productionUi) {
        if (aosChromeActive() && !aosPanelHidden()) {
            vec3 shell = amouranthOsBackdrop(panelPos, vp, theme);
            if (shell.x >= 0.0) {
                vec3 guest = rtxDosViewportColor(panelPos, vec2(img), theme);
                vec3 col = aosComposeProgramWindow(shell, guest, panelPos, vec2(img));
                return finishHudColor(col, panelPos, vec2(img), hud.puv, t, theme, hoverSec);
            }
        }
        vec3 dosCol = rtxDosViewportColor(panelPos, vec2(img), theme);
        if (dosCol.x >= 0.0)
            return finishHudColor(dosCol, panelPos, vec2(img), hud.puv, t, theme, hoverSec);
        return aosProductionDesktop(panelPos, vp, theme, hud.puv, t, hoverSec);
    }
    if ((field.control & CTRL_FIELD_DEBUG) == 0u)
        return finishHudColor(theme.void_, panelPos, vec2(img), hud.puv, t, theme, hoverSec);
    vec2 scale = computeHudScale(hud.panelSize);
    vec2 p = panelPos - vec2(hud.offset);
    vec2 lp = (p - vec2(MARGIN)) / scale;
    uint cell_x = uint(max(lp.x, 0.0)) / COL_PITCH;
    uint cell_y = uint(max(lp.y, 0.0)) / ROW_PITCH;
    vec2 sampleLp = lp;
    uint sample_x = cell_x;
    uint sample_y = cell_y;
    vec2 cellLp = vec2(float(cell_x * COL_PITCH), float(cell_y * ROW_PITCH));
    vec2 fracInCell = lp - cellLp;
    uint px = uint(fracInCell.x);
    uint py = uint(fracInCell.y);
    bool hasCell = lp.x >= 0.0 && lp.y >= 0.0 && cell_x < GRID_COLS && cell_y < GRID_ROWS;
    vec3 bg = theme.void_;
    if (hasCell) {
        bool isGfx = isGraphicZone(sample_y, sample_x, hoverSec);
        bg = opsFieldBg(sample_y, sample_x, isGfx, theme, hoverSec);
        if (isGfx) {
            vec3 gfx = graphicLayerFrac(sampleLp, sample_y, sample_x, t, theme, hoverSec);
            if (gfx != vec3(0.0)) bg = gfx;
        }

    }
    if (!hasCell || px >= FONT_W || py >= FONT_H)
        return finishHudColor(bg, panelPos, vec2(img), hud.puv, t, theme, hoverSec);
    uint ascii = getChar(cell_y, cell_x, hoverSec);
    float ink = fontOn(ascii, px, py) ? 1.0 : 0.0;
    vec3 color = bg;
    if (ink > 0.05) {
        vec3 fg = colorFor(cell_y, cell_x, ascii, ink, theme);
        color = mix(bg, flatInk(px, py, ascii, fg, theme), clamp(ink, 0.0, 1.0));
    }
    color = applyLabelHover(color, hoverBlock, cell_y, cell_x, theme);
    return finishHudColor(color, panelPos, vec2(img), hud.puv, t, theme, hoverSec);
}

void main() {
    if (gl_WorkGroupID.x == 0u && gl_WorkGroupID.y == 0u &&
        gl_LocalInvocationID.x == 0u && gl_LocalInvocationID.y == 0u) {
        init_die();
        if ((field.control & 2u) != 0u) field_trigger_1024(0u);
        if ((field.control & 4u) != 0u) die.irq_vector = field.data_bus[0] & 0xFFu;
        if ((field.control & CTRL_HOST_CPU) == 0u) {
            uint cycles = field.data_bus[1];
            if (aosChromeActive() && aosPanelHidden()) cycles = min(cycles, 64u);
            if (cycles == 0u) cycles = 1u;
            if (cycles > MAX_CYCLES_PER_FRAME) cycles = MAX_CYCLES_PER_FRAME;
            for (uint c = 0u; c < cycles; ++c) {
                if ((die.EFLAGS & EFLAGS_HALTED) != 0u) break;
                execute_cycle();
            }
        }
    }
    barrier(); memoryBarrierBuffer(); barrier();
    bool aosShell = aosChromeActive() && aosPanelHidden()
        && (field.control & CTRL_HOST_CPU) == 0u;
    if (!aosShell) {
        ivec2 fs = imageSize(fieldPhi);
        ivec2 fc = ivec2(gl_GlobalInvocationID.xy);
        if (fc.x < fs.x && fc.y < fs.y)
            evolveAnalogFields(fc, field.sealed_time);
        barrier(); memoryBarrierImage(); barrier();
    } else {
        barrier(); memoryBarrierImage(); barrier();
    }
    ivec2 gid = ivec2(gl_GlobalInvocationID.xy);
    ivec2 img = imageSize(resultImage);
    float t = field.sealed_time;
    ThemePal theme = loadTheme(themeIdFromControl());

    vec3 color = renderHudFrac(vec2(gid), img, t, theme, SEC_NONE, 0u);
    vec2 vp = aosViewport(vec2(img));
    float taskH = 52.0 * aosUiScale(vp);
    if (float(gid.y) >= vp.y - taskH) {
        vec3 desk = aosDarkDesktop(vec2(gid), vp, taskH, theme);
        vec3 chrome = aosLayerChrome(desk, vec2(gid), vp, theme);
        if (chrome.x >= 0.0)
            color = chrome;
    }
    imageStore(resultImage, gid, vec4(color, 1.0));
}