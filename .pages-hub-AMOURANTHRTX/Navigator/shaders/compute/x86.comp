// ── Amouranth 2026 — single master RTX palette (rose · cyan · void) ───────────
struct ThemePal {
    vec3 void_; vec3 panel; vec3 zebra; vec3 border; vec3 title;
    vec3 section; vec3 label; vec3 value; vec3 warn; vec3 mem; vec3 rule;
    vec3 copper; vec3 silicon; vec3 pcb; vec3 grin; vec3 accent; vec3 gemTint;
    float heatHue; float ior; float dispersion; float facetMul;
};

ThemePal loadTheme(uint id) {
    uint pack = field.data_bus[62];
    id = pack & 0xFFu;
    float rose = float((pack >> 8u) & 0xFFu) / 255.0;
    float cyan = float((pack >> 16u) & 0xFFu) / 255.0;
    ThemePal t;
    t.void_ = vec3(0.06, 0.07, 0.09);
    t.panel = vec3(0.18, 0.19, 0.22);
    t.zebra = vec3(0.14, 0.15, 0.18);
    t.border = vec3(0.42, 0.44, 0.48);
    t.title = vec3(0.88, 0.90, 0.94);
    t.section = vec3(0.55, 0.58, 0.62);
    t.label = vec3(0.72, 0.72, 0.76);
    t.value = vec3(0.85, 0.85, 0.88);
    t.warn = vec3(1.0, 0.60, 0.34);
    t.mem = vec3(0.0, 0.45, 0.82);
    t.rule = vec3(0.28, 0.28, 0.32);
    t.copper = vec3(0.85, 0.55, 0.15);
    t.silicon = vec3(0.12, 0.12, 0.14);
    t.pcb = vec3(0.06, 0.06, 0.08);
    t.grin = vec3(0.55, 0.58, 0.64);
    t.accent = vec3(rose * 0.55, cyan * 0.45, cyan);
    if (length(t.accent) < 0.08)
        t.accent = vec3(0.20, 0.45, 0.72);
    t.gemTint = mix(t.accent, vec3(0.35, 0.55, 0.75), 0.55);
    if (id == 1u) {
        t.accent = vec3(0.25, 0.50, 0.78);
        t.gemTint = vec3(0.30, 0.55, 0.72);
        t.panel = vec3(0.22, 0.23, 0.26);
        t.zebra = vec3(0.16, 0.17, 0.20);
        t.border = vec3(0.48, 0.50, 0.54);
        t.title = vec3(0.92, 0.94, 0.96);
        t.mem = vec3(0.30, 0.55, 0.82);
    }
    if (id == 4u) {
        t.void_ = vec3(0.04, 0.05, 0.08);
        t.panel = vec3(0.11, 0.12, 0.16);
        t.zebra = vec3(0.08, 0.09, 0.13);
        t.border = vec3(0.26, 0.28, 0.34);
        t.title = vec3(0.80, 0.82, 0.88);
        t.section = vec3(0.40, 0.42, 0.48);
        t.label = vec3(0.64, 0.66, 0.72);
        t.value = vec3(0.76, 0.78, 0.84);
        t.accent = vec3(0.34, 0.42, 0.56);
        t.gemTint = vec3(0.28, 0.36, 0.50);
        t.mem = vec3(0.24, 0.36, 0.52);
        t.silicon = vec3(0.09, 0.10, 0.13);
        t.pcb = vec3(0.05, 0.06, 0.09);
    }
    if (id == 8u) {
        t.void_ = vec3(0.05, 0.05, 0.06);
        t.panel = vec3(0.12, 0.12, 0.13);
        t.zebra = vec3(0.09, 0.09, 0.10);
        t.border = vec3(0.22, 0.22, 0.24);
        t.title = vec3(0.91, 0.91, 0.92);
        t.section = vec3(0.38, 0.38, 0.40);
        t.label = vec3(0.62, 0.62, 0.64);
        t.value = vec3(0.78, 0.78, 0.80);
        t.accent = vec3(0.54, 0.71, 0.97);
        t.gemTint = vec3(0.40, 0.55, 0.78);
        t.mem = vec3(0.35, 0.55, 0.90);
        t.silicon = vec3(0.10, 0.10, 0.11);
        t.pcb = vec3(0.06, 0.06, 0.07);
    }
    t.heatHue = 0.58;
    t.ior = 1.45;
    t.dispersion = 0.02;
    t.facetMul = 1.5;
    return t;
}

uint themeIdFromControl() { return field.data_bus[62] & 0xFFu; }
bool rtxOverlayOn() { return true; }
float rtxGain() { return 0.0; }
vec3 displayMap(vec3 c) {
    c = max(c, vec3(0.0));
    c = c / (c + vec3(1.0));
    return clamp(c, vec3(0.0), vec3(1.0));
}

float fieldBusFloat(uint slot) { return uintBitsToFloat(field.data_bus[slot]); }

ivec2 fieldMapCoord(vec2 uv) {
    ivec2 fs = imageSize(fieldPhi);
    return clamp(ivec2(uv * vec2(fs)), ivec2(0), fs - ivec2(1));
}

vec2 mouseFabricUv() {
    if (field.mouse_x < 0.0) return vec2(0.5);
    return clamp(vec2(field.mouse_x, field.mouse_y), vec2(0.0), vec2(1.0));
}

uint memPageBase() { return die.EIP & 0xFFFFF000u; }

float vizLiveT(float t) { return floor(t * VIZ_HZ) / VIZ_HZ; }
float vizStaticPhase() { return float((die.cycle_count >> 6) & 255u) * 0.004; }
bool isStaticImgRow(uint row) { return row >= IMG_STATIC_R0 && row <= IMG_STATIC_R1; }
bool isLiveImgRow(uint row) { return row >= IMG_LIVE_R0 && row <= IMG_LIVE_R1; }
bool isImgRow(uint row) { return isStaticImgRow(row) || isLiveImgRow(row); }

uint hitSection(uint row, uint col) {
    if (row > TEXT_R1) return SEC_NONE;
    if (col >= PHI_C0 && col < PHI_C1 && row >= 6u && row <= 17u) return SEC_PHI;
    if (col >= THM_C0 && col < THM_C1 && row >= 6u && row <= 17u) return SEC_THERMO;
    if (col >= GFX_C0 && col < GFX_C1 && row >= 6u && row <= 18u) return SEC_DIE;
    if (col >= GFX_C0 && col < GFX_C1 && row >= 3u && row <= 5u) return SEC_FLOW;
    if (row >= MEM_ROW0 && row <= MEM_ROW1 && col < THM_C0) return SEC_MEM;
    if (row >= BUS_HEX_R0 && row <= BUS_HEX_R1 && col < 114u) return SEC_BUS;
    if (row >= 6u && row <= 13u && col < GFX_C1) return SEC_GPR;
    if (row >= 3u && row <= 4u) return SEC_FCC;
    return SEC_NONE;
}

vec2 fabricUvFromPanel(vec2 panelUv, uint panelKind) {
    vec2 anchor = vec2(float(die.EIP & 0xFFu) / 255.0, float(die.ESP & 0xFFu) / 255.0);
    if (panelKind == 1u) anchor = vec2(0.18, 0.42);
    else if (panelKind == 2u) anchor = vec2(0.72, 0.38);
    else if (panelKind == 3u) anchor = vec2(0.50, 0.55);
    else if (panelKind == 4u) anchor = vec2(0.62, 0.22);
    else if (panelKind == 5u) anchor = vec2(0.35, 0.68);
    return clamp(anchor + (panelUv - 0.5) * 0.88, vec2(0.0), vec2(1.0));
}

uint panelKindAt(uint row, uint col) {
    if (!isImgRow(row)) return 0u;
    if (col >= IMG_PHI_C0 && col < IMG_PHI_C1) return 1u;
    if (col >= IMG_THM_C0 && col < IMG_THM_C1) return 2u;
    if (col >= IMG_DIE_C0 && col < IMG_DIE_C1) return 3u;
    if (col >= IMG_FLW_C0 && col < IMG_FLW_C1) return 4u;
    if (col >= IMG_AUX_C0 && col < IMG_AUX_C1) return 5u;
    return 0u;
}

vec2 fabricUvFromCell(vec2 cellUv, uint row, uint col, uint hoverSec) {
    return fabricUvFromPanel(cellUv, panelKindAt(row, col));
}

vec2 computeHudScale(ivec2 panelSize) {
    uint needW = GRID_COLS * COL_PITCH + MARGIN * 2u;
    uint needH = GRID_ROWS * ROW_PITCH + MARGIN * 2u;
    return max(vec2(1.0), vec2(panelSize) / vec2(needW, needH));
}

void evolveAnalogFields(ivec2 fc, float t) {
    ivec2 fs = imageSize(fieldPhi);
    if (fc.x >= fs.x || fc.y >= fs.y) return;
    float dt = 0.016 * fieldBusFloat(16u);
    float thermoA = fieldBusFloat(17u);
    float waveC = fieldBusFloat(18u);
    float gateF = fieldBusFloat(19u);
    float entFl = fieldBusFloat(20u);
    float inject = fieldBusFloat(21u);
    float propS = fieldBusFloat(22u);
    float couple = fieldBusFloat(23u);

    float phi = imageLoad(fieldPhi, fc).r;
    float phiL = imageLoad(fieldPhi, clamp(fc + ivec2(-1, 0), ivec2(0), fs - ivec2(1))).r;
    float phiR = imageLoad(fieldPhi, clamp(fc + ivec2(1, 0), ivec2(0), fs - ivec2(1))).r;
    float phiU = imageLoad(fieldPhi, clamp(fc + ivec2(0, -1), ivec2(0), fs - ivec2(1))).r;
    float phiD = imageLoad(fieldPhi, clamp(fc + ivec2(0, 1), ivec2(0), fs - ivec2(1))).r;
    float lap = phiL + phiR + phiU + phiD - 4.0 * phi;
    float newPhi = phi + waveC * dt * lap + propS * sin(t * 0.7 + float(fc.x + fc.y) * 0.01) * 0.002;

    float thermo = imageLoad(fieldThermo, fc).r;
    float tL = imageLoad(fieldThermo, clamp(fc + ivec2(-1, 0), ivec2(0), fs - ivec2(1))).r;
    float tR = imageLoad(fieldThermo, clamp(fc + ivec2(1, 0), ivec2(0), fs - ivec2(1))).r;
    float tU = imageLoad(fieldThermo, clamp(fc + ivec2(0, -1), ivec2(0), fs - ivec2(1))).r;
    float tD = imageLoad(fieldThermo, clamp(fc + ivec2(0, 1), ivec2(0), fs - ivec2(1))).r;
    float hostHeat = fieldBusFloat(33u);
    float teslaK = fieldBusFloat(34u);
    float newThermo = thermo + thermoA * dt * (tL + tR + tU + tD - 4.0 * thermo) + entFl * 0.001;
    newThermo += abs(lap) * couple * 0.004 + hostHeat * 0.08;

    float flow = imageLoad(fieldFlow, fc).r;
    float gradX = (phiR - phiL) * 0.5;
    float gradY = (phiD - phiU) * 0.5;
    vec2 flowDir = normalize(vec2(gradX, gradY) + vec2(1e-4));
    float teslaR = (flowDir.x > 0.0) ? 0.18 : 3.2;
    float teslaTurb = fract(sin(dot(vec3(float(fc.x), float(fc.y), t), vec3(12.9898, 78.233, 45.5432))) * 43758.5453) * 0.45;
    teslaR *= (1.0 + teslaTurb) * max(teslaK, 0.05);
    if (flowDir.x < 0.0) newThermo += entFl * 0.003 * teslaK;
    float newFlow = mix(flow, length(vec2(gradX, gradY)) * gateF, (0.12 + dt) / teslaR);

    // Extended field dispatch — parallel lead-in/core/lead-out slots (non-point waves)
    if ((field.control & CTRL_EXTENDED_FIELD) != 0u) {
        float extPhi = fieldBusFloat(35u);
        float extThermo = fieldBusFloat(36u);
        float extFlow = fieldBusFloat(37u);
        float extEntropy = fieldBusFloat(38u);
        newPhi += extPhi * 0.004;
        newThermo += extThermo * 0.006 + extEntropy * 0.003;
        newFlow = mix(newFlow, extFlow, 0.18);
    }

    imageStore(fieldPhi, fc, vec4(clamp(newPhi, -2.0, 2.0), 0.0, 0.0, 1.0));
    imageStore(fieldThermo, fc, vec4(clamp(newThermo, 0.0, 1.5), 0.0, 0.0, 1.0));
    imageStore(fieldFlow, fc, vec4(clamp(newFlow, 0.0, 1.0), gradX, gradY, 1.0));
}

