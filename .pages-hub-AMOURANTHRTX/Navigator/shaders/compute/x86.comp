        ch = regPair(col, CA, VA, 68u,49u,50u,58u, field.data_bus[12]); if (ch!=0u) return ch;
        ch = regPair(col, CB, VB, 68u,49u,51u,58u, field.data_bus[13]); if (ch!=0u) return ch;
        ch = regPair(col, CC, VC, 68u,49u,52u,58u, field.data_bus[14]); if (ch!=0u) return ch;
        ch = regPair(col, CD, VD, 68u,49u,53u,58u, field.data_bus[15]); if (ch!=0u) return ch;
        return extSysRow(row, col);
    }
    uint b = r * 4u;
    uint ch = 0u;
    ch = zmmIdLabel(col, CA, b); if (ch != 0u) return ch;
    ch = regValue(col, VA, die.ZMM1024[b][0]); if (ch != 0u) return ch;
    ch = zmmIdLabel(col, CB, b + 1u); if (ch != 0u) return ch;
    ch = regValue(col, VB, die.ZMM1024[b + 1u][0]); if (ch != 0u) return ch;
    ch = zmmIdLabel(col, CC, b + 2u); if (ch != 0u) return ch;
    ch = regValue(col, VC, die.ZMM1024[b + 2u][0]); if (ch != 0u) return ch;
    ch = zmmIdLabel(col, CD, b + 3u); if (ch != 0u) return ch;
    ch = regValue(col, VD, die.ZMM1024[b + 3u][0]); if (ch != 0u) return ch;
    return extSysRow(row, col);
}

uint zmmExtRow(uint row, uint col) {
    uint r = row - 16u;
    if (r > 2u) return 32u;
    uint b = 12u + r * 4u;
    uint ch = 0u;
    ch = zmmIdLabel(col, CA, b); if (ch != 0u) return ch;
    ch = regValue(col, VA, die.ZMM1024[b][0]); if (ch != 0u) return ch;
    ch = zmmIdLabel(col, CB, b + 1u); if (ch != 0u) return ch;
    ch = regValue(col, VB, die.ZMM1024[b + 1u][0]); if (ch != 0u) return ch;
    ch = zmmIdLabel(col, CC, b + 2u); if (ch != 0u) return ch;
    ch = regValue(col, VC, die.ZMM1024[b + 2u][0]); if (ch != 0u) return ch;
    ch = zmmIdLabel(col, CD, b + 3u); if (ch != 0u) return ch;
    ch = regValue(col, VD, die.ZMM1024[b + 3u][0]); if (ch != 0u) return ch;
    return 32u;
}

uint gprRow(uint row, uint col) {
    uint r = row - 6u;
    if (r <= 3u) {
        uint ch = 0u;
        if (r == 0u) {
            ch = regPair(col, CA, VA, 69u,65u,88u,32u, die.EAX); if (ch!=0u) return ch;
            ch = regPair(col, CB, VB, 69u,66u,88u,32u, die.EBX); if (ch!=0u) return ch;
            ch = regPair(col, CC, VC, 69u,67u,88u,32u, die.ECX); if (ch!=0u) return ch;
            ch = regPair(col, CD, VD, 69u,68u,88u,32u, die.EDX); if (ch!=0u) return ch;
        } else if (r == 1u) {
            ch = regPair(col, CA, VA, 69u,83u,73u,32u, die.ESI); if (ch!=0u) return ch;
            ch = regPair(col, CB, VB, 69u,68u,73u,32u, die.EDI); if (ch!=0u) return ch;
            ch = regPair(col, CC, VC, 69u,66u,80u,32u, die.EBP); if (ch!=0u) return ch;
            ch = regPair(col, CD, VD, 69u,83u,80u,32u, die.ESP); if (ch!=0u) return ch;
        } else if (r == 2u) {
            ch = regPair(col, CA, VA, 82u,56u,32u,32u, die.R8); if (ch!=0u) return ch;
            ch = regPair(col, CB, VB, 82u,57u,32u,32u, die.R9); if (ch!=0u) return ch;
            ch = regPair(col, CC, VC, 82u,49u,48u,32u, die.R10); if (ch!=0u) return ch;
            ch = regPair(col, CD, VD, 82u,49u,49u,32u, die.R11); if (ch!=0u) return ch;
        } else {
            ch = regPair(col, CA, VA, 82u,49u,50u,32u, die.R12); if (ch!=0u) return ch;
            ch = regPair(col, CB, VB, 82u,49u,51u,32u, die.R13); if (ch!=0u) return ch;
            ch = regPair(col, CC, VC, 82u,49u,52u,32u, die.R14); if (ch!=0u) return ch;
            ch = regPair(col, CD, VD, 82u,49u,53u,32u, die.R15); if (ch!=0u) return ch;
        }
        return extSysRow(row, col);
    }
    if (r >= 4u && r <= 7u)
        return zmmSampleRow(row, col);
    return 32u;
}

// x86 real-mode field die — byte decoder (included into CANVAS.comp via generator patch)
const uint CTRL_RTXDOS = 64u;
const uint CTRL_HOST_CPU = 8u;
const uint DISK_IMAGE_BASE = 0x20000u;
const uint DISK_IMAGE_BYTES = 737280u;
const uint GUEST_RAM_BYTES = 0x4000000u;
const uint BOOT_VECTOR = 0x7C00u;
const uint EFLAGS_HALTED = 0x40000000u;

uint translate(uint lin) {
    if ((die.CR0 & 0x80000000u) == 0u) return lin % uint(die.RAM.length() * 4u);
    uint tlb_idx = (lin >> 12) & 2047u;
    if ((die.TLB[tlb_idx] & 1u) != 0u) {
        die.RAM[TRACE_STAT_HIT]++;
        return (die.TLB[tlb_idx] & ~0xFFFu) | (lin & 0xFFFu);
    }
    die.RAM[TRACE_STAT_MISS]++;
    uint pml4e = die.PML4[(lin >> 39) & 0x1FFu];
    if ((pml4e & 1u) == 0u) { die.CR2 = lin; die.irq_vector = 14u; return 0u; }
    return lin % uint(die.RAM.length() * 4u);
}

uint regRead(uint r) {
    r &= 7u;
    if (r == 0u) return die.EAX;
    if (r == 1u) return die.ECX;
    if (r == 2u) return die.EDX;
    if (r == 3u) return die.EBX;
    if (r == 4u) return die.ESP;
    if (r == 5u) return die.EBP;
    if (r == 6u) return die.ESI;
    return die.EDI;
}

void regWrite(uint r, uint v) {
    r &= 7u;
    if (r == 0u) die.EAX = v;
    else if (r == 1u) die.ECX = v;
    else if (r == 2u) die.EDX = v;
    else if (r == 3u) die.EBX = v;
    else if (r == 4u) die.ESP = v;
    else if (r == 5u) die.EBP = v;
    else if (r == 6u) die.ESI = v;
    else die.EDI = v;
}

void setFlagsArith(uint a, uint b, uint r) {
    if (r == 0u) die.EFLAGS |= 0x40u; else die.EFLAGS &= ~0x40u;
    if (r < a) die.EFLAGS |= 0x01u; else die.EFLAGS &= ~0x01u;
    if ((r & 0x80000000u) != 0u) die.EFLAGS |= 0x80u; else die.EFLAGS &= ~0x80u;
}

void pushStack(uint v) {
    die.ESP -= 4u;
    uint a = translate(die.ESP);
    die.RAM[a / 4u] = v;
}

uint popStack() {
    uint a = translate(die.ESP);
    uint v = die.RAM[a / 4u];
    die.ESP += 4u;
    return v;
}

uint ramByte(uint addr) {
    if (addr < 0xC0000u) {
        if (addr >= uint(die.RAM.length()) * 4u) return 0u;
        uint widx = addr >> 2;
        uint shift = (addr & 3u) << 3;
        return (die.RAM[widx] >> shift) & 0xFFu;
    }
    addr = translate(addr);
    if (addr >= uint(die.RAM.length()) * 4u) return 0u;
    uint widx = addr >> 2;
    uint shift = (addr & 3u) << 3;
    return (die.RAM[widx] >> shift) & 0xFFu;
}

void ramWriteByte(uint addr, uint val) {
    addr = translate(addr);
    if (addr >= uint(die.RAM.length()) * 4u) return;
    uint widx = addr >> 2;
    uint shift = (addr & 3u) << 3;
    uint mask = ~(0xFFu << shift);
    die.RAM[widx] = (die.RAM[widx] & mask) | ((val & 0xFFu) << shift);
}

uint ramWord(uint addr) {
    return ramByte(addr) | (ramByte(addr + 1u) << 8);
}

void ramWriteWord(uint addr, uint val) {
    ramWriteByte(addr, val & 0xFFu);
    ramWriteByte(addr + 1u, (val >> 8) & 0xFFu);
}

uint linearAddr(uint seg, uint off) {
    return ((seg & 0xFFFFu) << 4) + (off & 0xFFFFu);
}

uint fetchByte() {
    uint a = linearAddr(die.CS, die.EIP);
    uint b = ramByte(a);
    die.EIP = (die.EIP + 1u) & 0xFFFFu;
    return b;
}

uint fetchWord() {
    uint lo = fetchByte();
    uint hi = fetchByte();
    return lo | (hi << 8);
}

int fetchS8() {
    uint u = fetchByte();
    return (u & 0x80u) != 0u ? int(u) - 256 : int(u);
}

void setCF(bool on) {
    if (on) die.EFLAGS |= 1u; else die.EFLAGS &= ~1u;
}

void setZF16(uint v) {
    if ((v & 0xFFFFu) == 0u) die.EFLAGS |= 0x40u; else die.EFLAGS &= ~0x40u;
}

uint reg16(uint r) {
    return regRead(r & 7u) & 0xFFFFu;
}

void setReg16(uint r, uint v) {
    uint cur = regRead(r & 7u);
    regWrite(r & 7u, (cur & 0xFFFF0000u) | (v & 0xFFFFu));
}

void push16(uint v) {
    die.ESP = (die.ESP - 2u) & 0xFFFFu;
    ramWriteWord(linearAddr(die.SS, die.ESP), v);
}

uint pop16() {
    uint a = linearAddr(die.SS, die.ESP);
    uint v = ramWord(a);
    die.ESP = (die.ESP + 2u) & 0xFFFFu;
    return v;
}

uint segValue(uint idx) {
    if (idx == 0u) return die.ES;
    if (idx == 1u) return die.CS;
    if (idx == 2u) return die.SS;
    if (idx == 3u) return die.DS;
    return die.DS;
}

void setSeg(uint idx, uint v) {
    v &= 0xFFFFu;
    if (idx == 0u) die.ES = v;
    else if (idx == 1u) die.CS = v;
    else if (idx == 2u) die.SS = v;
    else die.DS = v;
}

bool decodeEA16(uint modrm, uint seg, out uint addr, out bool isReg, out uint regIdx) {
    uint mod = modrm >> 6;
    uint reg = (modrm >> 3) & 7u;
    uint rm = modrm & 7u;
    regIdx = reg;
    isReg = (mod == 3u);
    if (isReg) { addr = 0u; return true; }
    uint off = 0u;
    if (rm == 0u) off = reg16(3u) + reg16(6u);
    else if (rm == 1u) off = reg16(3u) + reg16(7u);
    else if (rm == 2u) off = reg16(5u) + reg16(6u);
    else if (rm == 3u) off = reg16(5u) + reg16(7u);
    else if (rm == 4u) off = reg16(6u);
    else if (rm == 5u) off = reg16(7u);
    else if (rm == 6u) {
        if (mod == 0u) off = fetchWord();
        else { off = reg16(5u); if (mod == 1u) off = (off + uint(fetchS8())) & 0xFFFFu; else off = (off + fetchWord()) & 0xFFFFu; }
    } else off = reg16(3u);
    if (rm != 6u || mod != 0u) {
        if (mod == 1u) off = (off + uint(fetchS8())) & 0xFFFFu;
        else if (mod == 2u) off = (off + fetchWord()) & 0xFFFFu;
    }
    addr = linearAddr(seg, off);
    return true;
}

uint mem16(uint addr) { return ramWord(addr); }
uint mem32(uint addr) { return ramWord(addr) | (ramWord(addr + 2u) << 16u); }
void writeMem16(uint addr, uint v) { ramWriteWord(addr, v); }
uint mem8(uint addr) { return ramByte(addr); }
void writeMem8(uint addr, uint v) { ramWriteByte(addr, v); }

const uint HD_MIRROR_BYTE = 0x01000000u;

uint floppyByteOffset(uint cyl, uint head, uint sector) {
    if (sector < 1u || sector > 18u) return 0xFFFFFFFFu;
    return DISK_IMAGE_BASE + (cyl * 18u + head * 9u + (sector - 1u)) * 512u;
}

uint hdLbaByteOffset(uint lba) {
    uint byte = HD_MIRROR_BYTE + lba * 512u;
    if (byte + 512u > GUEST_RAM_BYTES) return 0xFFFFFFFFu;
    return byte;
}

void vgaPutChar(uint col, uint ch, uint attr) {
    uint off = VGA_BASE + col * 2u;
    uint widx = off / 4u;
    uint shift = (off % 4u) * 8u;
    uint mask = ~(0xFFu << shift);
    if (widx < uint(die.RAM.length()))
        die.RAM[widx] = (die.RAM[widx] & mask) | ((ch | (attr << 8u)) << shift);
}

void handle_bios_int(uint int_num) {
    if (int_num == 0x10u && (die.EAX & 0xFF00u) == 0x0E00u) {
        vgaPutChar(die.ECX & 0x7FFu, die.EBX & 0xFFu, 0x07u);
    } else if (int_num == 0x16u) {
        uint key = field.data_bus[41];
        if (key == 0u) key = field.data_bus[KEY_BUS_SLOT];
        if ((key & 0xFFu) == 0u) key = (key >> 8u) & 0xFFu;
        die.EAX = key & 0xFFu;
        if (key != 0u) die.EAX |= 0x0100u;
    }
}

void int13_disk() {
    uint ah = (die.EAX >> 8) & 0xFFu;
    uint dl = die.EDX & 0xFFu;
    bool hd = dl >= 0x80u;
    if (ah == 0x00u) { setCF(false); return; }
    if (ah == 0x42u && hd) {
        uint pkt = linearAddr(die.DS, die.ESI & 0xFFFFu);
        uint count = mem16(pkt + 2u);
        uint buf = mem32(pkt + 12u);
        uint lbaLo = mem32(pkt + 8u);
        if (count == 0u) { setCF(true); return; }
        for (uint i = 0u; i < count; ++i) {
            uint src = hdLbaByteOffset(lbaLo + i);
            if (src == 0xFFFFFFFFu) { setCF(true); return; }
            for (uint b = 0u; b < 512u; ++b)
                writeMem8(buf + i * 512u + b, ramByte(src + b));
        }
        die.EAX = (die.EAX & 0xFFFF00FFu);
        setCF(false);
        return;
    }
    if (ah == 0x02u) {
        uint al = die.EAX & 0xFFu;
        uint head = die.EDX & 0xFFu;
        uint cyl = ((die.ECX >> 8) & 0xFFu) | ((die.ECX & 0xC0u) << 2);
        uint sector = die.ECX & 0x3Fu;
        if (al == 0u || sector == 0u) { setCF(true); return; }
        uint dst = linearAddr(die.ES, die.EBX);
        uint n = al;
        for (uint i = 0u; i < n; ++i) {
            uint src;
            if (hd) {
                uint lba = cyl * 16u * 63u + head * 63u + (sector + i - 1u);
                src = hdLbaByteOffset(lba);
            } else {
                src = floppyByteOffset(cyl, head, sector + i);
                if (src != 0xFFFFFFFFu && src + 512u > DISK_IMAGE_BASE + DISK_IMAGE_BYTES)
                    src = 0xFFFFFFFFu;
            }
            if (src == 0xFFFFFFFFu) { setCF(true); return; }
            for (uint b = 0u; b < 512u; ++b)
                writeMem8(dst + i * 512u + b, ramByte(src + b));
        }
        die.EAX = (die.EAX & 0xFFFFFF00u) | n;
        setCF(false);
        return;
    }
    if (ah == 0x08u) {
        if (hd) {
            die.ECX = (die.ECX & 0xFFFF00FFu) | (0x3FFu << 8);
            die.EDX = (die.EDX & 0xFFFFFF00u) | 0x10u;
            die.EBX = 0xFFFFu;
        } else {
            die.ECX = (die.ECX & 0xFFFF00FFu) | (0x4909u << 8);
            die.EDX = (die.EDX & 0xFFFFFF00u) | 0x01u;
            die.EBX = 0x0003u;
        }
        setCF(false);
        return;
    }
    setCF(true);
}

void int2f_mscdex() {
    uint ax = die.EAX & 0xFFFFu;
    if ((ax >> 8) != 0x15u) { setCF(true); return; }
    uint sub = ax & 0xFFu;
    uint drives = field.data_bus[52];
    uint letter = field.data_bus[53];
    if (sub == 0x00u) {
        die.ECX = drives & 0xFFFFu;
        die.EAX = 0u;
        setCF(false);
        return;
    }
    if (sub == 0x03u) {
        if ((die.EBX & 0xFFu) < drives) {
            die.EDX = (die.EDX & 0xFFFFFF00u) | letter;
            die.EAX = 0u;
            setCF(false);
            return;
        }
        die.EAX = 0x0Fu;
        setCF(false);
        return;
    }
    if (sub == 0x04u) {
        if (drives != 0u && (die.EBX & 0xFFu) == letter) {
            die.EBX = 0u;
            die.EAX = 0u;
            setCF(false);
            return;
        }
        die.EAX = 0x0Fu;
        setCF(false);
        return;
    }
    if (sub == 0x06u) {
        die.EBX = 0x0201u;
        die.EAX = 0u;
        setCF(false);
        return;
    }
    if (sub == 0x08u || sub == 0x0Cu) {
        die.EAX = (drives != 0u) ? 0u : 0x0Fu;
        setCF(false);
        return;
    }
    die.EAX = 0x0Fu;
    setCF(false);
}

void int21_dos() {
    uint ah = (die.EAX >> 8) & 0xFFu;
    if (ah == 0x09u) {
        uint p = linearAddr(die.DS, die.EDX);
        for (uint guard = 0u; guard < 256u; ++guard) {
            uint c = mem8(p + guard);
            if (c == 0u || c == 36u) break;
            vgaPutChar((die.EBX + guard) & 0x7Fu, c, 0x07u);
        }
        return;
    }
    if (ah == 0x0Eu) {
        vgaPutChar(die.EBX & 0x7Fu, die.EAX & 0xFFu, 0x07u);
        return;
    }
    if (ah == 0x30u) {
        die.EAX = 0x00070000u;
        die.EBX = (die.EBX & 0xFFFF00FFu) | (0x10u << 8);
        return;
    }
    if (ah == 0x4Cu) {
        die.EFLAGS |= EFLAGS_HALTED;
        return;
    }
    setCF(true);
}

void dispatch_int(uint n) {
    if (n == 0x10u) handle_bios_int(0x10u);
    else if (n == 0x13u) int13_disk();
    else if (n == 0x16u) handle_bios_int(0x16u);
    else if (n == 0x21u) int21_dos();
    else if (n == 0x2Fu) int2f_mscdex();
    else if (n == 0x15u || n == 0x1Au) setCF(true);
    else {
        push16(die.EFLAGS & 0xFFFFu);
        die.EFLAGS &= ~0x200u;
        push16(die.CS);
        push16(die.EIP);
        uint iv = n * 4u;
        die.EIP = ramWord(iv);
        die.CS = ramWord(iv + 2u);
    }
}

void pushDebugTrace(uint instr, uint op) {
    uint slot = die.cycle_count % TRACE_SLOTS;
    die.RAM[TRACE_RAM_BASE + slot] = die.EIP;
    die.RAM[TRACE_RAM_BASE + TRACE_SLOTS + slot] = (op << 24u) | (instr & 0xFFFFFFu);
    uint logSlot = die.cycle_count % LOG_SLOTS;
    die.RAM[LOG_RAM_BASE + logSlot] = die.cycle_count ^ die.EIP ^ instr ^ (op << 8u);
}

uint opMnemonicChar(uint op, uint pos) {
    if (op == 0x50u) { const uint s[4]=uint[](80u,85u,83u,72u); return (pos<4u)?s[pos]:32u; }
    if (op == 0x58u) { const uint s[3]=uint[](80u,79u,80u); return (pos<3u)?s[pos]:32u; }
    if (op == 0xB8u || op == 0xB9u || op == 0xBBu) { const uint s[3]=uint[](77u,79u,86u); return (pos<3u)?s[pos]:32u; }
    if (op == 0x01u || op == 0x03u) { const uint s[3]=uint[](65u,68u,68u); return (pos<3u)?s[pos]:32u; }
    if (op == 0x29u || op == 0x2Bu) { const uint s[3]=uint[](83u,85u,66u); return (pos<3u)?s[pos]:32u; }
    if (op == 0xCDu) { const uint s[3]=uint[](73u,78u,84u); return (pos<3u)?s[pos]:32u; }
    if (op == 0xF4u) { const uint s[3]=uint[](72u,76u,84u); return (pos<3u)?s[pos]:32u; }
    if (pos == 0u) return 63u;
    if (pos == 1u) return 63u;
    return 32u;
}

uint instrExtRow(uint row, uint col) {
    uint r = row - 24u;
    if (r > 2u) return 32u;
    uint pc = linearAddr(die.CS, die.EIP);
    uint op = ramByte(pc);
    uint imm = ramWord(pc + 1u);
    uint nextPc = linearAddr(die.CS, (die.EIP + 1u) & 0xFFFFu);
    uint nextInstr = ramByte(nextPc);
    uint instr = op | (imm << 8);
    uint ch = 0u;
    if (r == 0u) {
        ch = strField(col, 46u, 114u, 6u); if (ch != 0u) return ch;
        ch = hexAt(die.EIP, col, 52u, 8u); if (ch != 0u) return ch;
        ch = strField(col, 62u, 119u, 7u); if (ch != 0u) return ch;
        if (col >= 70u && col < 74u) return opMnemonicChar(op, col - 70u);
        ch = hexAt(op, col, 74u, 2u); if (ch != 0u) return ch;
        ch = hexAt(imm, col, 78u, 8u); if (ch != 0u) return ch;
    } else if (r == 1u) {
        ch = strField(col, 46u, 115u, 4u); if (ch != 0u) return ch;
        ch = hexAt(instr, col, 50u, 8u); if (ch != 0u) return ch;
        ch = strField(col, 60u, 116u, 4u); if (ch != 0u) return ch;
        ch = hexAt(nextInstr, col, 64u, 8u); if (ch != 0u) return ch;
        ch = strField(col, 74u, 117u, 3u); if (ch != 0u) return ch;
        ch = hexAt(die.ESP, col, 78u, 8u); if (ch != 0u) return ch;
    } else {
        ch = lit4(col, CE, 73u, 78u, 83u, 84u); if (ch != 0u) return ch;
        ch = hexAt(op, col, VE, 2u); if (ch != 0u) return ch;
        ch = lit4(col, CF, 82u,65u,77u,58u); if (ch != 0u) return ch;
        ch = hexAt(imm, col, VF, 8u); if (ch != 0u) return ch;
        ch = lit4(col, CG, 78u,88u,84u,58u); if (ch != 0u) return ch;
        ch = hexAt(nextInstr & 0xFFu, col, VG, 2u); if (ch != 0u) return ch;
        ch = lit4(col, CH, 79u,80u,58u,32u); if (ch != 0u) return ch;
        ch = hexAt(nextInstr >> 16u, col, VH, 8u); if (ch != 0u) return ch;
    }
    return 32u;
}

uint tlbValidSample() {
    uint c = 0u;
    for (uint i = 0u; i < 512u; ++i)
        if ((die.TLB[i] & 1u) != 0u) c++;
    return c;
}

uint debugTraceChar(uint col, uint baseCol) {
    if (col < baseCol) return 0u;
    uint pos = col - baseCol;
    uint scroll = (die.cycle_count / 2u + uint(field.sealed_time * 6.0)) % (TRACE_SLOTS * 13u);
    uint slot = (scroll / 13u + pos / 13u) % TRACE_SLOTS;
    uint sub = (scroll + pos) % 13u;
    uint eip = die.RAM[TRACE_RAM_BASE + slot];
    uint packed = die.RAM[TRACE_RAM_BASE + TRACE_SLOTS + slot];
    uint op = packed >> 24u;
    uint instr = packed & 0xFFFFFFu;
    if (sub < 8u) return toHexChar((eip >> ((7u - sub) * 4u)) & 0xFu);
    if (sub == 8u) return 58u;
    if (sub < 11u) return toHexChar((op >> ((10u - sub) * 4u)) & 0xFu);
    if (sub == 11u) return 58u;
    return toHexChar((instr >> ((12u - sub) * 4u)) & 0xFu);
}

uint debugLogChar(uint col, uint baseCol) {
    if (col < baseCol) return 0u;
    uint pos = col - baseCol;
    uint scroll = (die.cycle_count / 4u + uint(field.sealed_time * 3.0)) % (LOG_SLOTS * 28u);
    uint slot = (scroll / 28u + pos / 28u) % LOG_SLOTS;
    uint sub = (scroll + pos) % 28u;
    uint sig = die.RAM[LOG_RAM_BASE + slot];
    uint msg = (sig + slot * 17u) % 6u;
    if (sub < 6u) {
        uint id = 110u + msg;
        return strAt(id, sub);
    }
    if (sub == 6u) return 32u;
    if (sub < 14u) return toHexChar((die.cycle_count >> ((13u - sub) * 4u)) & 0xFu);
    if (sub == 14u) return 32u;
    if (sub < 22u) return toHexChar((die.EIP >> ((21u - sub) * 4u)) & 0xFu);
    if (sub == 22u) return 32u;
    if (sub < 24u) return toHexChar((sig >> ((23u - sub) * 4u)) & 0xFu);
    return 32u;
}

uint pipelineStageRow(uint row, uint col) {
    if (row != 2u || col < PHI_C0 || col >= PHI_C0 + 32u) return 0u;
    uint phase = die.cycle_count % 4u;
    uint ch = strField(col, PHI_C0, 111u, 11u);
    if (ch != 0u) return ch;
    uint stages[4] = uint[4](70u, 68u, 69u, 87u);
    uint stageNames[4][4] = uint[4][4](
        uint[4](70u,69u,84u,67u), uint[4](68u,69u,67u,32u),
        uint[4](69u,88u,69u,32u), uint[4](87u,66u,32u,32u));
    for (uint s = 0u; s < 4u; ++s) {
        uint base = PHI_C0 + 12u + s * 5u;
        if (col >= base && col < base + 4u) {
            uint c = stageNames[s][col - base];
            return (s == phase) ? c : ((c >= 65u && c <= 90u) ? (c + 32u) : c);
        }
        if (col == base + 4u && s < 3u) return 62u;
    }
    return 0u;
}

uint debugConsoleRow(uint row, uint col) {
    if (row == HELP_R0) {
        uint ch = strField(col, 2u, 110u, 12u);
        if (ch != 0u) return ch;
        ch = debugTraceChar(col, 16u);
        if (ch != 0u) return ch;
    }
    if (row == HELP_R0 + 1u) {
        uint ch = strField(col, 2u, 112u, 10u);
        if (ch != 0u) return ch;
        ch = hexAt(tlbValidSample(), col, 14u, 3u);
        if (ch != 0u) return ch;
        ch = lit4(col, 18u, 47u,53u,49u,50u);
        if (ch != 0u) return ch;
        ch = lit4(col, 22u, 72u,73u,84u,58u);
        if (ch != 0u) return ch;
        ch = hexAt(die.RAM[TRACE_STAT_HIT], col, 26u, 6u);
        if (ch != 0u) return ch;
        ch = lit4(col, 33u, 77u,83u,83u,58u);
        if (ch != 0u) return ch;
        ch = hexAt(die.RAM[TRACE_STAT_MISS], col, 37u, 6u);
        if (ch != 0u) return ch;
        ch = lit4(col, 44u, 69u,70u,76u,58u);
        if (ch != 0u) return ch;
        ch = hexAt(die.EFLAGS, col, 48u, 8u);
        if (ch != 0u) return ch;
        ch = strField(col, 60u, 118u, 8u);
        if (ch != 0u) return ch;
        ch = hexAt(die.cycle_count, col, 70u, 8u);
        if (ch != 0u) return ch;
    }
    if (row == HELP_R1) {
        uint ch = strField(col, 2u, 113u, 11u);
        if (ch != 0u) return ch;
        ch = debugLogChar(col, 14u);
        if (ch != 0u) return ch;
    }
    return 0u;
}


void handle_interrupts() {
    if (die.irq_vector == 0u) return;
    uint vec = die.irq_vector; die.irq_vector = 0u;
    if ((die.CR0 & 1u) == 0u) {
        push16(die.EFLAGS & 0xFFFFu);
        push16(die.CS & 0xFFFFu);
        push16(die.EIP & 0xFFFFu);
        die.EIP = die.IDT[vec * 2u] & 0xFFFFu;
        die.CS = die.IDT[vec * 2u + 1u] & 0xFFFFu;
    } else {
        pushStack(die.EFLAGS);
        pushStack(die.CS);
        pushStack(die.EIP);
        die.EIP = die.IDT[vec * 2u];
    }
}

void illegalHalt(uint op) {
    pushDebugTrace(op, 0xFFu);
    die.EFLAGS |= EFLAGS_HALTED;
}


void rb(inout uint p, uint b) { ramWriteByte(p, b); p++; }

void seedBootRom() {
    uint p = 0u;
    rb(p, 0xEBu); rb(p, 0x1Cu);
    const uint banner[28] = uint[28](
        65u,77u,79u,85u,82u,65u,78u,84u,72u,32u,70u,73u,69u,76u,68u,32u,
        67u,80u,85u,32u,79u,78u,76u,73u,78u,69u,62u,62u);
    for (uint i = 0u; i < 28u; ++i) rb(p, banner[i]);
    rb(p, 0u);
    rb(p, 0xBEu); rb(p, 0x02u); rb(p, 0x00u);
    uint loop1 = p;
    rb(p, 0xACu); rb(p, 0x0Au); rb(p, 0xC0u); rb(p, 0x74u); rb(p, 0x08u);
    rb(p, 0xB4u); rb(p, 0x0Eu); rb(p, 0xB7u); rb(p, 0x07u); rb(p, 0xCDu); rb(p, 0x10u);
    rb(p, 0xEBu); rb(p, uint(int(loop1) - int(p) - 1) & 0xFFu);
    uint keyloop = p;
    rb(p, 0xB4u); rb(p, 0x00u); rb(p, 0xCDu); rb(p, 0x16u);
    rb(p, 0x0Au); rb(p, 0xC0u); rb(p, 0x74u); rb(p, 0xF4u);
    rb(p, 0xB4u); rb(p, 0x0Eu); rb(p, 0xB7u); rb(p, 0x07u); rb(p, 0xCDu); rb(p, 0x10u);
    rb(p, 0xEBu); rb(p, uint(int(keyloop) - int(p) - 1) & 0xFFu);
    rb(p, 0xF4u);
}

void init_die() {
    if ((field.control & 1u) == 0u) return;
    bool gpuDoom = (field.control & 128u) != 0u;
    bool rtxDos = (field.control & CTRL_RTXDOS) != 0u && !gpuDoom;
    die.irq_vector = 0u;
    die.video_mode = 3u;
    die.EFLAGS &= ~EFLAGS_HALTED;
    if (!rtxDos && !gpuDoom) {
        die.EAX = die.EBX = die.ECX = die.EDX = 0u;
        die.ESI = die.EDI = die.EBP = 0u; die.ESP = 0xFFFEu;
        die.R8 = die.R9 = die.R10 = die.R11 = die.R12 = die.R13 = die.R14 = die.R15 = 0u;
        die.EIP = 0u; die.EFLAGS = 0x00000202u;
        die.CR0 = 0u; die.CR2 = die.CR3 = die.CR4 = die.CR8 = 0u;
        die.CS = die.DS = die.ES = die.SS = 0u;
        die.FS = die.GS = 0u;
        die.cycle_count = 0u;
        for (uint i = 0u; i < uint(die.RAM.length()); ++i) die.RAM[i] = 0u;
        seedBootRom();
    } else if (rtxDos) {
        die.CR0 = 0u;
        if (die.EIP == 0u) die.EIP = BOOT_VECTOR;
        if (die.ESP == 0u) die.ESP = BOOT_VECTOR;
        die.cycle_count = 0u;
    } else if (gpuDoom) {
        die.cycle_count = 0u;
        die.video_mode = 0x13u;
        ramWriteByte(0x449u, 0x13u);
    }
    if (!rtxDos) {
        for (uint i = 0u; i < 2000u; ++i) die.RAM[VGA_BASE / 4u + i] = 0x07200720u;
    }
    die.RAM[TRACE_STAT_HIT] = 0u;
    die.RAM[TRACE_STAT_MISS] = 0u;
}

void execute_cycle() {
    if ((die.EFLAGS & EFLAGS_HALTED) != 0u) return;
    handle_interrupts();

    uint startIp = die.EIP;
    uint segOv = 0xFFFFu;
    uint op = fetchByte();
    for (uint guard = 0u; guard < 4u && (op == 0x26u || op == 0x2Eu || op == 0x36u || op == 0x3Eu); ++guard) {
        if (op == 0x26u) segOv = 0u;
        else if (op == 0x2Eu) segOv = 1u;
        else if (op == 0x36u) segOv = 2u;
        else if (op == 0x3Eu) segOv = 3u;
        op = fetchByte();
    }
    uint dataSeg = (segOv == 0xFFFFu) ? die.DS : segValue(segOv);

    if (op == 0x90u) {
    } else if (op == 0xF4u) {
        die.EFLAGS |= EFLAGS_HALTED;
    } else if (op == 0xCDu) {
        dispatch_int(fetchByte());
    } else if (op == 0xC3u) {
        die.EIP = pop16();
    } else if (op == 0xCFu) {
        die.EIP = pop16();
        die.CS = pop16();
        die.EFLAGS = (die.EFLAGS & 0xFFFF0000u) | pop16();
    } else if (op == 0xEBu) {
        int rel = fetchS8();
        die.EIP = uint(int(die.EIP) + rel) & 0xFFFFu;
    } else if (op == 0xE9u) {
        int rel = int(fetchWord());
        die.EIP = uint(int(die.EIP) + rel) & 0xFFFFu;
    } else if (op == 0xE2u) {
        int rel = fetchS8();
        die.ECX = (die.ECX - 1u) & 0xFFFFu;
        if ((die.ECX & 0xFFFFu) != 0u)
            die.EIP = uint(int(die.EIP) + rel) & 0xFFFFu;
    } else if (op >= 0x70u && op <= 0x7Fu) {
        int rel = fetchS8();
        bool take = false;
        bool zf = (die.EFLAGS & 0x40u) != 0u;
        bool cf = (die.EFLAGS & 1u) != 0u;
        if (op == 0x74u) take = zf;
        else if (op == 0x75u) take = !zf;
        else if (op == 0x72u) take = cf;
        else if (op == 0x73u) take = !cf;
        else if (op == 0x78u) take = (die.EFLAGS & 0x80u) != 0u;
        else if (op == 0x79u) take = (die.EFLAGS & 0x80u) == 0u;
        if (take) die.EIP = uint(int(die.EIP) + rel) & 0xFFFFu;
    } else if (op >= 0xB0u && op <= 0xB7u) {
        uint r = op - 0xB0u;
        uint v = fetchByte();
        setReg16(r, (reg16(r) & 0xFF00u) | v);
    } else if (op >= 0xB8u && op <= 0xBFu) {
        setReg16(op - 0xB8u, fetchWord());
    } else if (op >= 0x50u && op <= 0x57u) {
        push16(reg16(op - 0x50u));
    } else if (op >= 0x58u && op <= 0x5Fu) {
        setReg16(op - 0x58u, pop16());
    } else if (op >= 0x40u && op <= 0x47u) {
        uint v = (reg16(op - 0x40u) + 1u) & 0xFFFFu;
        setReg16(op - 0x40u, v);
        setZF16(v);
    } else if (op >= 0x48u && op <= 0x4Fu) {
        uint v = (reg16(op - 0x48u) - 1u) & 0xFFFFu;
        setReg16(op - 0x48u, v);
        setZF16(v);
    } else if (op == 0x31u || op == 0x33u || op == 0x29u || op == 0x2Bu || op == 0x09u || op == 0x0Bu ||
               op == 0x21u || op == 0x23u || op == 0x01u || op == 0x03u || op == 0x85u) {
        uint modrm = fetchByte();
        bool isReg = false;
        uint regIdx = 0u;
        uint ea = 0u;
        decodeEA16(modrm, dataSeg, ea, isReg, regIdx);
        uint lhs = isReg ? reg16(modrm & 7u) : mem16(ea);
        uint rhs = reg16(regIdx);
        uint res = lhs;
        if (op == 0x31u || op == 0x33u) res = lhs ^ rhs;
        else if (op == 0x29u || op == 0x2Bu) res = (lhs - rhs) & 0xFFFFu;
        else if (op == 0x09u || op == 0x0Bu) res = lhs | rhs;
        else if (op == 0x21u || op == 0x23u) res = lhs & rhs;
        else if (op == 0x01u || op == 0x03u) res = (lhs + rhs) & 0xFFFFu;
        else if (op == 0x85u) res = lhs & rhs;
        if (op != 0x85u) {
            if (isReg) setReg16(modrm & 7u, res);
            else writeMem16(ea, res);
        }
        setZF16(res);
    } else if (op == 0x89u || op == 0x8Bu || op == 0x88u || op == 0x8Au) {
        uint modrm = fetchByte();
        bool isReg = false;
        uint regIdx = 0u;
        uint ea = 0u;
        decodeEA16(modrm, dataSeg, ea, isReg, regIdx);
        if (op == 0x89u) {
            if (isReg) setReg16(modrm & 7u, reg16(regIdx));
            else writeMem16(ea, reg16(regIdx));
        } else if (op == 0x8Bu) {
            setReg16(regIdx, isReg ? reg16(modrm & 7u) : mem16(ea));
        } else if (op == 0x88u) {
            uint v = reg16(regIdx) & 0xFFu;
            if (isReg) setReg16(modrm & 7u, (reg16(modrm & 7u) & 0xFF00u) | v);
            else writeMem8(ea, v);
        } else {
            uint v = isReg ? (reg16(modrm & 7u) & 0xFFu) : mem8(ea);
            setReg16(regIdx, (reg16(regIdx) & 0xFF00u) | v);
        }
    } else if (op == 0x8Eu || op == 0x8Cu) {
        uint modrm = fetchByte();
        bool isReg = false;
        uint regIdx = 0u;
        uint ea = 0u;
        decodeEA16(modrm, dataSeg, ea, isReg, regIdx);
        uint sreg = (modrm >> 3) & 3u;
        if (op == 0x8Eu) {
            uint v = isReg ? reg16(modrm & 7u) : mem16(ea);
            setSeg(sreg, v);
        } else {
            uint v = segValue(sreg);
            if (isReg) setReg16(modrm & 7u, v);
            else writeMem16(ea, v);
        }
    } else if (op == 0x3Du) {
        uint imm = fetchWord();
        uint ax = reg16(0u);
        uint res = (ax - imm) & 0xFFFFu;
        setZF16(res);
        setCF(ax < imm);
    } else if (op == 0x05u) {
        uint imm = fetchWord();
        uint ax = (reg16(0u) + imm) & 0xFFFFu;
        setReg16(0u, ax);
        setZF16(ax);
    } else if (op == 0x83u) {
        uint modrm = fetchByte();
        int simm = fetchS8();
        bool isReg = false;
        uint regIdx = 0u;
        uint ea = 0u;
        decodeEA16(modrm, dataSeg, ea, isReg, regIdx);
        uint sub = (modrm >> 3) & 7u;
        uint lhs = isReg ? reg16(modrm & 7u) : mem16(ea);
        uint res = lhs;
        if (sub == 0u || sub == 2u) res = (lhs + uint(simm)) & 0xFFFFu;
        else if (sub == 5u || sub == 7u) res = (lhs - uint(simm)) & 0xFFFFu;
        else if (sub == 4u) res = lhs & uint(simm);
        else if (sub == 1u) res = lhs | uint(simm);
        else if (sub == 6u) res = lhs ^ uint(simm);
        else { illegalHalt(op); return; }
        if (sub != 7u) {
            if (isReg) setReg16(modrm & 7u, res);
            else writeMem16(ea, res);
        }
        setZF16(sub == 7u ? (lhs & uint(simm)) : res);
    } else if (op == 0xA0u) {
        uint imm = fetchWord();
        setReg16(0u, (reg16(0u) & 0xFF00u) | mem8(linearAddr(dataSeg, imm)));
    } else if (op == 0xA1u) {
        setReg16(0u, mem16(linearAddr(dataSeg, fetchWord())));
    } else if (op == 0xA2u) {
        uint imm = fetchWord();
        writeMem8(linearAddr(dataSeg, imm), reg16(0u) & 0xFFu);
    } else if (op == 0xA3u) {
        writeMem16(linearAddr(dataSeg, fetchWord()), reg16(0u));
    } else if (op == 0xACu) {
        uint v = mem8(linearAddr(die.DS, die.ESI & 0xFFFFu));
        setReg16(0u, (reg16(0u) & 0xFF00u) | v);
        die.ESI = (die.ESI + 1u) & 0xFFFFu;
    } else if (op == 0xAAu) {
        writeMem8(linearAddr(die.ES, die.EDI & 0xFFFFu), reg16(0u) & 0xFFu);
        die.EDI = (die.EDI + 1u) & 0xFFFFu;
    } else if (op == 0x1Eu) push16(die.DS);
    else if (op == 0x1Fu) die.DS = pop16();
    else if (op == 0x06u) push16(die.ES);
    else if (op == 0x07u) die.ES = pop16();
    else if (op == 0x0Eu) push16(die.CS);
    else if (op == 0xFAu) die.EFLAGS &= ~0x200u;
    else if (op == 0xFBu) die.EFLAGS |= 0x200u;
    else if (op == 0xFCu) { }
    else if (op == 0xEAu) {
        uint off = fetchWord();
        uint seg = fetchWord();
        die.EIP = off;
        die.CS = seg;
    } else {
        illegalHalt(op);
        return;
    }

    uint packed = op | ((die.EIP - startIp) << 8);
    pushDebugTrace(packed, op);
    die.cycle_count++;
}uint segField(uint col, uint lbl, uint val, uint a, uint b, uint c, uint d) {
    uint ch = lit4(col, lbl, a, b, c, d);
    if (ch != 0u) return ch;
    return hexAt(val, col, lbl + 4u, 4u);
}

uint memHexByte(uint col, uint base, uint bytei) {
    uint addr = base + bytei;
    uint val = (addr / 4u < uint(die.RAM.length()))
        ? (die.RAM[addr/4u] >> ((addr % 4u)*8u)) & 0xFFu : 0u;
    uint hi = toHexChar(val >> 4u);
    uint lo = toHexChar(val & 0xFu);
    uint pos = col - 11u;
    if ((pos & 1u) == 0u) return hi;
    return lo;
}

uint fccSlotHex(uint col, uint slot, uint labelCol, uint a, uint b, uint c) {
    uint ch = lit4(col, labelCol, a, b, c, 58u);
    if (ch != 0u) return ch;
    if (col >= labelCol + 5u && col < labelCol + 13u)
        return hexAt(field.data_bus[slot], col, labelCol + 5u, 8u);
    return 0u;
}

uint fccSlotAt(uint col, uint slot, uint labelCol, uint a, uint b, uint c) {
    return fccSlotHex(col, slot, labelCol, a, b, c);
}

uint fccDispatchRow(uint row, uint col, uint hoverSec) {
    if (row != 4u || (col >= GFX_C0 && col < GFX_C1)) return 0u;
    uint ch = 0u;
    if (col < GFX_C0) {
        ch = strField(col, PHI_C0, 70u, 8u); if (ch != 0u) return ch;
        ch = fccSlotAt(col, 16u, PHI_C0 + 9u, 84u,83u,32u); if (ch != 0u) return ch;
        ch = fccSlotAt(col, 17u, PHI_C0 + 9u + FCC_SLOT_W, 84u,72u,32u); if (ch != 0u) return ch;
        if (hoverSec == SEC_FCC)
            ch = fccSlotAt(col, 18u, PHI_C0 + 9u + FCC_SLOT_W * 2u, 87u,86u,32u);
        return ch;
    }
    if (col < THM_C0 || col >= THM_C1) return 0u;
    ch = fccSlotAt(col, 18u, THM_C0, 87u,86u,32u); if (ch != 0u) return ch;
    ch = fccSlotAt(col, 19u, THM_C0 + FCC_SLOT_W, 71u,84u,32u); if (ch != 0u) return ch;
    ch = fccSlotAt(col, 20u, THM_C0 + FCC_SLOT_W * 2u, 69u,78u,70u); if (ch != 0u) return ch;
    ch = fccSlotAt(col, 21u, THM_C0 + FCC_SLOT_W * 3u, 73u,78u,32u); if (ch != 0u) return ch;
    if (hoverSec == SEC_FCC) {
        ch = fccSlotAt(col, 22u, THM_C0 + FCC_SLOT_W * 4u, 80u,82u,80u); if (ch != 0u) return ch;
    }
    return ch;
}

uint acctDispatchRow(uint row, uint col, uint hoverSec) {
    if (row != 3u || col < THM_C0 || col >= THM_C1) return 0u;
    uint ch = 0u;
    ch = strField(col, THM_C0, 71u, 7u); if (ch != 0u) return ch;
    ch = fccSlotAt(col, 24u, THM_C0 + 8u, 69u,78u,84u); if (ch != 0u) return ch;
    ch = fccSlotAt(col, 25u, THM_C0 + 8u + FCC_SLOT_W, 66u,78u,68u); if (ch != 0u) return ch;
    if (hoverSec == SEC_FCC) {
        ch = fccSlotAt(col, 26u, THM_C0 + 8u + FCC_SLOT_W * 2u, 67u,83u,84u); if (ch != 0u) return ch;
        ch = fccSlotAt(col, 27u, THM_C0 + 8u + FCC_SLOT_W * 3u, 70u,82u,69u); if (ch != 0u) return ch;
    }
    return ch;
}

uint statusDispatchRow(uint row, uint col) {
    if (row != 3u || col >= PHI_C1) return 0u;
    uint ch = 0u;
    ch = strField(col, PHI_C0, 4u, 6u); if (ch != 0u) return ch;
    ch = hexAt(die.cycle_count, col, PHI_C0 + 7u, 8u); if (ch != 0u) return ch;
    ch = strField(col, PHI_C0 + 16u, 5u, 3u); if (ch != 0u) return ch;
    ch = hexAt(die.EIP, col, PHI_C0 + 20u, 8u); if (ch != 0u) return ch;
    ch = strField(col, PHI_C0 + 29u, 6u, 3u); if (ch != 0u) return ch;
    ch = hexAt(die.irq_vector, col, PHI_C0 + 33u, 2u); if (ch != 0u) return ch;
    return 0u;
}

uint fieldProbeRow(uint row, uint col) {
    if (row != 19u) return 0u;
    vec2 probeUv = vec2(float(die.EIP & 0xFFu) / 255.0, float(die.ESP & 0xFFu) / 255.0);
    ivec2 fc = fieldMapCoord(probeUv);
    ivec2 fs = imageSize(fieldPhi);
    fc = clamp(fc, ivec2(0), fs - ivec2(1));
    uint phiBits = floatBitsToUint(imageLoad(fieldPhi, fc).r);
    uint thermoBits = floatBitsToUint(imageLoad(fieldThermo, fc).r);
    uint flowBits = floatBitsToUint(imageLoad(fieldFlow, fc).r);
    uint ch = 0u;
    ch = strField(col, 2u, 72u, 4u); if (ch != 0u) return ch;
    ch = hexAt(phiBits, col, 6u, 8u); if (ch != 0u) return ch;
    ch = strField(col, 16u, 73u, 5u); if (ch != 0u) return ch;
    ch = hexAt(thermoBits, col, 21u, 8u); if (ch != 0u) return ch;
    ch = strField(col, 32u, 74u, 5u); if (ch != 0u) return ch;
    ch = hexAt(flowBits, col, 37u, 8u); if (ch != 0u) return ch;
    ch = lit4(col, CE, 80u,82u,66u,58u); if (ch != 0u) return ch;
    ch = hexAt(floatBitsToUint(thermoAccountant.entropyThisFrame), col, VE, 8u); if (ch != 0u) return ch;
    ch = lit4(col, CF, 66u,78u,68u,58u); if (ch != 0u) return ch;
    ch = hexAt(floatBitsToUint(thermoAccountant.avgBoundaryThermo), col, VF, 8u); if (ch != 0u) return ch;
    ch = lit4(col, CG, 70u,82u,69u,58u); if (ch != 0u) return ch;
    ch = hexAt(floatBitsToUint(thermoAccountant.freeEnergyIncome), col, VG, 8u); if (ch != 0u) return ch;
    ch = lit4(col, CH, 83u,84u,80u,58u); if (ch != 0u) return ch;
    ch = hexAt(thermoAccountant.steps, col, VH, 8u); if (ch != 0u) return ch;
    return 0u;
}

uint memDumpRow(uint row, uint col, uint hoverSec) {
    if (row < MEM_ROW0 || row > MEM_ROW1) return 0u;
    uint memrow = row - MEM_ROW0;
    uint base = memPageBase() + memrow * 16u;
    uint ch = 0u;
    if (col >= 2u && col < 10u) return hexAt(base, col, 2u, 8u);
    if (col >= 11u && col < 43u) {
        uint pos = col - 11u;
        uint bytei = pos / 2u;
        if (bytei < 16u) return memHexByte(col, base, bytei);
    }
    if (col >= 46u && col < MEM_ASCII0) {
        uint bytei = (col - 46u);
        if (bytei < 16u) {
            uint addr = base + bytei;
            uint val = (addr / 4u < uint(die.RAM.length()))
                ? (die.RAM[addr/4u] >> ((addr % 4u)*8u)) & 0xFFu : 0u;
            if (val < 32u || val > 126u) return 46u;
            return val;
        }
    }
    if (col >= MEM_ASCII0 && col < MEM_ASCII1) {
        uint bytei = 16u + (col - MEM_ASCII0);
        if (bytei < 32u) {
            uint addr = base + bytei;
            uint val = (addr / 4u < uint(die.RAM.length()))
                ? (die.RAM[addr/4u] >> ((addr % 4u)*8u)) & 0xFFu : 0u;
            if (val < 32u || val > 126u) return 46u;
            return val;
        }
    }
    return 0u;
}

uint busHexRow(uint row, uint col, uint hoverSec) {
    if (row < BUS_HEX_R0 || row > BUS_HEX_R1) return 0u;
    if (col < 2u || col >= 114u) return 0u;
    uint slotInRow = (col - 2u) / 9u;
    uint digit = (col - 2u) % 9u;
    if (digit >= 8u) return 32u;
    uint slot = (row == BUS_HEX_R0) ? slotInRow : (8u + slotInRow);
    if (slot >= 16u) return 0u;
    return toHexChar(field.data_bus[slot] >> ((7u - digit) * 4u));
}

uint busSlotLabelRow(uint row, uint col) {
    if (row != BUS_LABEL_ROW || col < 2u || col >= 114u) return 0u;
    uint slotInRow = (col - 2u) / 9u;
    uint pos = (col - 2u) % 9u;
    if (pos > 3u) return 0u;
    if (pos == 0u) return 68u;
    if (pos == 1u) {
        uint d = slotInRow % 10u;
        return (slotInRow < 10u) ? (48u + d) : (48u + (d / 10u));
    }
    if (pos == 2u && slotInRow >= 10u) return 48u + (slotInRow % 10u);
    if (pos == 2u) return 58u;
    return 0u;
}

uint fieldOpsLabels(uint row, uint col) {
