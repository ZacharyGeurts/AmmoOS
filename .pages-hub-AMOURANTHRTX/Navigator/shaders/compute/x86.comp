float graphicCellFrame(ivec2 lp, uint row, uint col) {
    ivec4 R = cellPixelRect(row, col);
    if (!inPixelRect(lp, R)) return 0.0;
    vec2 uv = (vec2(lp - R.xy) + 0.5) / vec2(float(R.z - R.x), float(R.w - R.y));
    float edge = min(min(uv.x, 1.0 - uv.x), min(uv.y, 1.0 - uv.y));
    float rim = smoothstep(0.11, 0.0, edge);
    float topBar = smoothstep(0.16, 0.0, uv.y);
    return clamp(rim + topBar * 0.5, 0.0, 1.0);
}

vec3 colorFor(uint row, uint col, uint ascii, float ink, ThemePal th) {
    if (ink < 0.05) return th.void_;
    uint k = cellKind(row, col, ascii);
    vec3 fg = th.label * 0.92;
    if (k == 6u) fg = th.border;
    else if (k == 2u) fg = th.title;
    else if (k == 3u) fg = th.section;
    else if (k == 1u) fg = th.rule;
    else if (k == 4u) fg = th.value;
    else if (k == 5u) fg = th.mem;
    else if (k == 7u) fg = th.grin;
    else if (die.irq_vector != 0u && row == 3u && col >= 40u && col < 42u) fg = th.warn * 1.4;
    return fg;
}

