@ECHO OFF
SET WINBOOTDIR=C:\WINDOWS
SET WINDIR=C:\WINDOWS
IF EXIST C:\WINDOWS\WIN.COM GOTO CHECKKERN
ECHO.
ECHO Windows 3.1 — Zachary Geurts MCSE+I
ECHO Copy licensed Windows to C:\WINDOWS — see WIN31.TXT
IF EXIST C:\WIN31.TXT TYPE C:\WIN31.TXT
ECHO.
ECHO RTX preview at C:\> : WIN31 or SETUP31
GOTO END
:CHECKKERN
IF EXIST C:\WINDOWS\KERNEL.EXE GOTO RUN31
IF EXIST C:\WINDOWS\KRNL386.EXE GOTO RUN31
ECHO KERNEL.EXE / KRNL386.EXE missing in C:\WINDOWS
IF EXIST C:\WIN31.TXT TYPE C:\WIN31.TXT
GOTO END
