# hostess7 — migrated from run-tests.sh
@profile fastest
@verbose clean
@motto "hostess7 stack tests · AmmoLang assert"

suite hostess7 ·
  group hostess7 in nexus
    assert script:hostess7_in_nexus
  group h7 library module
    assert file:lib/h7-library-bridge.py
    assert file:lib/nexus-librarian-corps.py
    assert file:lib/h7-library-secure-reader.py
    assert file:data/nexus-librarians.json
    assert file:data/librarian-corps-doctrine.json
    assert file:lib/h7-library-atlas.py
    assert file:lib/h7-field-drive-tie.py
    assert file:lib/dewey-library-github.py
    assert file:data/dewey-decimal-map.json
    assert file:data/library-profiles.json
    assert file:data/war-books-seed.json
    assert file:data/dewey-full-tree.json
    assert file:panel/assets/h7-reader.js
    assert file:lib/field-books/network-security-field-guide.txt
    assert grep:lib/threat-panel.sh:h7_library
    assert grep:lib/threat-panel.sh:h7-library-bridge.py
    assert grep:panel/threat-panel.html:view-library
    assert grep:panel/threat-panel.html:library-dewey
    assert grep:panel/threat-panel.html:library-profile-select
    assert grep:panel/threat-panel.html:library-war-shelves
    assert grep:panel/threat-panel.html:H7Reader
    assert grep:lib/threat-panel-http.py:/api/library/search
    assert grep:lib/threat-panel-http.py:/api/library/full
    assert grep:lib/threat-panel-http.py:/api/library/profiles
    assert grep:lib/threat-panel-http.py:/api/library/librarians
    assert grep:lib/threat-panel-http.py:/api/library/reader/issue
    assert grep:lib/threat-panel-http.py:/api/library/knowledge
    assert grep:panel/assets/h7-reader.js:openSecure
    assert grep:panel/threat-panel.html:h7r-bookmarks
    assert grep:panel/threat-panel.html:librarian_corps
    assert py:h7-library-secure-reader.py issue network-security-field-guide match:"secure": true
    assert py:nexus-librarian-corps.py status match:margot_dewey
    assert py:nexus-librarian-corps.py teach match:"taught"
    assert py:h7-library-bridge.py librarians match:clara_catalog
    assert py:h7-library-bridge.py build match:network-security-field-guide
    assert py:h7-library-bridge.py build match:h7-library-atlas
    assert py:h7-library-bridge.py search security match:passages
    assert grep:lib/threat-panel-http.py:/api/library/atlas
    assert grep:panel/threat-panel.html:library-collections
    assert py:h7-library-bridge.py profiles match:hostess7
    assert py:h7-field-drive-tie.py inventory match:textbooks_h7
    assert py:h7-library-bridge.py tracking match:manifest_count
    assert grep:panel/threat-panel.html:tracking.lists
  group h7 corpus sync
    assert script:h7_corpus_sync
  group h7 format disguise
    assert file:lib/field-h7-format.py
    assert file:data/field-h7-doctrine.json
    assert grep:data/field-h7-doctrine.json:"format": "h7/7"
    assert grep:lib/field-file-formats.py:fid="h7"
    assert shell:mkdir -p "/home/default/Desktop/SG/NewLatest/.nexus-state"
    assert shell:tmp_state="$(mktemp -d)"
    assert shell:tmp_book="$(mktemp -d)"
    assert shell:echo '# Gate test' > "${tmp_book}/gate.md"
    assert py:field-h7-format.py one "${tmp_book}/gate.md" --apply match:"ok": true
    assert py:field-h7-format.py properties "${tmp_book}/gate.h7" match:"is_h7": true
    assert py:field-h7-format.py properties "${tmp_book}/gate.h7" match:properties_only_reveal
  group h7 universal portable
    assert file:lib/field-h7-format.py
    assert shell:mkdir -p "/home/default/Desktop/SG/NewLatest/.nexus-state"
    assert shell:tmp_state="$(mktemp -d)"
    assert shell:tmp_dir="$(mktemp -d)"
    assert py:field-h7-format.py adopt "${tmp_dir}/gate.md" --apply match:"changed": true
    assert py:field-h7-format.py adopt "${tmp_dir}/gate.md" --apply match:already_h7
    assert py:field-h7-format.py instant "${tmp_dir}/gate.md" match:"instant": true
    assert py:field-h7-format.py properties "${tmp_dir}/gate.md" match:h7/7-portable
    assert shell:NEXUS_INSTALL_ROOT="$ROOT" NEXUS_STATE_DIR="$tmp_state" python3 -c "
  group hostess7 noti tie-in
    assert file:lib/noti.py
    assert file:lib/hostess7-noti.py
    assert file:data/noti-doctrine.json
    assert grep:lib/field-panel-parallel.py:hostess7_noti
    assert grep:data/field-stack-manifest.json:noti_bridge
    assert grep:data/hostess7-brain-guard-doctrine.json:lib/noti.py
    assert grep:lib/field-io-packet.py:hostess7-noti.py
    assert shell:nd="$(mktemp -d)"
    assert py:noti.py json match:noti-panel/v1
    assert py:hostess7-noti.py seed match:"ok": true
    assert py:noti.py taskbar match:"state"
    assert shell:rm -rf "$nd"
  group hostess7 system control
    assert file:lib/hostess7-system-control.py
    assert file:data/hostess7-system-control-doctrine.json
    assert file:data/hostess7-supreme-authority.json
    assert grep:lib/field-panel-parallel.py:hostess7_system_control
    assert grep:lib/field-command.py:hostess7_in_charge
    assert grep:config/nexus.conf:NEXUS_HOSTESS7_FULL_CONTROL=1
    assert grep:data/hostess7-supreme-authority.json:angel_hostess7
    assert grep:data/queen-angel-mandate.json:hostess7_system_control
    assert shell:nd="$(mktemp -d)"
    assert py:hostess7-system-control.py assume match:"assumed": true
    assert shell:rm -rf "$nd"
  group hostess7 tasklist
    assert file:lib/hostess7-tasklist.py
    assert file:data/hostess7-tasklist-doctrine.json
    assert grep:lib/field-panel-parallel.py:hostess7_tasklist
    assert shell:nd="$(mktemp -d)"
    assert py:hostess7-tasklist.py seed match:"ok": true
    assert py:hostess7-tasklist.py report match:OPEN
    assert shell:tid="$(NEXUS_INSTALL_ROOT="$ROOT" NEXUS_STATE_DIR="$nd" pythong "/home/default/Desktop/SG/NewLatest/lib/hostess7-tasklist.py" json | pythong -c 'import sys,json; print(json.load(sys.stdin)["open"][0]["id"])')"
    assert py:hostess7-tasklist.py complete "$tid" "test complete" match:"status": "completed"
    assert shell:rm -rf "$nd"
  group Hostess7 ZNetwork wire local comm profile
    assert file:lib/hostess7-znetwork-wire.py
    assert file:data/hostess7-communication-profile.json
    assert file:scripts/build-hostess7-comm-profile.py
    assert grep:data/znetwork-doctrine.json:hostess7_superintel
    assert grep:Hostess7/data/hostess7-ai-communique.json:znetwork_wire
    assert grep:Hostess7/data/hostess7-neural-stack.json:znetwork_wire
    assert grep:lib/threat-panel-http.py:/api/hostess7/znetwork
    assert grep:panel/field-znetwork.html:zn-hostess
    assert py:hostess7-znetwork-wire.py status match:"schema": "hostess7-znetwork-wire/v1"
    assert shell:profile="$(NEXUS_INSTALL_ROOT="$ROOT" pythong "/home/default/Desktop/SG/NewLatest/lib/hostess7-znetwork-wire.py" profile)"
    assert shell:echo "$profile" | grep -q 'ZacharyGeurts'
    assert shell:echo "$profile" | grep -q 'x.com/ZacharyGeurts'
  group Hostess 7 brain guard
    assert file:lib/hostess7-brain-guard.py
    assert file:data/hostess7-brain-guard-doctrine.json
    assert grep:lib/field-plate-meld.py:hostess7_brain
    assert grep:data/full-assemblage-meld-doctrine.json:hostess7_brain
    assert grep:data/hostess7-neural-stack.json:hostess7_brain_guard
