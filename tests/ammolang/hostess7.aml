    assert grep:lib/threat-panel-http.py:/api/hostess7/brain-guard
    assert grep:lib/threat-panel-http.py:/api/hostess7/brain-guard/witness
    assert grep:lib/threat-panel-http.py:/api/hostess7/self-view
    assert file:lib/hostess7-self-view.py
    assert file:data/hostess7-self-view-wants.json
    assert py:hostess7-self-view.py json match:first_person
    assert grep:data/simple-iron-plate-goals.json:hostess7_brain_guard
