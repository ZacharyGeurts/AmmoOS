    assert py:hostess7-brain-guard.py json match:panel_sha256
    assert py:hostess7-brain-guard.py verify match:guard_score
    assert py:hostess7-brain-guard.py witness match:hostess7-brain-guard-witness
    assert py:iron-plate-motion-resolve.py full-meld match:hostess7_brain
    assert py:universal-protector.py json match:hostess7_brain
  group Hostess 7 programming supremacy
    assert file:lib/hostess7-programming.py
