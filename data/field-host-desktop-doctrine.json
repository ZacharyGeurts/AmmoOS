    "right_click_context": true,
    "programs_as_windows": true,
    "nexus_integrated_launch": true,
    "no_client_browser": true,
    "queen_browser_only": true,
    "browser_in_c2": true,
    "browser_launcher_visible": false,
    "boot_program": "",
    "launch_at_c2_desktop": true,
    "launch_url": "/field",
    "kiosk_launch": true,
    "fullscreen_desktop": true,
    "fullscreen_over_host_taskbar": true,
    "kilroy_by_default": true,
