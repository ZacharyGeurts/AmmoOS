    "default_files_opener": "queen-files",
    "terminal_cwd_root": "kilroy",
    "taskbar_quick_only": true,
    "taskbar_show_running": false,
    "g16_taskbar": true,
    "start_menu_folders": true,
    "start_menu_collapsed": true,
    "monitor_dashboard_right": true,
    "auto_import_bookmarks": true
