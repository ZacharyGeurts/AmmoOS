    {"id": "audio", "name": "Audio", "glyph": "audio", "exec": "/field-audio-settings", "shell": true},
    {"id": "display", "name": "Display", "glyph": "display", "exec": "/control-panel", "shell": true},
    {"id": "bookmarks", "name": "Bookmarks", "glyph": "bookmark", "action": "bookmarks"},
