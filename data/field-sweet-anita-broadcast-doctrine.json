{
  "schema": "field-sweet-anita-broadcast/v1",
  "title": "Sweet_Anita · Field Broadcasting",
  "channel_name": "Sweet_Anita",
  "motto": "Twitch-style video tab — embedded panel preview, never tunnel desktop. Best dB for everyone. Decks and every major platform wired.",
  "branding": {
    "theme": "twitch",
    "primary_color": "#9146ff",
    "accent_color": "#f472b6",
