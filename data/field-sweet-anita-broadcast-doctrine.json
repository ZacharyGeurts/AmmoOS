    { "id": "kick", "name": "Kick", "protocol": "RTMP", "ingest": "rtmps://fa723fc1b171.global-contribute.live-video.net/app", "docs": "https://kick.com/dashboard/settings/stream" },
    { "id": "tiktok", "name": "TikTok Live", "protocol": "RTMP", "ingest": "rtmp://push-rtmp.tiktokcdn.com/live/", "docs": "https://www.tiktok.com/live/studio" },
    { "id": "facebook", "name": "Facebook Gaming", "protocol": "RTMPS", "ingest": "rtmps://live-api-s.facebook.com:443/rtmp", "docs": "https://www.facebook.com/gaming/streamer" },
    { "id": "rumble", "name": "Rumble", "protocol": "RTMP", "ingest": "rtmp://rumble.com/live", "docs": "https://rumble.com/account/livestream" },
    { "id": "instagram", "name": "Instagram Live", "protocol": "RTMPS", "ingest": "rtmps://live-upload.instagram.com:443/rtmp", "docs": "https://help.instagram.com/" },
    { "id": "linkedin", "name": "LinkedIn Live", "protocol": "RTMP", "ingest": "rtmp://rtmp.linkedin.com:1935/live", "docs": "https://www.linkedin.com/help/linkedin/answer/a568503" },
    { "id": "x", "name": "X (Twitter)", "protocol": "RTMP", "ingest": "rtmp://va.pscp.tv:80/x", "docs": "https://help.x.com/en/using-x/media-studio" }
