  "audio_best": {
    "sample_rate_hz": 48000,
    "buffer_ms": 10,
    "mic_peak_dbfs": { "floor": -18, "ceiling": -6, "target": -12 },
    "stream_lufs": { "integrated": -14, "true_peak_max_db": -1 },
    "noise_gate_db": -42,
    "motto": "48 kHz · clean passthrough default · Field Best filters opt-in"
  },
  "platforms": [
