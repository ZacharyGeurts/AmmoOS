    { "id": "touch_portal", "name": "Touch Portal", "protocol": "websocket", "default_port": 9080 },
    { "id": "companion", "name": "Bitfocus Companion", "protocol": "websocket", "default_port": 16622 },
    { "id": "deckboard", "name": "Deckboard", "protocol": "websocket" },
    { "id": "nexus_panel", "name": "NEXUS Panel tabs", "protocol": "field", "note": "Jump keys map to Sweet_Anita + US OBS" }
