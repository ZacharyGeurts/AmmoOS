{
  "schema": "queen-ammoos-sovereignty/v1",
  "title": "AmmoOS sovereignty — Queen underlying, ZNetwork owns the pipe",
  "motto": "AmmoOS · 127.0.0.1 · God Bless — Queen is the browser and the system; ZNetwork holds 100% of internet in/out; we are our own drivers on any hardware.",
  "product": "AmmoOS",
  "loopback_authority": "127.0.0.1",
  "local_only_control": true,
  "presume_sole_internet": true,
  "policy": {
    "queen_underlying_browser": true,
    "queen_full_system_control_local": true,
    "no_os_browser_primary": true,
    "no_foreign_network_stack": true,
    "znetwork_internet_pipe_percent_target": 100,
    "znetwork_always_full_pipe": true,
    "hardware_pipe_full": true,
    "own_drivers_on_any_hardware": true,
    "field_operator_iron_plate": true,
    "native_layer_authority": true,
    "ingress_egress_local_only_policy": true,
    "hardened_as_only_internet": true
  },
  "queen": {
    "browser": "Queen Browser",
    "engine": "queen-field-gecko",
    "shell": "/world/browser.html",
    "c2_loopback": "http://127.0.0.1:9477/field",
    "panel_loopback": "http://127.0.0.1:9477/command",
    "doctrine": "Queen/data/queen-field-browser-doctrine.json",
    "gates": "data/field-queen-gates-seed.json",
    "role": "Underlying browser + in-process field OS — full local control, no OS browser hook"
  },
  "local_services": {
    "truth_dns": "lib/field-dns.py",
    "field_dhcp": "lib/field-dhcp.py",
    "auto_connect": "lib/field-local-dns-connect.py",
    "takeover": "lib/dns-service-takeover.py",
    "loopback_resolver": "127.0.0.1",
    "dhcp_dns_option": "127.0.0.1",
    "policy": "Use our own local DHCP and DNS — connect when either starts",
    "motto": "Truth Resolver + Field DHCP on loopback — auto-steer resolv and DHCP client"
  },
  "znetwork": {
    "sole_internet_stack": true,
    "internet_pipe_percent": 100,
    "ingress_egress_owner": "znetwork",
    "relayer_default": true,
    "civilian_passthrough": true,
    "doctrine": "data/znetwork-doctrine.json",
    "modules": [
      "lib/znetwork-relayer.py",
      "lib/znetwork-orchestrator.py",
      "lib/znetwork-smart-inside.py",
      "lib/znetwork-exploit-shield.py"
    ],
    "motto": "100% of internet pipe — in and out through ZNetwork relayer; hostile interdict, civilian pass"
  },
  "hardware": {
    "own_drivers": true,
    "driver_doctrine": "We are our own drivers on any hardware — FieldGpuDispatch, FieldSurface, iron plate, IRQ/DMA/PCI/USB/net paths owned by field stack",
    "operator_doctrine": "data/field-operator-doctrine.json",
    "native_layer": "data/native-layer-doctrine.json",
    "layers": ["irq", "dma", "pci", "usb", "net", "input", "storage", "gpu", "audio"],
    "pipe": "full_hardware_wire_in_out"
  },
  "hardening": {
    "loopback_first": true,
    "truth_dns_sovereign": true,
    "connection_gatekeeper_iff": true,
    "packet_permission_v4": true,
    "zero_telemetry": true,
    "settings_surface_minimal": true,
    "best_settings_locked": true
  },
  "env": {
    "QUEEN_BROWSER_ONLY": "1",
    "QUEEN_NO_OS_BROWSER": "1",
    "NEXUS_FIELD_BROWSER_QUEEN": "1",
    "ZNETWORK_RELAYER": "1",
    "ZNETWORK_SMART_INSIDE": "1",
    "ZNETWORK_PROTECTION_ONLY": "0",
    "ZNETWORK_INTERNET_PIPE_TARGET": "100",
    "NEXUS_FIELD_DNS": "1",
    "NEXUS_FIELD_DHCP": "1",
    "NEXUS_FIELD_LOCAL_DNS_CONNECT": "1"
  }
}