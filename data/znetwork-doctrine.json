{
  "schema": "znetwork-doctrine/v2",
  "title": "ZNetwork — field secure network manager (NewLatest integrated)",
  "version": "2.0.0-field",
  "default_mode": "REVIEW_ONLY",
  "modes": ["REVIEW_ONLY", "SHADOW", "ACTIVE"],
  "meld_citation": "ironclad:meld:2",
  "sovereign_time": {
    "source": "lib/sovereign-clock.py",
    "role": "sole timestamp for activation receipts, tray swap, and status seals"
  },
  "truth_gate": {
    "required": ["ironclad", "field_sanity", "g1id_baselines", "voltage"],
    "role": "No activate, tray swap, or bridge attach without all gates green"
  },
  "taskbar_swap": {
    "on_activate": true,
    "icon": "znetwork-tray",
    "app_id": "znetwork-field-panel",
    "revert_on_deactivate": true,
    "state_file": "znetwork-tray-mode.json"
  },
  "field_bridges": {
    "connection_gatekeeper": "lib/connection-gatekeeper.py",
    "field_dns": "lib/field-dns.py",
    "packet_field": "lib/packet-field.py",
    "field_io_packet": "lib/field-io-packet.py",
    "trust_strike": "lib/trust-strike-engine.py",
    "attack_kit": "lib/field-attack-kit.py",
    "gatekeeper_enforce": "lib/gatekeeper-enforce.sh"
  },
  "active_gate": {
    "env": "ZNETWORK_REVIEW_APPROVED=1",
    "checklist": "znetwork/data/review-checklist.json",
    "approved_must_be": true
  },
  "orchestrator": "lib/znetwork-orchestrator.py",
  "shell_bridge": "lib/znetwork-field.sh",
  "binary_probe": "bin/znetwork",
  "plate_slot": "znetwork"
}