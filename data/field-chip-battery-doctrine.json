{
  "schema": "field-chip-battery-doctrine/v1",
  "title": "Universal chip battery — every die indexed for combinatorics",
  "motto": "Cyrix, CoCo, MAME, CHIPS — all silicon leaves on the combinatorics tree.",
  "module": "lib/field-chip-battery.py",
  "panel": "field-chip-battery-panel.json",
  "cache": "field-chip-battery.json",
  "seed": "data/field-chip-battery-seed.json",
  "mame_cache": "data/field-chip-battery-mame-cache.json",
  "combinatorics": {
    "facet": "chips_battery",
    "leaf_prefix": "chip",
    "doctrine": "Grok16/data/g16-field-combinatorics-doctrine.json"
  },
  "combinatronic": {
    "schema": "field-chips-combinatronic/v1",
    "title": "Universal CHIPS Combinatronic",
    "motto": "Every die a combinatorics leaf — hard path %, narrow bands, no wide piping.",
    "api": "/api/chips/combinatronic",
    "queen_surface": "/world/queen-chips-cores.html",
    "panel_cmd": "combinatronic",
    "visuals": {
      "doctrine": "data/field-combinatronic-visuals-doctrine.json",
      "catalog": "data/field-combinatronic-chip-catalog.json",
      "pattern": "chip_png",
      "repair": "field-combinatronic-visuals.py repair"
    }
  },
  "sources": [
    {"id": "seed", "label": "Curated seed — Cyrix, CoCo, classic MAME"},
    {"id": "mame", "label": "MAME -listdevices live import"},
    {"id": "chips_manifest", "label": "Queen CHIPS g16 hot paths"},
    {"id": "queen_game_room", "label": "Queen game room systems + host CPUs"},
    {"id": "isa_data", "label": "Hostess7 ISA opcode platforms"},
    {"id": "cpu_library", "label": "CPU library catalog — ARM, Apple, mobile, x86"}
  ],
  "thermal_gate": {
    "low_power_default": true,
    "env": "NEXUS_CHIP_BATTERY_LOW_POWER",
    "mame_live_env": "NEXUS_CHIP_BATTERY_MAME_LIVE",
    "headroom_min_pct": 12,
    "max_mame_live_devices": 8000
  },
  "kinds": [
    "host_cpu", "guest_cpu", "soc", "sound", "video", "pio", "mmu", "fdc",
    "mame_device", "chips_hot", "isa_platform", "gpu", "fpga", "network"
  ],
  "code_path_prediction": {
    "seed": "data/field-chip-path-predict-seed.json",
    "hard_percent": true,
    "narrow_band_width": 16,
    "pipe_policy": "adjacent_narrow_only",
    "power_sort_context": "chip_paths",
    "organize_algorithm": "narrow_band"
  }
}