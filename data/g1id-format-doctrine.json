{
  "schema": "g1id-format-doctrine/v1",
  "title": "G1ID — Geometric Identity (This One)",
  "extension": ".g1id",
  "media_type": "application/vnd.ironclad.g1id+json",
  "motto": "Cold file, 3D proportions only — this one hardened, plate preserved.",
  "thermal": {
    "policy": "cold_only",
    "hot_forbidden": true,
    "max_file_bytes": 65536,
    "max_array_items": 32,
    "atomic_write": true,
    "network_in_codec": false
  },
  "spatial": {
    "dimensions_allowed": 3,
    "axes": ["x", "y", "z"],
    "t_forbidden": true,
    "units_default": "m",
    "extent_max_m": 1000.0,
    "proportion_min": 0.001,
    "proportion_max": 1000.0
  },
  "identity": {
    "kind_locked": "this_one",
    "that_one_forbidden_in_file": true,
    "citation": "ironclad:spatial_existence:1",
    "sealed_anchor": "ironclad:place:2"
  },
  "plate": {
    "preserved": true,
    "verify_on_read": true,
    "fields": ["canonical_hash", "immutable", "realized"],
    "amendment_forbidden": true
  },
  "payload_schema": "g1-geometric-identity/v1",
  "example": "data/examples/operator-this-one.g1id",
  "integrations": {
    "spatial_existence": "lib/ironclad-spatial-existence.py",
    "ironclad_plate": "lib/ironclad-plate.py",
    "g16_bridge": "Grok16/forge/g16-g1id.py"
  }
}