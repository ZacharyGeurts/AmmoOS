    "FIELD_SOVEREIGN_STACK_MELD": "1",
    "AMMOOS_CORE_FUSED": "1",
    "QUEEN_SHELL_OUTER_ONLY": "1",
    "QUEEN_CANVAS_SHADER": "CANVAS",
    "AMOURANTHRTX_DEMO": "0",
    "AMMOOS_INSIDE_QUEEN": "0",
    "QUEEN_DEFENDS_WITH_NEXUS": "1",
    "QUEEN_DEFENDS_WITH_ZNETWORK": "1",
    "HARDWARE_NO_BREAK": "1"
