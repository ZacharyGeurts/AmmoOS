{
  "schema": "field-stack-layer/v1",
  "title": "Field stack layers — sovereign core · blocks · Queen shell",
  "version": "1.2.0",
  "motto": "NEXUS C2 · KILROY · AmmoOS fused tight. CHIPS blocks nested. Queen shell outer. Plate meld seals — nobody in between.",
  "statement": "Sovereign core (C2+KILROY+AmmoOS) melds first; CHIPS and child blocks stack inside; Queen browser is the outer shell only. ZNetwork absorbed in KILROY lane — not a gap tier.",
